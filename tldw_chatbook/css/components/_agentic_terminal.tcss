/* ========================================
 * COMPONENTS: Agentic Terminal Design System
 * ========================================
 * Shared shell primitives for Home, Console, destination wrappers, status,
 * recovery, source authority, approvals, events, forms, toolbars, and shortcuts.
 *
 * Semantic token contract:
 * ds-surface-panel, ds-text-primary, ds-action-focus,
 * ds-status-ready, ds-status-running, ds-status-warning, ds-status-error,
 * ds-status-paused, ds-status-blocked, ds-status-approval-required,
 * ds-authority-local, ds-authority-server, ds-authority-workspace,
 * ds-source-role-context, ds-source-role-evidence,
 * ds-source-role-editable-target, ds-source-role-output-seed.
 *
 * Required readable status labels:
 * Ready, Running, Paused, Blocked, Unavailable, Approval required, Unsaved, Recovered.
 * ======================================== */

.ds-destination-header {
    height: auto;
    min-height: 3;
    padding: 1 2;
    margin: 0 0 1 0;
    border: tall $ds-action-focus;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.ds-panel {
    height: auto;
    min-height: 3;
    padding: 1 2;
    margin: 0 0 1 0;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.ds-inspector {
    height: auto;
    min-width: 24;
    padding: 1;
    border: round $ds-grid-line;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.ds-status-badge {
    width: auto;
    height: 1;
    padding: 0 1;
    text-style: bold;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.ds-recovery-callout {
    height: auto;
    padding: 1 2;
    border: round $ds-status-warning;
    background: $ds-status-warning 10%;
    color: $ds-text-primary;
}

.ds-source-role {
    width: auto;
    height: 1;
    padding: 0 1;
    border: round $ds-source-role-context;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.ds-approval-card {
    height: auto;
    padding: 1 2;
    border: thick $ds-status-approval-required;
    background: $ds-status-approval-required 12%;
    color: $ds-text-primary;
}

.ds-event-row {
    height: auto;
    min-height: 1;
    padding: 0 1;
    border-bottom: solid $ds-grid-line;
    color: $ds-text-primary;
}

.ds-field-row {
    height: auto;
    min-height: 2;
    padding: 0 1;
    layout: horizontal;
}

.ds-toolbar {
    height: auto;
    min-height: 1;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#home-dashboard,
#console-shell,
#library-shell,
#artifacts-shell,
#personas-shell,
#watchlists-collections-shell,
#schedules-shell,
#mcp-shell,
#acp-shell,
#skills-shell,
#settings-shell {
    height: 100%;
    min-height: 0;
}

#home-title,
#console-title,
#library-title,
#artifacts-title,
#personas-title,
#watchlists-collections-title,
#schedules-title,
#workflows-title,
#mcp-title,
#acp-title,
#skills-title,
#settings-title {
    height: $ds-destination-header-height;
    min-height: $ds-destination-header-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#home-purpose,
#console-purpose,
#library-purpose,
#artifacts-purpose,
#mcp-purpose,
#console-status-row,
#library-status-row,
#console-mode-bar,
#artifacts-mode-strip,
#personas-mode-strip,
#watchlists-filter-strip,
#schedules-filter-strip,
#workflows-mode-strip,
#mcp-mode-strip,
#acp-purpose,
#acp-mode-strip,
#skills-mode-strip,
#settings-category-strip {
    height: $ds-destination-compact-strip-height;
    min-height: $ds-destination-compact-strip-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

.destination-action-button {
    height: 1;
    min-height: 1;
    padding: 0 1;
}

.home-dashboard-region,
.console-region,
.library-region,
#artifacts-list-pane,
#artifacts-detail-pane,
#artifacts-inspector-pane,
#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#mcp-server-tree-pane,
#mcp-detail-pane,
#mcp-readiness-pane,
#acp-list-pane,
#acp-detail-pane,
#acp-inspector-pane,
#skills-list-pane,
#skills-detail-pane,
#skills-inspector-pane,
#settings-category-pane,
#settings-detail-pane,
#settings-impact-pane,
#ccp-character-library-pane,
#ccp-behavior-detail-pane,
#ccp-attachment-inspector-pane {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#settings-category-pane {
    width: 1fr;
}

#settings-detail-pane,
#settings-impact-pane {
    width: 2fr;
}

#home-dashboard-grid {
    height: $ds-home-dashboard-grid-height;
    min-height: $ds-home-dashboard-grid-height;
    padding: 0 1;
    margin: 0;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#home-status-row,
#home-status,
#home-status-body,
#home-scope-filter-row,
#home-action-hints {
    height: $ds-home-compact-row-height;
    min-height: $ds-home-compact-row-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

.home-dashboard-region {
    min-height: 0;
}

#home-attention-queue,
#home-active-work-region,
#home-inspector,
#home-next-actions-region,
#home-recent-work-region {
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

.home-narrow-pane {
    width: 1fr;
}

.home-wide-pane {
    width: 2fr;
}

.home-pane-divider {
    width: 1;
    min-width: 1;
    height: 100%;
    min-height: 0;
    background: $ds-column-line;
}

.destination-pane-divider {
    width: 1;
    min-width: 1;
    height: 100%;
    min-height: 0;
    background: $ds-grid-line;
}

#home-attention,
#home-system-status,
#home-next-best-action,
#home-recent-work {
    height: $ds-home-compact-row-height;
    min-height: $ds-home-compact-row-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#home-followup-row {
    height: $ds-home-followup-row-height;
    min-height: 0;
    margin: 1 0 0 0;
}

.home-followup-region {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
    margin: 0;
}

#home-active-work-region .ds-toolbar {
    height: $ds-home-control-button-height;
    min-height: $ds-home-control-button-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#console-workspace-grid {
    height: $ds-console-workspace-grid-height;
    min-height: 20;
    padding: 0 1;
    margin: 0;
    overflow: hidden;
    border-top: solid $ds-grid-line;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#console-control-bar {
    height: $ds-console-control-bar-height;
    min-height: $ds-console-control-bar-height;
    padding: 0 1;
    margin: 0;
    overflow: hidden;
}

.console-control-summary-line {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
}

.console-hidden-control {
    display: none;
}

#console-staged-context-tray,
#console-main-column,
#console-run-inspector {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
}

#console-staged-context-tray {
    width: 5fr;
    min-width: 40;
}

#console-main-column {
    width: 9fr;
    min-width: 52;
    padding: 0 1;
}

#console-run-inspector {
    width: 5fr;
    min-width: 40;
}

#console-staged-context-tray,
#console-run-inspector,
#console-transcript-region {
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#console-run-inspector-state {
    height: auto;
    min-height: 0;
}

.console-inspector-group-heading {
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-inspector-action {
    height: 1;
    min-height: 1;
    margin: 0;
}

.console-inspector-disabled-reason {
    height: 0;
    min-height: 0;
}

.console-live-work-source-readiness {
    height: auto;
    min-height: 0;
    margin: 1 0 0 0;
}

.console-live-work-source-row {
    height: auto;
    min-height: 1;
}

#console-transcript-region,
#console-session-surface {
    height: 1fr;
    min-height: 0;
}

#console-transcript-region {
    padding: 0 1;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
}

.console-start-here,
.console-provider-blocker,
.console-action-hints {
    height: auto;
    min-height: 1;
    padding: 0 1;
}

.console-start-here {
    margin: 0 0 1 0;
    border-left: solid $ds-action-focus;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.console-provider-blocker {
    margin: 0 0 1 0;
    border-left: solid $ds-status-warning;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-action-hints {
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

#console-native-composer {
    height: auto;
    min-height: $ds-console-composer-height;
    max-height: 8;
    padding: 1;
    margin: 0;
    layout: horizontal;
    align: left middle;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
}

#console-composer-title,
#console-composer-status,
.console-control-label {
    height: 1;
    min-height: 1;
}

#console-composer-title {
    width: 10;
    min-width: 10;
}

#console-command-visible-text {
    width: 1fr;
    min-width: 0;
    height: auto;
    min-height: 1;
    max-height: 4;
    margin: 0 1 0 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    overflow: hidden;
}

#console-native-composer:focus-within #console-command-visible-text,
#console-command-visible-text:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-command-input {
    display: none;
    width: 0;
    min-width: 0;
    height: 0;
    min-height: 0;
}

#console-composer-status {
    width: auto;
    min-width: 0;
}

#console-session-surface .chat-input-area {
    display: none;
}

.console-transcript-system-event {
    height: auto;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    border-left: solid $ds-status-warning;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-session-surface,
#console-chat-tabs,
#console-chat-tabs #chat-sessions-container,
#console-chat-tabs .chat-session {
    height: 100%;
    min-height: 0;
}

#console-session-surface .chat-empty-state {
    min-height: 5;
    padding: 0 1;
    text-align: left;
    content-align: left top;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#console-session-surface .chat-log {
    padding: 0 1;
    background: $ds-surface-panel;
    border: tall $ds-grid-line;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
    scrollbar-size: 1 1;
}

#console-send-message,
#console-stop-generation {
    width: 8;
    min-width: 8;
}

#console-send-message,
#console-stop-generation,
#console-attach-context,
#console-save-chatbook {
    height: 1;
    min-height: 1;
    color: $ds-text-primary;
    text-style: bold;
}

#console-attach-context {
    width: 10;
    min-width: 10;
}

#console-save-chatbook {
    width: 22;
    min-width: 22;
}

.console-control-label,
.console-staged-context-row,
.console-staged-context-summary,
.console-staged-context-recovery {
    width: auto;
    min-width: 0;
    height: auto;
}

.console-compact-model-bar {
    width: auto;
    min-width: 0;
}

#library-mode-bar {
    height: $ds-library-mode-bar-height;
    min-height: $ds-library-mode-bar-height;
    padding: 0 1;
    margin: 0;
    overflow: hidden;
}

#library-mode-label {
    width: $ds-library-mode-label-width;
    min-width: $ds-library-mode-label-width;
    height: $ds-library-mode-bar-height;
    min-height: $ds-library-mode-bar-height;
}

.library-mode-chip {
    width: auto;
    min-width: 0;
    height: $ds-library-mode-chip-height;
    min-height: $ds-library-mode-chip-height;
    padding: 0 1;
    border: none;
}

#library-contract-grid,
#artifacts-workbench,
#personas-workbench,
#watchlists-workbench,
#schedules-workbench,
#workflows-workbench,
#mcp-workbench,
#acp-workbench,
#skills-workbench,
#settings-workbench {
    height: 1fr;
    min-height: 20;
    padding: 1;
    margin: 0;
    overflow: hidden;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#personas-workbench {
    padding: 1;
    border: solid #6f6f6f;
}

#artifacts-list-pane,
#artifacts-detail-pane,
#artifacts-inspector-pane,
#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#mcp-server-tree-pane,
#mcp-detail-pane,
#mcp-readiness-pane,
#acp-list-pane,
#acp-detail-pane {
    margin: 0 1 0 0;
}

#artifacts-inspector-pane,
#personas-inspector-pane,
#watchlists-inspector-pane,
#schedules-inspector-pane,
#workflows-inspector-pane,
#mcp-readiness-pane,
#acp-inspector-pane {
    margin: 0;
}

#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#acp-list-pane,
#acp-detail-pane,
#acp-inspector-pane {
    height: 100%;
    min-height: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#personas-list-pane {
    width: 2fr;
    min-width: 26;
    border: solid #6f6f6f;
    padding: 1;
}

#personas-detail-pane {
    width: 4fr;
    min-width: 42;
    border: solid #6f6f6f;
    padding: 1;
}

#personas-inspector-pane {
    width: 2fr;
    min-width: 30;
    border: solid #6f6f6f;
    padding: 1;
}

#schedules-list-pane,
#workflows-list-pane,
#acp-list-pane {
    width: 2fr;
    min-width: 30;
    border: solid #6f6f6f;
    padding: 1;
}

#schedules-detail-pane,
#workflows-detail-pane,
#acp-detail-pane {
    width: 4fr;
    min-width: 52;
    border: solid #6f6f6f;
    padding: 1;
}

#schedules-inspector-pane,
#workflows-inspector-pane,
#acp-inspector-pane {
    width: 2fr;
    min-width: 34;
    border: solid #6f6f6f;
    padding: 1;
}

#personas-selected-target-card,
#personas-readiness-card {
    width: 100%;
    height: auto;
    margin: 1 0;
    padding: 1;
    border: solid #6f6f6f;
    background: $ds-surface-raised;
}

#personas-selected-target-title,
#personas-readiness-title {
    text-style: bold;
}

.acp-selected-session-row {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-surface-raised;
    text-style: bold;
}

.acp-inspector-group-title {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

#personas-list-detail-divider,
#personas-detail-inspector-divider,
#watchlists-list-detail-divider,
#watchlists-detail-inspector-divider,
#schedules-list-detail-divider,
#schedules-detail-inspector-divider,
#workflows-list-detail-divider,
#workflows-detail-inspector-divider,
#acp-list-detail-divider,
#acp-detail-inspector-divider {
    background: $ds-grid-line;
}

#personas-list-detail-divider,
#personas-detail-inspector-divider {
    background: #7a7a7a;
}

.artifacts-column-title,
.personas-column-title,
.watchlists-column-title,
.schedules-column-title,
.workflows-column-title,
.acp-column-title,
.skills-column-title,
.ccp-column-title,
.settings-column-title {
    width: 100%;
    height: 1;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

#library-source-browser,
#library-source-detail,
#library-source-inspector {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    overflow-y: auto;
}

.ds-shortcut-bar {
    dock: bottom;
    height: 1;
    padding: 0 1;
    background: $ds-surface-inspector;
    color: $ds-text-muted;
}

.density-compact .ds-panel,
.density-compact .ds-inspector,
.density-compact .ds-approval-card,
.density-compact .ds-recovery-callout {
    padding: 0 1;
    margin: 0 0 1 0;
}

.density-compact .ds-destination-header {
    min-height: 2;
    padding: 0 1;
}

.density-comfortable .ds-panel,
.density-comfortable .ds-inspector,
.density-comfortable .ds-approval-card,
.density-comfortable .ds-recovery-callout {
    padding: 1 2;
    margin: 1 1;
}

.density-comfortable .ds-destination-header {
    min-height: 4;
    padding: 1 2;
}

.is-active {
    border: round $ds-action-focus;
    text-style: bold;
}

.library-mode-chip.is-active {
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.library-source-action {
    width: $ds-library-source-action-width;
    min-width: $ds-library-source-action-min-width;
    height: $ds-library-source-action-height;
    min-height: $ds-library-source-action-height;
    margin: 0;
}

.is-disabled {
    opacity: 0.55;
}

.is-blocked {
    border: round $ds-status-error;
    background: $ds-status-error 10%;
}

.is-running {
    border: round $ds-status-running;
}

.is-paused {
    border: round $ds-status-paused;
}

.is-unsaved {
    border: round $ds-status-unsaved;
}

.is-stale {
    color: $ds-text-muted;
}

.is-conflict {
    border: thick $ds-status-error;
}

.needs-approval {
    border: thick $ds-status-approval-required;
    background: $ds-status-approval-required 12%;
}

.source-local {
    border: round $ds-authority-local;
}

.source-server {
    border: round $ds-authority-server;
}

.source-workspace {
    border: round $ds-authority-workspace;
}

.source-remote-only {
    border: round $ds-authority-remote-only;
}

.source-dry-run {
    border: dashed $ds-grid-line;
    color: $ds-text-muted;
}
