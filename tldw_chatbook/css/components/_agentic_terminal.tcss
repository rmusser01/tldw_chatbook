/* ========================================
 * COMPONENTS: Agentic Terminal Design System
 * ========================================
 * Shared shell primitives for Home, Console, destination wrappers, status,
 * recovery, source authority, approvals, events, forms, toolbars, and shortcuts.
 *
 * Semantic token contract:
 * ds-surface-panel, ds-text-primary, ds-action-focus,
 * ds-status-ready, ds-status-running, ds-status-warning, ds-status-error,
 * ds-status-paused, ds-status-blocked, ds-status-approval-required,
 * ds-authority-local, ds-authority-server, ds-authority-workspace,
 * ds-source-role-context, ds-source-role-evidence,
 * ds-source-role-editable-target, ds-source-role-output-seed.
 *
 * Required readable status labels:
 * Ready, Running, Paused, Blocked, Unavailable, Approval required, Unsaved, Recovered.
 * ======================================== */

.ds-destination-header {
    height: auto;
    min-height: 3;
    padding: 1 2;
    margin: 0 0 1 0;
    border: tall $ds-action-focus;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.ds-panel {
    height: auto;
    min-height: 3;
    padding: 1 2;
    margin: 0 0 1 0;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.ds-inspector {
    height: auto;
    min-width: 24;
    padding: 1;
    border: round $ds-grid-line;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.ds-status-badge {
    width: auto;
    height: 1;
    padding: 0 1;
    text-style: bold;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.ds-recovery-callout {
    height: auto;
    padding: 1 2;
    border: round $ds-status-warning;
    background: $ds-status-warning 10%;
    color: $ds-text-primary;
}

.ds-source-role {
    width: auto;
    height: 1;
    padding: 0 1;
    border: round $ds-source-role-context;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.ds-approval-card {
    height: auto;
    padding: 1 2;
    border: thick $ds-status-approval-required;
    background: $ds-status-approval-required 12%;
    color: $ds-text-primary;
}

.ds-event-row {
    height: auto;
    min-height: 1;
    padding: 0 1;
    border-bottom: solid $ds-grid-line;
    color: $ds-text-primary;
}

.ds-field-row {
    height: auto;
    min-height: 2;
    padding: 0 1;
    layout: horizontal;
}

.ds-toolbar {
    height: auto;
    min-height: 1;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

ConsoleSettingsModal {
    align: center middle;
}

#console-settings-modal {
    width: 92;
    max-width: 95%;
    height: 90%;
    max-height: 95%;
    overflow: hidden;
    scrollbar-size: 1 1;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
    padding: 1 2;
}

#console-settings-body {
    height: 1fr;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

.console-settings-modal-section {
    height: auto;
    margin: 1 0 0 0;
}

.console-settings-primary-section {
    padding: 0 1;
    border: round $ds-action-focus;
    background: $ds-surface-raised;
}

.console-settings-modal-row {
    height: auto;
    min-height: 1;
}

.console-settings-modal-label {
    width: 16;
    min-width: 16;
    max-width: 16;
    height: 1;
    min-height: 1;
    content-align: left middle;
}

.console-settings-control {
    width: 1fr;
    min-width: 0;
}

ConsoleSettingsModal Input {
    width: 1fr;
    min-width: 0;
    height: 3;
    min-height: 3;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

ConsoleSettingsModal Checkbox {
    height: 1;
    min-height: 1;
}

ConsoleSettingsModal Select > SelectCurrent {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    content-align: left middle;
}

ConsoleSettingsModal Select > SelectCurrent Static#label {
    width: 1fr;
    height: 1;
    background: transparent;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select > SelectCurrent .arrow {
    background: transparent;
    color: $ds-text-muted;
}

ConsoleSettingsModal Input:focus {
    height: 3;
    min-height: 3;
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

ConsoleSettingsModal Input > .input--cursor {
    background: $ds-input-focus-accent;
    color: $ds-surface-panel;
}

ConsoleSettingsModal Input > .input--selection {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
}

ConsoleSettingsModal Select:focus {
    border: none;
    border-bottom: none;
    outline: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select:focus > SelectCurrent {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

ConsoleSettingsModal Select > SelectOverlay {
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    min-width: 30;
}

ConsoleSettingsModal Select > SelectOverlay Option {
    padding: 0 2;
    min-height: 3;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select > SelectOverlay Option:hover {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select > SelectOverlay Option.-selected {
    padding: 0 2;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-settings-modal-actions {
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    align-horizontal: right;
}

#console-settings-cancel,
#console-settings-save {
    width: 12;
    min-width: 12;
    height: 1;
    min-height: 1;
}

.console-settings-error {
    height: auto;
    min-height: 1;
    max-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-status-error 10%;
    color: $ds-text-primary;
}

#home-dashboard,
#console-shell,
#library-shell,
#notes-shell,
#artifacts-shell,
#personas-shell,
#watchlists-collections-shell,
#schedules-shell,
#mcp-shell,
#acp-shell,
#skills-shell,
#settings-shell {
    height: 100%;
    min-height: 0;
}

#home-title,
#console-title,
#library-title,
#notes-title,
#artifacts-title,
#personas-title,
#watchlists-collections-title,
#schedules-title,
#workflows-title,
#mcp-title,
#acp-title,
#skills-title,
#settings-title {
    height: $ds-destination-header-height;
    min-height: $ds-destination-header-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#home-purpose,
#console-purpose,
#library-purpose,
#artifacts-purpose,
#mcp-purpose,
#console-status-row,
#library-status-row,
#notes-mode-strip,
#console-mode-bar,
#artifacts-mode-strip,
#personas-mode-strip,
#watchlists-filter-strip,
#schedules-filter-strip,
#workflows-mode-strip,
#mcp-mode-strip,
#acp-purpose,
#acp-mode-strip,
#skills-mode-strip,
#settings-category-strip {
    height: $ds-destination-compact-strip-height;
    min-height: $ds-destination-compact-strip-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

.destination-action-button {
    height: 1;
    min-height: 1;
    padding: 0 1;
}

Button#console-open-provider-settings.console-provider-api-key-action {
    border: none;
    outline: none;
    background: $ds-status-warning;
    color: $background;
    text-opacity: 1;
    text-style: bold;
}

Button#console-open-provider-settings.console-provider-api-key-action:hover,
Button#console-open-provider-settings.console-provider-api-key-action:focus,
Button#console-open-provider-settings.console-provider-api-key-action:hover:focus {
    border: none;
    outline: none;
    background: $ds-status-warning;
    color: $background;
    text-opacity: 1;
    text-style: bold underline;
}

.home-dashboard-region,
.console-region,
.library-region,
#artifacts-list-pane,
#artifacts-detail-pane,
#artifacts-inspector-pane,
#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#mcp-server-tree-pane,
#mcp-detail-pane,
#mcp-readiness-pane,
#acp-list-pane,
#acp-detail-pane,
#acp-inspector-pane,
#skills-list-pane,
#skills-detail-pane,
#skills-inspector-pane,
#settings-category-pane,
#settings-detail-pane,
#settings-impact-pane,
#ccp-character-library-pane,
#ccp-behavior-detail-pane,
#ccp-attachment-inspector-pane {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#settings-category-pane {
    width: 3fr;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#settings-detail-pane {
    width: 6fr;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#settings-impact-pane {
    width: 2fr;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#home-dashboard-grid {
    height: $ds-home-dashboard-grid-height;
    min-height: $ds-home-dashboard-grid-height;
    padding: 0 1;
    margin: 0;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#home-status-row,
#home-status,
#home-status-body,
#home-scope-filter-row,
#home-action-hints {
    height: $ds-home-compact-row-height;
    min-height: $ds-home-compact-row-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

.home-dashboard-region {
    min-height: 0;
}

#home-attention-queue,
#home-active-work-region,
#home-inspector,
#home-next-actions-region,
#home-recent-work-region {
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

.home-narrow-pane {
    width: 1fr;
}

.home-wide-pane {
    width: 2fr;
}

.home-pane-divider {
    width: 1;
    min-width: 1;
    height: 100%;
    min-height: 0;
    background: $ds-column-line;
}

.destination-pane-divider {
    width: 1;
    min-width: 1;
    height: 100%;
    min-height: 0;
    background: $ds-grid-line;
}

#home-attention,
#home-system-status,
#home-next-best-action,
#home-recent-work {
    height: $ds-home-compact-row-height;
    min-height: $ds-home-compact-row-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#home-followup-row {
    height: $ds-home-followup-row-height;
    min-height: 0;
    margin: 1 0 0 0;
}

.home-followup-region {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
    margin: 0;
}

#home-active-work-region .ds-toolbar {
    height: $ds-home-control-button-height;
    min-height: $ds-home-control-button-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#console-workspace-grid {
    height: $ds-console-workspace-grid-height;
    min-height: 20;
    padding: 0 1;
    margin: 0;
    overflow: hidden;
    border-top: solid $ds-grid-line;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#console-control-bar {
    height: $ds-console-control-bar-height;
    min-height: $ds-console-control-bar-height;
    padding: 0 1;
    margin: 0;
    overflow: hidden;
}

.console-control-summary-line {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
}

.console-hidden-control {
    display: none;
}

#console-staged-context-tray,
#console-workspace-context,
#console-run-inspector {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
}

#console-main-column,
#console-right-rail {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
}

#console-staged-context-tray,
#console-workspace-context {
    width: 100%;
    min-width: 0;
}

#console-staged-context-tray {
    height: auto;
    min-height: 4;
    max-height: 10;
}

#console-workspace-context {
    height: 1fr;
    min-height: 8;
}

#console-left-rail {
    height: 100%;
    min-height: 0;
    overflow: hidden;
}

#console-left-rail-body {
    width: 100%;
    min-width: 0;
    height: 1fr;
    min-height: 0;
    padding: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#console-inspector-rail-body {
    width: 100%;
    min-width: 0;
    height: 1fr;
    min-height: 0;
    padding: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#console-main-column {
    width: 13fr;
    min-width: 60;
    padding: 0;
}

#console-right-rail {
    width: 4fr;
    min-width: 34;
    overflow: hidden;
}

#console-staged-context-tray,
#console-workspace-context,
#console-right-rail,
#console-run-inspector,
#console-transcript-region {
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#console-staged-context-tray.console-frame-quiet,
#console-workspace-context.console-frame-quiet {
    border: none;
    background: $ds-surface-panel;
}

#console-run-inspector {
    width: 100%;
    min-width: 0;
    height: auto;
    min-height: 0;
    border: none;
}

#console-run-inspector-state {
    height: auto;
    min-height: 0;
}

.console-rail-handle {
    width: 13;
    min-width: 13;
    max-width: 13;
    height: 100%;
    min-height: 20;
    padding: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

.console-rail-handle-right {
    width: 11;
    min-width: 11;
    max-width: 11;
    height: auto;
    min-height: 3;
    max-height: 6;
    border: none;
    background: transparent;
}

.console-rail-handle-button {
    width: 11;
    min-width: 0;
    max-width: 11;
    height: 100%;
    min-height: 100%;
    max-height: 100%;
    text-align: center;
    content-align: center middle;
}

.console-rail-handle-button-right {
    width: 11;
    max-width: 11;
    height: 3;
    min-height: 3;
    max-height: 3;
}

.console-rail-collapse-button {
    height: 1;
    min-height: 1;
    text-align: left;
    content-align: left middle;
}

.console-rail-handle-badge {
    height: auto;
    min-height: 1;
    width: 100%;
    text-align: center;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.console-rail-header {
    height: 1;
    min-height: 1;
    layout: horizontal;
}

.console-rail-title {
    width: 1fr;
    min-width: 0;
    text-align: left;
    content-align: left middle;
}

.console-inspector-group-heading {
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-inspector-status-summary {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-inspector-action {
    height: 1;
    min-height: 1;
    margin: 0;
}

.console-inspector-disabled-reason {
    height: 0;
    min-height: 0;
}

.console-live-work-source-readiness {
    height: auto;
    min-height: 0;
    margin: 1 0 0 0;
}

.console-live-work-source-row {
    height: auto;
    min-height: 1;
}

.console-settings-summary {
    height: auto;
    min-height: 9;
    padding: 0 1;
}

.console-left-rail-section.console-settings-summary {
    margin: 0 0 1 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-panel;
}

.console-settings-header {
    height: 1;
    min-height: 1;
    layout: horizontal;
    align: left middle;
}

.console-settings-title {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
    max-height: 1;
}

.console-settings-row {
    height: 1;
    min-height: 1;
    max-height: 1;
    overflow: hidden hidden;
    text-wrap: nowrap;
    text-overflow: ellipsis;
}

#console-settings-open {
    width: auto;
    min-width: 9;
    max-width: 14;
    height: 1;
    min-height: 1;
    margin: 0;
}

#console-transcript-region,
#console-session-surface {
    height: 1fr;
    min-height: 0;
}

#console-session-surface {
    padding: 0;
    margin: 0;
    border: none;
}

#console-transcript-region {
    padding: 0 1;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
}

.console-start-here,
.console-provider-blocker,
.console-action-hints {
    height: auto;
    min-height: 1;
    padding: 0 1;
}

.console-start-here {
    margin: 0;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

#console-start-here,
#console-action-hints {
    display: none;
    height: 0;
    min-height: 0;
    max-height: 0;
    padding: 0;
    margin: 0;
}

.console-provider-blocker {
    margin: 0 0 1 0;
    border: solid $ds-status-warning;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-action-hints {
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

#console-native-composer {
    height: auto;
    min-height: $ds-console-composer-height;
    max-height: 8;
    padding: 1;
    margin: 0;
    layout: horizontal;
    align: left middle;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
}

#console-native-composer.console-composer-has-draft {
    border: round $ds-status-ready;
}

#console-native-composer.console-composer-focused {
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
}

#console-native-composer.console-composer-setup-blocked #console-command-visible-text {
    color: $ds-status-warning;
}

#console-composer-title,
#console-composer-status,
.console-control-label {
    height: 1;
    min-height: 1;
}

#console-composer-title {
    width: 10;
    min-width: 10;
}

#console-command-visible-text {
    width: 1fr;
    min-width: 0;
    height: auto;
    min-height: 1;
    max-height: 4;
    margin: 0 1 0 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    overflow: hidden;
}

#console-native-composer.console-composer-has-draft #console-command-visible-text,
#console-native-composer:focus-within #console-command-visible-text,
#console-command-visible-text:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-composer-actions {
    width: 37;
    min-width: 37;
    max-width: 37;
    height: 1;
    min-height: 1;
    layout: horizontal;
    align: right middle;
}

#console-command-input {
    display: none;
    width: 0;
    min-width: 0;
    height: 0;
    min-height: 0;
}

#console-composer-status {
    width: auto;
    min-width: 0;
}

#console-session-surface .chat-input-area {
    display: none;
}

.console-transcript-system-event {
    height: auto;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    border-left: solid $ds-status-warning;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-chat-tabs,
#console-chat-tabs #chat-sessions-container,
#console-chat-tabs .chat-session {
    height: 100%;
    min-height: 0;
}

#console-transcript-surface {
    height: 1fr;
    min-height: 0;
    layers: console-background console-content;
}

#console-transcript-background-effect {
    layer: console-background;
    width: 100%;
    height: 100%;
    color: $ds-text-muted;
    background: transparent;
}

#console-native-transcript {
    height: 1fr;
    min-height: 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
    scrollbar-size: 1 1;
}

#console-transcript-surface #console-native-transcript {
    layer: console-content;
    height: 1fr;
    min-height: 0;
    background: transparent;
}

#console-transcript-title,
.console-transcript-title {
    height: 1;
    min-height: 1;
    max-height: 1;
    margin: 0;
    background: $ds-surface-panel;
    color: $ds-text-muted;
    text-style: none;
}

#console-native-tab-strip,
.console-session-tab-strip {
    height: 1;
    min-height: 1;
    max-height: 1;
    margin: 0;
    background: $ds-surface-panel;
}

.console-session-tab,
#console-new-chat-tab {
    width: auto;
    min-width: 8;
    height: 1;
    min-height: 1;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-session-close-button {
    padding: 0;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.console-session-tab-active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-session-tab-active:hover,
.console-session-tab-active:hover:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

#console-native-transcript:focus {
    border: solid $ds-focus-accent;
    border-bottom: solid $ds-focus-accent;
}

.console-transcript-rule {
    height: 1;
    min-height: 1;
    color: $ds-grid-line;
}

.console-transcript-message {
    height: auto;
    min-height: 2;
    padding: 0 1;
    margin: 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.console-transcript-message-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-transcript-action-row {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-transcript-action-button {
    width: auto;
    min-width: 0;
    height: 1;
    min-height: 1;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-transcript-action-button:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

.console-workspace-selector-row {
    margin: 0 0 1 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.console-workspace-action {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
}

.console-transcript-empty-state {
    height: auto;
    min-height: 2;
    padding: 0 1;
    color: $ds-text-muted;
}

#console-chat-tabs {
    display: none;
}

#console-session-surface .chat-empty-state {
    min-height: 5;
    padding: 0 1;
    text-align: left;
    content-align: left top;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#console-session-surface .chat-log {
    padding: 0 1;
    background: $ds-surface-panel;
    border: tall $ds-grid-line;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
    scrollbar-size: 1 1;
}

#console-send-message,
#console-stop-generation {
    width: 8;
    min-width: 8;
}

#console-send-message,
#console-stop-generation,
#console-attach-context,
#console-save-chatbook {
    height: 1;
    min-height: 1;
}

#console-attach-context {
    width: 10;
    min-width: 10;
}

#console-save-chatbook {
    width: 8;
    min-width: 8;
}

.console-action-primary {
    border: none;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

.console-action-secondary {
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-action-subdued {
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: none;
}

.console-action-disabled {
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-disabled;
    text-style: none;
}

.console-action-disabled:hover,
.console-action-disabled:focus,
.console-action-disabled:hover:focus {
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-disabled;
    text-style: none;
    outline: none;
}

#console-stop-generation.console-stop-active {
    border: none;
    background: $ds-status-warning 20%;
    color: $ds-text-primary;
    text-style: bold;
}

#console-save-chatbook.console-save-chatbook-ready {
    color: $ds-text-primary;
}

.console-control-label,
.console-staged-context-row,
.console-staged-context-summary,
.console-staged-context-recovery {
    width: auto;
    min-width: 0;
    height: auto;
}

.console-compact-model-bar {
    width: auto;
    min-width: 0;
}

#library-mode-bar {
    height: $ds-library-mode-bar-height;
    min-height: $ds-library-mode-bar-height;
    padding: 0 1;
    margin: 0;
    overflow: hidden;
}

#library-mode-label {
    width: $ds-library-mode-label-width;
    min-width: $ds-library-mode-label-width;
    height: $ds-library-mode-bar-height;
    min-height: $ds-library-mode-bar-height;
}

#notes-status-row {
    width: 1fr;
    min-width: 0;
    height: $ds-destination-compact-strip-height;
    min-height: $ds-destination-compact-strip-height;
    text-align: right;
    color: $ds-text-muted;
}

Button.library-mode-chip,
Button.notes-mode-chip {
    width: auto;
    min-width: 0;
    height: $ds-library-mode-chip-height;
    min-height: $ds-library-mode-chip-height;
    padding: 0 1;
    border: none;
}

.library-mode-chip:focus,
.notes-mode-chip:focus {
    outline: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

#library-contract-grid,
#artifacts-workbench,
#personas-workbench,
#watchlists-workbench,
#schedules-workbench,
#workflows-workbench,
#mcp-workbench,
#acp-workbench,
#skills-workbench,
#settings-workbench {
    height: 1fr;
    min-height: 20;
    padding: 1;
    margin: 0;
    overflow: hidden;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#personas-workbench {
    padding: 1;
    border: solid #6f6f6f;
}

/* Notes mode regions hold framed panes (Console rail framing), so the
   regions themselves stay chrome-free like Console's main area. */
#notes-mode-region-notes,
#notes-mode-region-sync,
#notes-mode-region-templates {
    height: 1fr;
    min-height: 20;
    padding: 0;
    margin: 0;
    overflow: hidden;
    border: none;
    background: transparent;
}

#artifacts-list-pane,
#artifacts-detail-pane,
#artifacts-inspector-pane,
#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#mcp-server-tree-pane,
#mcp-detail-pane,
#mcp-readiness-pane,
#acp-list-pane,
#acp-detail-pane {
    margin: 0 1 0 0;
}

#artifacts-inspector-pane,
#personas-inspector-pane,
#watchlists-inspector-pane,
#schedules-inspector-pane,
#workflows-inspector-pane,
#mcp-readiness-pane,
#acp-inspector-pane {
    margin: 0;
}

#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#acp-list-pane,
#acp-detail-pane,
#acp-inspector-pane {
    height: 100%;
    min-height: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#personas-list-pane {
    width: 2fr;
    min-width: 26;
    border: solid #6f6f6f;
    padding: 1;
}

#personas-detail-pane {
    width: 4fr;
    min-width: 42;
    border: solid #6f6f6f;
    padding: 1;
}

#personas-inspector-pane {
    width: 2fr;
    min-width: 30;
    border: solid #6f6f6f;
    padding: 1;
}

#schedules-list-pane,
#workflows-list-pane,
#acp-list-pane {
    width: 2fr;
    min-width: 30;
    border: solid #6f6f6f;
    padding: 1;
}

#schedules-detail-pane,
#workflows-detail-pane,
#acp-detail-pane {
    width: 4fr;
    min-width: 52;
    border: solid #6f6f6f;
    padding: 1;
}

#schedules-inspector-pane,
#workflows-inspector-pane,
#acp-inspector-pane {
    width: 2fr;
    min-width: 34;
    border: solid #6f6f6f;
    padding: 1;
}

#personas-selected-target-card,
#personas-readiness-card {
    width: 100%;
    height: auto;
    margin: 1 0;
    padding: 1;
    border: solid #6f6f6f;
    background: $ds-surface-raised;
}

#personas-selected-target-title,
#personas-readiness-title {
    text-style: bold;
}

.acp-selected-session-row {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.acp-inspector-group-title {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

#personas-list-detail-divider,
#personas-detail-inspector-divider,
#watchlists-list-detail-divider,
#watchlists-detail-inspector-divider,
#schedules-list-detail-divider,
#schedules-detail-inspector-divider,
#workflows-list-detail-divider,
#workflows-detail-inspector-divider,
#acp-list-detail-divider,
#acp-detail-inspector-divider {
    background: $ds-grid-line;
}

#personas-list-detail-divider,
#personas-detail-inspector-divider {
    background: #7a7a7a;
}

.artifacts-column-title,
.personas-column-title,
.watchlists-column-title,
.schedules-column-title,
.workflows-column-title,
.acp-column-title,
.skills-column-title,
.ccp-column-title,
.settings-column-title {
    width: 100%;
    height: 1;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-active-section {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button {
    width: 100%;
    height: 1;
    min-height: 1;
    max-height: 1;
    margin: 0;
    padding: 0 1;
    content-align: left middle;
    text-align: left;
    background: $ds-surface-panel;
}

Button.settings-category-button.settings-active-section {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button:focus {
    outline: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

Button.settings-category-button.settings-active-section:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button.settings-active-section:hover,
Button.settings-category-button.settings-active-section:hover:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button.settings-primary-search-match {
    color: $ds-text-primary;
    text-style: bold;
}

Button.settings-category-button.settings-secondary-search-match {
    color: $ds-text-muted;
}

#settings-category-search {
    width: 100%;
    height: 3;
    min-height: 3;
    max-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

#settings-category-search:focus {
    border: solid $ds-action-focus;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
    outline: none;
}

#settings-category-search.settings-category-search-active {
    border: solid $ds-action-focus;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.settings-category-search-help {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

.settings-category-search-status {
    width: 100%;
    min-height: 2;
    padding: 0 1;
    margin: 0 0 1 0;
    color: $ds-text-primary;
    background: $ds-surface-panel;
}

.settings-search-empty {
    width: 100%;
    min-height: 3;
    padding: 1;
    margin: 1 0 0 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-muted;
}

#settings-shell Button:focus,
#settings-shell Button:hover:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold underline;
    outline: none;
}

.settings-category-group-title {
    width: 100%;
    height: 1;
    min-height: 1;
    padding: 0 1;
    margin: 1 0 0 0;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-state-banner {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-detail-row {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.settings-input-row {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
}

.settings-select-row {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
}

.settings-input-label {
    width: 12;
    min-width: 12;
    height: 1;
    min-height: 1;
    padding: 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-select-row .settings-input-label {
    height: 3;
    min-height: 3;
    content-align: left middle;
}

.settings-compact-input {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.settings-compact-input:focus {
    border: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold underline;
    outline: none;
}

.settings-compact-input.settings-invalid-input,
.settings-compact-select.settings-invalid-input {
    background: $ds-status-error 18%;
    color: $ds-text-primary;
    text-style: bold;
    outline: none;
}

.settings-compact-input.settings-invalid-input:focus,
.settings-compact-select.settings-invalid-input:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-opacity: 1;
    text-style: bold;
    outline: none;
}

.settings-compact-select {
    width: 1fr;
    height: 3;
    min-height: 3;
    margin: 0;
    padding: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.settings-compact-select > SelectCurrent {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
    content-align: left middle;
}

.settings-compact-select:focus {
    border: solid $ds-action-focus;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
    outline: none;
}

.settings-compact-select:focus > SelectCurrent {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-compact-select > SelectOverlay {
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    min-width: 30;
}

.settings-compact-select > SelectOverlay Option {
    padding: 0 2;
    min-height: 3;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.settings-compact-select > SelectOverlay Option:hover {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

.settings-compact-select > SelectOverlay Option.-selected {
    padding: 0 2;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.settings-provider-manual-hidden {
    display: none;
}

.settings-status-row {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-inspector;
    color: $ds-text-muted;
}

.settings-storage-check-result {
    min-height: 7;
}

.settings-category-status-hidden {
    display: none;
}

.settings-dirty-category {
    color: $ds-status-unsaved;
    text-style: bold;
}

.settings-focus-card {
    width: 100%;
    min-height: 10;
    padding: 1;
    margin: 0 0 1 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#settings-advanced-config-card {
    height: 1fr;
    min-height: 0;
}

.settings-secondary-card {
    width: 100%;
    height: auto;
    min-height: 6;
    padding: 1;
    margin: 0 0 1 0;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#settings-console-behavior-card {
    min-height: 12;
}

.settings-action-row {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 1 0;
}

.settings-action-row Button {
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
}

.settings-action-row Button:focus,
#settings-impact-pane Button:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold underline;
    outline: none;
}

.settings-sync-safety-row {
    width: 100%;
    padding: 0 1;
    background: $ds-surface-raised;
}

.settings-advanced-safety-status {
    background: $ds-status-unsaved 10%;
    color: $ds-status-unsaved;
    text-style: bold;
}

#settings-advanced-config-editor {
    height: 1fr;
    min-height: 10;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#library-source-browser {
    width: $ds-library-source-browser-width;
    min-width: $ds-library-source-browser-width;
    max-width: $ds-library-source-browser-width;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    overflow-y: auto;
}

/* Notes form controls mirror the Console settings control language exactly:
   quiet tall-bordered inputs, single-row flattened selects, accent focus. */
#notes-shell Input {
    height: 3;
    min-height: 3;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#notes-shell Input:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#notes-shell Input > .input--cursor {
    background: $ds-input-focus-accent;
    color: $ds-surface-panel;
}

#notes-shell Select {
    height: 1;
    min-height: 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#notes-shell Select > SelectCurrent {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    content-align: left middle;
}

#notes-shell Select > SelectCurrent Static#label {
    width: 1fr;
    height: 1;
    background: transparent;
    color: $ds-text-primary;
}

#notes-shell Select > SelectCurrent .arrow {
    background: transparent;
    color: $ds-text-muted;
}

#notes-shell Select:focus {
    border: none;
    border-bottom: none;
    outline: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

#notes-shell TextArea {
    border: tall $ds-surface-panel;
    background: $ds-surface-panel;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#notes-shell TextArea:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
}

/* The keywords editor reads as a form control, not an editor surface. */
#notes-shell TextArea.notes-keywords-textarea {
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
}


#notes-shell ListView {
    border: none;
    background: $ds-surface-panel;
    padding: 0;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

Button.notes-delete-action {
    color: $ds-status-error;
}

/* Docked Notes action bar mirrors the Console composer chrome. */
#notes-action-bar {
    height: 3;
    min-height: 3;
    max-height: 3;
    padding: 0 1;
    margin: 0;
    border: round #6f7782;
    background: $ds-surface-panel;
    align: left middle;
}

.notes-action-bar-group {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    align: left middle;
}

.notes-action-bar-spacer {
    width: 1fr;
    min-width: 0;
    height: 1;
}

.notes-action-bar-group Button {
    height: 1;
    min-height: 1;
    margin-left: 1;
}

/* Sync mode: framed setup form + Console-transcript-style activity log. */
#notes-sync-pane {
    height: 1fr;
    min-height: 0;
    padding: 0;
    border: none;
    background: transparent;
}

#notes-sync-setup {
    width: 44;
    min-width: 30;
    height: 100%;
    padding: 0 1;
    margin: 0 1 0 0;
    border: solid #6f7782;
    background: $ds-surface-panel;
}

#notes-sync-activity {
    width: 1fr;
    min-width: 0;
    height: 100%;
    padding: 0 1;
    border: solid #6f7782;
    background: $ds-surface-panel;
}

.notes-sync-field-label {
    height: 1;
    min-height: 1;
    margin-top: 1;
    color: $ds-text-muted;
    text-style: bold;
}

.notes-sync-auto-label {
    width: auto;
    height: 1;
    min-height: 1;
    color: $ds-text-muted;
    text-style: bold;
}

#notes-sync-activity-log {
    height: 1fr;
    min-height: 0;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

.notes-sync-activity-line {
    height: auto;
    min-height: 1;
    color: $ds-text-muted;
}

.notes-sync-activity-line.activity-success {
    color: $ds-status-ready;
}

.notes-sync-activity-line.activity-error {
    color: $ds-status-error;
}

/* Templates mode: framed list beside a framed full-height preview. */
#notes-templates-pane {
    height: 1fr;
    min-height: 0;
    padding: 0;
    border: none;
    background: transparent;
}

#notes-templates-list-pane {
    width: 36;
    min-width: 24;
    height: 100%;
    padding: 0 1;
    margin: 0 1 0 0;
    border: solid #6f7782;
    background: $ds-surface-panel;
}

#notes-template-preview-pane {
    width: 1fr;
    min-width: 0;
    height: 100%;
    padding: 0 1;
    border: solid #6f7782;
    background: $ds-surface-panel;
}

#notes-template-preview-scroll {
    height: 1fr;
    min-height: 0;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

/* Navigator scope lists stay dense and top-aligned like Console rails. */
#notes-navigator-pane ListView {
    height: auto;
    min-height: 1;
    max-height: 10;
}

/* Sort row: the global `Select { width: 100%; }` rule would otherwise
   inflate the select and push the order toggle out of the row. */
#notes-sort-row {
    height: 1;
    min-height: 1;
    margin-bottom: 1;
    align: left middle;
}

#notes-sort-row > Static {
    width: 6;
    min-width: 6;
    color: $ds-text-muted;
}

#notes-sort-row Select {
    width: 1fr;
    min-width: 0;
    margin: 0;
}

#notes-sort-row Button {
    margin-left: 1;
}


#library-source-inspector {
    width: 2fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    overflow-y: auto;
}

/* Console's rendered frame color (#6f7782) — see chat_screen.CONSOLE_FRAME_COLOR. */
#notes-navigator-pane,
#notes-inspector-pane {
    width: 2fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid #6f7782;
    background: $ds-surface-panel;
    overflow-y: auto;
}

#notes-navigator-pane,
#notes-inspector-pane {
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#library-source-detail {
    width: 5fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    overflow-y: auto;
}

#notes-editor-pane {
    width: 5fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid #6f7782;
    background: $ds-surface-panel;
    overflow-y: auto;
}

#notes-editor-pane {
    overflow-y: hidden;
}

.ds-shortcut-bar {
    dock: bottom;
    height: 1;
    padding: 0 1;
    background: $ds-surface-inspector;
    color: $ds-text-muted;
}

.density-compact .ds-panel,
.density-compact .ds-inspector,
.density-compact .ds-approval-card,
.density-compact .ds-recovery-callout {
    padding: 0 1;
    margin: 0 0 1 0;
}

.density-compact .ds-destination-header {
    min-height: 2;
    padding: 0 1;
}

.density-comfortable .ds-panel,
.density-comfortable .ds-inspector,
.density-comfortable .ds-approval-card,
.density-comfortable .ds-recovery-callout {
    padding: 1 2;
    margin: 1 1;
}

.density-comfortable .ds-destination-header {
    min-height: 4;
    padding: 1 2;
}

.is-active {
    border: round $ds-action-focus;
    text-style: bold;
}

.library-mode-chip.is-active,
.notes-mode-chip.is-active {
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.library-mode-chip.is-active:focus,
.notes-mode-chip.is-active:focus {
    outline: none;
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.library-source-action {
    width: $ds-library-source-action-width;
    min-width: $ds-library-source-action-min-width;
    height: $ds-library-source-action-height;
    min-height: $ds-library-source-action-height;
    margin: 0 0 1 0;
}

.library-source-action-spacer {
    height: 1;
    min-height: 1;
}

.library-source-action:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

.library-rag-region {
    width: 100%;
    min-width: 0;
    margin: 0 0 1 0;
}

#library-rag-query-controls {
    height: 7;
    min-height: 7;
}

#library-rag-query-controls.has-recovery {
    height: 10;
    min-height: 10;
}

#library-rag-source-scope {
    height: 2;
    min-height: 2;
}

#library-rag-source-scope.has-recovery {
    height: 12;
    min-height: 12;
}

#library-rag-query-row {
    width: 100%;
    height: 3;
    min-height: 3;
}

#library-rag-results {
    height: 1fr;
    min-height: 8;
}

#library-rag-query-input {
    width: 1fr;
    min-width: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-raised;
}

#library-rag-query-input:focus {
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
}

#library-rag-scope-summary {
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-rag-run-query {
    width: 18;
    min-width: 16;
    margin: 0 0 0 1;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

#library-rag-run-query:disabled {
    background: $ds-surface-raised;
    color: $ds-text-disabled;
    text-style: none;
}

.library-rag-result-row {
    padding: 0 1;
    margin: 1 0 0 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

.library-rag-result-row.is-selected {
    border: heavy $ds-focus-accent;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
}

.library-rag-result-badges {
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: bold;
}

.library-rag-recovery-action {
    width: 28;
    min-width: 18;
    background: $ds-status-warning 30%;
    color: $ds-text-primary;
    text-style: bold;
}

.library-rag-console-action {
    width: 18;
    min-width: 16;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

.library-rag-center-console-action {
    width: 24;
    min-width: 18;
    margin: 1 0 0 0;
}

.library-rag-console-action:disabled {
    background: $ds-surface-raised;
    color: $ds-text-disabled;
    text-style: none;
}

.is-disabled {
    opacity: 0.55;
}

.is-blocked {
    border: round $ds-status-error;
    background: $ds-status-error 10%;
}

.is-running {
    border: round $ds-status-running;
}

.is-paused {
    border: round $ds-status-paused;
}

.is-unsaved {
    border: round $ds-status-unsaved;
}

.is-stale {
    color: $ds-text-muted;
}

.is-conflict {
    border: thick $ds-status-error;
}

.needs-approval {
    border: thick $ds-status-approval-required;
    background: $ds-status-approval-required 12%;
}

.source-local {
    border: round $ds-authority-local;
}

.source-server {
    border: round $ds-authority-server;
}

.source-workspace {
    border: round $ds-authority-workspace;
}

.source-remote-only {
    border: round $ds-authority-remote-only;
}

.source-dry-run {
    border: dashed $ds-grid-line;
    color: $ds-text-muted;
}
