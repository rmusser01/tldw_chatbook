/* ========================================
 * COMPONENTS: Agentic Terminal Design System
 * ========================================
 * Shared shell primitives for Home, Console, destination wrappers, status,
 * recovery, source authority, approvals, events, forms, toolbars, and shortcuts.
 *
 * Semantic token contract:
 * ds-surface-panel, ds-text-primary, ds-action-focus,
 * ds-status-ready, ds-status-running, ds-status-warning, ds-status-error,
 * ds-status-paused, ds-status-blocked, ds-status-approval-required,
 * ds-authority-local, ds-authority-server, ds-authority-workspace,
 * ds-source-role-context, ds-source-role-evidence,
 * ds-source-role-editable-target, ds-source-role-output-seed.
 *
 * Required readable status labels:
 * Ready, Running, Paused, Blocked, Unavailable, Approval required, Unsaved, Recovered.
 * ======================================== */

.ds-destination-header {
    height: auto;
    min-height: 3;
    padding: 1 2;
    margin: 0 0 1 0;
    border: tall $ds-action-focus;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.ds-panel {
    height: auto;
    min-height: 3;
    padding: 1 2;
    margin: 0 0 1 0;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.ds-inspector {
    height: auto;
    min-width: 24;
    padding: 1;
    border: round $ds-grid-line;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.ds-status-badge {
    width: auto;
    height: 1;
    padding: 0 1;
    text-style: bold;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.ds-recovery-callout {
    height: auto;
    padding: 1 2;
    border: round $ds-status-warning;
    background: $ds-status-warning 10%;
    color: $ds-text-primary;
}

.ds-source-role {
    width: auto;
    height: 1;
    padding: 0 1;
    border: round $ds-source-role-context;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.ds-approval-card {
    height: auto;
    padding: 1 2;
    border: thick $ds-status-approval-required;
    background: $ds-status-approval-required 12%;
    color: $ds-text-primary;
}

.ds-event-row {
    height: auto;
    min-height: 1;
    padding: 0 1;
    border-bottom: solid $ds-grid-line;
    color: $ds-text-primary;
}

/* Field rows are label-above-value: every current user (Personas card and
   editors) composes them as Vertical containers, so the row must not force a
   horizontal layout (it jammed "Name"+value side by side and squeezed Inputs
   into the leftover width). */
.ds-field-row {
    height: auto;
    min-height: 2;
    padding: 0 1;
}

.ds-toolbar {
    height: auto;
    min-height: 1;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

ConsoleSettingsModal {
    align: center middle;
}

#console-settings-modal {
    width: 92;
    max-width: 95%;
    height: 90%;
    max-height: 95%;
    overflow: hidden;
    scrollbar-size: 1 1;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
    padding: 1 2;
}

#console-settings-body {
    height: 1fr;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

.console-settings-modal-section {
    height: auto;
    margin: 1 0 0 0;
}

.console-settings-primary-section {
    padding: 0 1;
    border: round $ds-action-focus;
    background: $ds-surface-raised;
}

.console-settings-modal-row {
    height: auto;
    min-height: 1;
}

.console-settings-modal-label {
    width: 16;
    min-width: 16;
    max-width: 16;
    height: 1;
    min-height: 1;
    content-align: left middle;
}

.console-settings-control {
    width: 1fr;
    min-width: 0;
}

ConsoleSettingsModal Input {
    width: 1fr;
    min-width: 0;
    height: 3;
    min-height: 3;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

ConsoleSettingsModal Checkbox {
    height: 1;
    min-height: 1;
}

ConsoleSettingsModal Select > SelectCurrent {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    content-align: left middle;
}

ConsoleSettingsModal Select > SelectCurrent Static#label {
    width: 1fr;
    height: 1;
    background: transparent;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select > SelectCurrent .arrow {
    background: transparent;
    color: $ds-text-muted;
}

ConsoleSettingsModal Input:focus {
    height: 3;
    min-height: 3;
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

ConsoleSettingsModal Input > .input--cursor {
    background: $ds-input-focus-accent;
    color: $ds-surface-panel;
}

ConsoleSettingsModal Input > .input--selection {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
}

ConsoleSettingsModal Select:focus {
    border: none;
    border-bottom: none;
    outline: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select:focus > SelectCurrent {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

ConsoleSettingsModal Select > SelectOverlay {
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    min-width: 30;
}

ConsoleSettingsModal Select > SelectOverlay Option {
    padding: 0 2;
    min-height: 3;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select > SelectOverlay Option:hover {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select > SelectOverlay Option.-selected {
    padding: 0 2;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-settings-modal-actions {
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    align-horizontal: right;
}

#console-settings-cancel,
#console-settings-save {
    width: 12;
    min-width: 12;
    height: 1;
    min-height: 1;
}

.console-settings-error {
    height: auto;
    min-height: 1;
    max-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-status-error 10%;
    color: $ds-text-primary;
}

ConsolePromptPickerModal {
    align: center middle;
}

#console-prompt-picker-modal {
    width: 76;
    max-width: 95%;
    height: auto;
    max-height: 85%;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
    padding: 1 2;
}

#console-prompt-picker-filter {
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-prompt-picker-filter:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

#console-prompt-picker-results {
    height: auto;
    max-height: 20;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
}

.console-prompt-picker-row {
    width: 100%;
    height: auto;
    min-height: 3;
    margin: 0 0 1 0;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.console-prompt-picker-row-highlighted {
    border: tall $ds-action-focus;
    background: $ds-input-focus-bg;
    text-style: bold;
}

.console-prompt-picker-row-blocked {
    color: $ds-text-muted;
}

#console-prompt-picker-reason {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-status-error 10%;
    color: $ds-text-primary;
}

#console-prompt-picker-empty {
    height: auto;
    margin: 1 0;
    color: $ds-text-muted;
}

ConsoleSkillPickerModal {
    align: center middle;
}

#console-skill-picker-modal {
    width: 76;
    max-width: 95%;
    height: auto;
    max-height: 85%;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
    padding: 1 2;
}

#console-skill-picker-filter {
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-skill-picker-filter:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

#console-skill-picker-results {
    height: auto;
    max-height: 20;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
}

.console-skill-picker-row {
    width: 100%;
    height: auto;
    min-height: 3;
    margin: 0 0 1 0;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.console-skill-picker-row-highlighted {
    border: tall $ds-action-focus;
    background: $ds-input-focus-bg;
    text-style: bold;
}

#console-skill-picker-empty {
    height: auto;
    margin: 1 0;
    color: $ds-text-muted;
}

ConsoleSystemPromptModal {
    align: center middle;
}

#console-system-prompt-modal {
    width: 84;
    max-width: 95%;
    height: 32;
    max-height: 90%;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
    padding: 1 2;
}

.console-system-prompt-row {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
}

.console-system-prompt-label {
    width: 8;
    min-width: 8;
    max-width: 8;
    height: 1;
    min-height: 1;
    content-align: left middle;
}

#console-system-prompt-scope {
    color: $ds-text-muted;
}

#console-system-prompt-text {
    width: 100%;
    height: 1fr;
    min-height: 10;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-system-prompt-text:focus {
    border: tall $ds-input-focus-accent;
    background: $ds-input-focus-bg;
}

#console-system-prompt-name {
    width: 1fr;
    min-width: 0;
    height: 3;
    min-height: 3;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-system-prompt-save-status {
    color: $ds-text-muted;
}

.console-system-prompt-actions {
    height: 3;
    min-height: 3;
    align-horizontal: right;
}

#console-system-prompt-clear,
#console-system-prompt-cancel,
#console-system-prompt-apply {
    width: 12;
    min-width: 12;
    height: 3;
    min-height: 3;
}

#home-dashboard,
#console-shell,
#library-shell,
#artifacts-shell,
#personas-shell,
#watchlists-collections-shell,
#schedules-shell,
#mcp-shell,
#acp-shell,
#skills-shell,
#settings-shell {
    height: 100%;
    min-height: 0;
}

#home-title,
#console-title,
#library-title,
#artifacts-title,
#personas-title,
#watchlists-collections-title,
#schedules-title,
#workflows-title,
#mcp-title,
#acp-title,
#skills-title,
#settings-title {
    height: $ds-destination-header-height;
    min-height: $ds-destination-header-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#home-purpose,
#console-purpose,
#library-purpose,
#artifacts-purpose,
#mcp-purpose,
#console-status-row,
#library-status-row,
#console-mode-bar,
#artifacts-mode-strip,
#personas-mode-strip,
#watchlists-filter-strip,
#schedules-filter-strip,
#workflows-mode-strip,
#mcp-mode-strip,
#acp-purpose,
#acp-mode-strip,
#skills-mode-strip,
#settings-category-strip {
    height: $ds-destination-compact-strip-height;
    min-height: $ds-destination-compact-strip-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

.destination-action-button {
    height: 1;
    min-height: 1;
    padding: 0 1;
}

.home-dashboard-region,
.library-region,
#artifacts-list-pane,
#artifacts-detail-pane,
#artifacts-inspector-pane,
#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#mcp-server-tree-pane,
#mcp-detail-pane,
#mcp-readiness-pane,
#acp-list-pane,
#acp-detail-pane,
#acp-inspector-pane,
#skills-list-pane,
#skills-detail-pane,
#skills-inspector-pane,
#settings-category-pane,
#settings-detail-pane,
#settings-impact-pane,
#ccp-character-library-pane,
#ccp-behavior-detail-pane,
#ccp-attachment-inspector-pane {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

/* Console's runtime frame (_frame_console_region) is the single border
   source for .console-region; no CSS border here to avoid a doubled frame. */
.console-region {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
    padding: 1;
    background: $ds-surface-panel;
}

#settings-category-pane {
    width: 3fr;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#settings-detail-pane {
    width: 6fr;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#settings-impact-pane {
    width: 2fr;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#home-triage-grid {
    padding: 0 1;
    margin: 0;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#home-header-line {
    height: $ds-home-compact-row-height;
    min-height: $ds-home-compact-row-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#home-rail,
#home-canvas {
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

.home-rail-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.home-rail-row-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.home-rail-section-body {
    height: auto;
    min-height: 0;
}

.home-rail-empty-copy {
    color: $ds-text-muted;
    padding: 0 1;
}

#home-next-action-callout {
    color: $ds-text-muted;
    padding: 0 1;
}

.destination-pane-divider {
    width: 1;
    min-width: 1;
    height: 100%;
    min-height: 0;
    background: $ds-grid-line;
}

#home-canvas-actions .ds-toolbar {
    height: auto;
    min-height: $ds-home-control-button-height;
    padding: 0 1;
    margin: 0;
    border: none;
    background: $ds-surface-panel;
}

.home-canvas-action {
    height: $ds-home-control-button-height;
    min-height: $ds-home-control-button-height;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    border: none;
}

/* Canvas actions gain .console-action-primary (mirrors the project's live
   "primary action button" convention) when they are the primary control
   for the currently selected row -- see HomeScreen._home_action_button /
   HomeCanvasState.primary_control_id. No id-scoped rule here anymore: the
   primary control follows selection (Retry when failed, Approve when
   approval-pending, Review flashcards when the due-flashcards row is
   selected, Open details otherwise), not one permanently-accented button. */

#library-shell-grid {
    padding: 0 1;
    margin: 0;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#library-header-line {
    height: $ds-home-compact-row-height;
    min-height: $ds-home-compact-row-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#library-rail {
    border: solid $ds-column-line;
    background: $ds-surface-panel;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#library-canvas {
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

.library-rail-empty-copy {
    color: $ds-text-muted;
    padding: 0 1;
}

.library-details-group {
    text-style: bold;
    color: $ds-text-primary;
    margin: 1 0 0 0;
    padding: 0 1;
}

.library-details-group-first {
    margin: 0;
}

.library-details-row {
    padding: 0 1;
}

.library-rail-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.library-rail-row-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Flashcards-due emphasis on the create-flashcards rail row. Bright uses an
   accent text color (not a background fill) so the row stands out without
   reading as selected -- real selection is `.library-rail-row-selected`'s
   background treatment below, and this row must stay visually distinct from
   that state. Dim uses the muted text color already used for rail hints
   elsewhere in this file (e.g. #library-notes-sync-status) so a zero-due
   state reads as quiet. */
.library-rail-row-due-bright {
    color: $ds-action-focus;
    text-style: bold;
}

.library-rail-row-due-dim {
    color: $ds-text-muted;
    text-style: none;
}

.library-conversation-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.library-conversation-row-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.library-media-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.library-media-row-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.library-notes-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

/* Same look as .library-notes-row, on a separate class: the notes Create
   view's Blank note / template rows must not also match the list view's
   ".library-notes-row" press handler (opening the editor for the pressed
   row's note_id), which would double-dispatch alongside the Create view's
   own handlers on every press. */
.library-notes-create-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

/* Same look as .library-notes-row: prompts list rows (library_prompts_canvas.py). */
.library-prompt-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

/* "From a template" group label: separates the primary Blank note action
   from the template rows (same top-rule section grammar as the media
   viewer's Content/Analysis/Highlights headers). */
#library-notes-template-section {
    width: 100%;
    text-style: bold;
    color: $ds-text-primary;
    border-top: solid $ds-grid-line;
    padding: 1 0 0 0;
    margin: 1 0 1 0;
}

.library-canvas-action {
    height: $ds-home-control-button-height;
    min-height: $ds-home-control-button-height;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    border: none;
}

#library-search-input {
    margin: 0 0 1 0;
}

#library-conversations-filter {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-notes-header {
    width: 100%;
    min-width: 0;
    height: auto;
    content-align: left middle;
}

#library-notes-filter {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-notes-filter:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-notes-status {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

#library-notes-empty {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

/* Prompts list canvas (library_prompts_canvas.py): same look as the notes
   list's header/filter/empty siblings above -- visual parity, not a
   separate design. */
#library-prompts-header {
    width: 100%;
    min-width: 0;
    height: auto;
    content-align: left middle;
}

#library-prompts-filter {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-prompts-filter:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-prompts-empty {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

/* Toolbar Import… row (library_prompts_canvas.py, Task 5): the path Input
   matches the filter box's field look; the outcome line is muted like the
   editor's save-status Static. */
#library-prompts-import-path {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-prompts-import-path:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-prompts-import-status {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

/* Toolbar Import… row (library_skills_canvas.py, Task 5): the path Input
   matches the filter box's field look; the outcome line is muted like the
   editor's save-status Static. */
#library-skills-import-path {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-skills-import-path:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-skills-import-status {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

/* Skills list canvas (library_skills_canvas.py, Task 3): same look as the
   prompts list's header/filter/empty/row siblings above -- visual parity,
   not a separate design. */
.library-skill-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

/* Needs-review (trust-blocked) skills stay selectable -- the trust panel
   needs them visible -- but render dim, same modifier-class pattern as
   ``.console-prompt-picker-row-blocked``. */
.library-skill-row-blocked {
    color: $ds-text-muted;
}

/* Row secondary line: the flags/description Static rendered right below
   each skill row's Button. Same muted tier as every other secondary/empty
   line in this canvas family. */
.library-skill-row-secondary {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

#library-skills-header {
    width: 100%;
    min-width: 0;
    height: auto;
    content-align: left middle;
}

#library-skills-filter {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-skills-filter:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-skills-empty {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

/* Skill detail/trust editor (library_skills_canvas.py, Task 4): Name/
   Description/Argument hint/Allowed tools/Model share the SAME field look
   as the prompt editor's own Inputs (visual parity, not a separate
   design) -- dual-pinned against #library-prompt-name in
   test_library_skills_canvas.py. */
#library-skill-name,
#library-skill-description,
#library-skill-argument-hint,
#library-skill-allowed-tools,
#library-skill-model {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-skill-name:focus,
#library-skill-description:focus,
#library-skill-argument-hint:focus,
#library-skill-allowed-tools:focus,
#library-skill-model:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

/* Bounded editor: same floor/ceiling as #library-prompt-system/-user so the
   Body TextArea stays compact instead of ballooning to fill the canvas. */
#library-skill-body {
    height: auto;
    min-height: 6;
    max-height: 14;
    margin: 0 0 1 0;
}

#library-skill-supporting,
#library-skill-save-status,
#library-skill-conflict-copy {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

/* Warnings line (shadow-name / save-marks-needs-review): a warning tier
   color, not muted -- unlike the read-only supporting-files/status lines
   above, these are actionable, attention-worthy copy. */
#library-skill-warnings {
    width: 100%;
    height: auto;
    color: $ds-status-warning;
    margin: 0 0 1 0;
}

/* Trust panel: state line dims while blocked/needs-review, same modifier-
   class pattern as .library-skill-row-blocked above. The changed-files
   line under it is muted like every other secondary line in this canvas
   family. */
#library-skill-trust-state {
    width: 100%;
    height: auto;
    margin: 0 0 1 0;
}

#library-skill-trust-state.library-skill-trust-state-blocked {
    color: $ds-text-muted;
}

#library-skill-trust-review-files {
    width: 100%;
    height: auto;
    min-height: 1;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

/* First-run trust setup state (Fix wave, Skills Phase-1 gate FIX 2): the
   explanation line replacing the normal changed-files line while
   ``trust_status == "trust_uninitialized"``. Same muted secondary-line
   look as #library-skill-trust-review-files above -- informational, not a
   warning tier (unlike #library-skill-warnings). */
#library-skill-trust-setup-explanation {
    width: 100%;
    height: auto;
    min-height: 1;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

#library-notes-create-header {
    width: 100%;
    min-width: 0;
    height: auto;
    content-align: left middle;
}

/* Note editor: title/keywords Inputs match the filter box's field look
   (tall border, focus accent) rather than defaulting to Textual's bare
   Input styling. */
#library-note-title,
#library-note-keywords {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-note-title:focus,
#library-note-keywords:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

/* Bounded editor: a bare TextArea in this scrolling canvas defaults to
   height:1fr, which would balloon to fill available space and crowd out
   the keywords/meta/action row beneath it. height:auto with a floor and a
   generous ceiling keeps short notes compact while long notes scroll
   inside the field itself instead of pushing the rest of the editor off
   screen. */
#library-note-body {
    height: auto;
    min-height: 12;
    max-height: 20;
    margin: 0 0 1 0;
}

/* The read-only Markdown preview takes the TextArea's place one-for-one
   when Preview is toggled on, so it gets the same bounded footprint (plus
   its own scroll region, since Markdown has no implicit one here). */
#library-note-preview-body {
    height: auto;
    min-height: 12;
    max-height: 20;
    margin: 0 0 1 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    overflow-y: auto;
}

/* Muted meta line: same tier as the media viewer's metadata block
   (#library-media-viewer-meta) so both editors read consistently. */
#library-note-meta {
    width: 100%;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

#library-note-conflict-copy,
#library-note-delete-confirm-copy {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

/* Prompt editor (library_prompts_canvas.py): same field/meta/conflict look
   as the note editor's siblings above -- visual parity, not a separate
   design. Name/Author/Details/Keywords are single-line Inputs; System
   prompt/User prompt are the bounded TextAreas below. */
#library-prompt-name,
#library-prompt-author,
#library-prompt-details,
#library-prompt-keywords {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-prompt-name:focus,
#library-prompt-author:focus,
#library-prompt-details:focus,
#library-prompt-keywords:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

/* Dim one-line field labels above each Input/TextArea -- the prompt editor
   has several ambiguous text fields (unlike the note editor's single body),
   so each needs its own caption; muted like the note editor's meta line. */
.library-prompt-field-label {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
}

/* One-line dim hint under the System prompt/User prompt labels (Task 8c
   U7): explains the two-part prompt model to a new user. Same muted tier
   as .library-prompt-field-label above; the trailing margin separates it
   from the TextArea beneath it. */
.library-prompt-field-hint {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

/* Bounded editors: same floor/ceiling as #library-note-body so System/User
   prompt stay compact instead of ballooning to fill the canvas. */
#library-prompt-system,
#library-prompt-user {
    height: auto;
    min-height: 6;
    max-height: 14;
    margin: 0 0 1 0;
}

#library-prompt-meta {
    width: 100%;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

#library-prompt-conflict-copy,
#library-prompt-save-status {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

/* Notes sync panel: section header matches the create view's group-label
   grammar; the folder Input matches the filter box's field look; status/
   activity are muted like the note editor's meta line. */
#library-notes-sync-header {
    width: 100%;
    text-style: bold;
    color: $ds-text-primary;
    margin: 0 0 1 0;
}

/* Purpose line: one-line explainer directly under the header, dim like the
   note editor's meta line. */
#library-notes-sync-purpose {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

/* Dim lowercase label above the folder Input, same muted tier as the
   activity log directly below it. */
#library-notes-sync-folder-label {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
}

#library-notes-sync-folder {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-notes-sync-folder:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

/* Starts the direction/conflict/auto-sync settings group right after
   Browse…, visually separating "where" (folder) from "how" (options). */
#library-notes-sync-direction {
    margin-top: 1;
}

/* Separates the primary action from the settings group above it. Accent
   treatment mirrors .console-action-primary (the project's live "primary
   action button" convention) so Sync now reads as the one button that
   matters on this panel. */
#library-notes-sync-run {
    margin-top: 1;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

#library-notes-sync-status {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 1 0 0 0;
    color: $ds-text-muted;
}

/* Failed status gets the standard $ds-status-error color -- status is the
   headline, so a failure must read as unambiguously bad. */
#library-notes-sync-status.library-notes-sync-status-failed {
    color: $ds-status-error;
}

/* Activity is the log, status is the headline -- one muted tier dimmer
   than #library-notes-sync-status so the hierarchy is visible even though
   both are "muted" text. */
#library-notes-sync-activity {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-disabled;
}

/* Ingest canvas: local-file ingest form + job queue. Mirrors the notes
   sync panel's render-safe stacked shape (VerticalScroll root -- L3a
   clipping lesson -- no Select, no Horizontal mixing 1fr + fixed-width
   children). */
#library-ingest-header {
    width: 100%;
    text-style: bold;
    color: $ds-text-primary;
    margin: 0 0 1 0;
}

.library-ingest-quiet-line {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

.library-ingest-field {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.library-ingest-field:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

/* Accent treatment mirrors #library-notes-sync-run / .console-action-primary
   (the project's live "primary action button" convention) so Start ingest
   reads as the one button that matters on this canvas. */
#library-ingest-start {
    margin-top: 1;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

#library-ingest-start:disabled {
    background: $ds-surface-raised;
    color: $ds-text-disabled;
    text-style: none;
}

#library-ingest-queue-heading {
    width: 100%;
    text-style: bold;
    color: $ds-text-primary;
    border-top: solid $ds-grid-line;
    padding: 1 0 0 0;
    margin: 1 0 1 0;
}

#library-ingest-queue-counts {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

#library-ingest-queue-empty {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
}

.library-ingest-row {
    width: 100%;
    height: auto;
    margin: 0 0 1 0;
    color: $ds-text-primary;
}

/* (L3b AB wave, A3) A row followed by action button(s) (Open in Library /
   Retry / Dismiss) trims its own bottom margin to 0 -- the actions
   wrapper's own `.library-ingest-row-actions` margin below supplies the
   spacing instead (tight gap above, blank line below), so the button(s)
   read as belonging to THIS row rather than the row underneath it. Plain
   rows (queued/running, or a defensively action-less done row) keep the
   base `.library-ingest-row` bottom margin for normal row-to-row
   spacing. */
.library-ingest-row-with-actions {
    margin: 0 0 0 0;
}

/* (L5, fix batch F1b) The wrapper around a row's action button(s) --
   Retry+Dismiss on a failed row, or Open in Library alone on a done row
   (the two never coexist on the same row). Carries the spacing the
   individual `.library-ingest-row-action` buttons used to carry alone
   (A3, above) now applied once to the whole group: indented 2 cells so it
   visually nests under its row, no gap above (tight to the row it
   belongs to, whose own margin is trimmed via
   `.library-ingest-row-with-actions` above), one blank line below before
   whatever comes next (another row, or "Clear finished"). `height: auto`
   keeps it from inheriting `Horizontal`'s `1fr` default, which would
   otherwise fight every other row for the VerticalScroll's height. */
.library-ingest-row-actions {
    height: auto;
    margin: 0 0 1 2;
}

/* Shared by every per-row action button (Open in Library / Retry /
   Dismiss) inside `.library-ingest-row-actions` above -- now just a small
   right gap between same-row siblings (Retry from Dismiss) so the pair
   reads as two distinct buttons rather than running together; the
   wrapper itself supplies the row's own indent/top/bottom spacing. */
.library-ingest-row-action {
    margin: 0 1 0 0;
}

/* (L3b AB wave, B2) "Clear finished" sits below every queue row -- a top
   margin separates it from the last row's own action button instead of
   reading as one more per-row action. */
#library-ingest-clear-finished {
    margin-top: 1;
}

/* Export canvas (F4 Task 2): in-canvas chatbook export form. Own classes
   rather than reusing `.library-ingest-*` -- the two canvases' CSS stays
   independently discoverable even though the rules mirror the ingest
   canvas's field/quiet-line styling exactly. */
.library-export-quiet-line {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

.library-export-field {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.library-export-field:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

/* Accent treatment mirrors #library-ingest-start / .console-action-primary
   (the project's live "primary action button" convention) so Export
   chatbook reads as the one button that matters on this canvas. */
#library-export-submit {
    margin-top: 1;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

#library-export-submit:disabled {
    background: $ds-surface-raised;
    color: $ds-text-disabled;
    text-style: none;
}

#library-media-title {
    width: 100%;
    min-width: 0;
    height: auto;
    content-align: left middle;
}

#library-media-type-filter {
    width: auto;
    min-width: 0;
    margin: 0 0 1 0;
}

/* Title: brightest + bold so it anchors the viewer; metadata recedes (muted)
   so the two read as distinct tiers instead of one wall of text. */
#library-media-viewer-title {
    width: 100%;
    text-style: bold;
    color: $ds-text-primary;
    margin: 0 0 1 0;
}

#library-media-viewer-meta {
    width: 100%;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

/* Section headers: bold + a thin top rule so Content / Analysis / Highlights
   read as real section boundaries the eye can find without reading. */
#library-media-viewer-content-title,
#library-media-viewer-analysis-title,
#library-media-viewer-highlights-title {
    width: 100%;
    text-style: bold;
    color: $ds-text-primary;
    border-top: solid $ds-grid-line;
    padding: 1 0 0 0;
    margin: 1 0 1 0;
}

#library-media-content-search {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-media-content-search:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-media-content-search-status {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

#library-media-viewer {
    height: 100%;
    overflow-y: auto;
    /* Never scroll horizontally: without this the vertical scroll container
       sizes its content to the widest child's natural width, so a long
       unbroken line (analysis summary, URL) sets a wide virtual width and
       width:100% children match it instead of wrapping. Constrain to the
       visible width so long lines wrap. */
    overflow-x: hidden;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

/* Text bodies default to width:auto (shrink-to-content); fill the width so
   long lines wrap within the (now horizontally-constrained) viewer. */
#library-media-viewer Static {
    width: 100%;
}

#library-media-viewer-content {
    /* Bounded so short content stays compact and long content scrolls inside
       this region; height:1fr here ballooned the pane and split the sections.
       max-height is generous so typical content shows in full (only long
       transcripts engage the inner scroll), reducing nested-scroll friction. */
    height: auto;
    max-height: 18;
    min-height: 3;
    margin: 0 0 1 0;
    border: solid $ds-grid-line;
    padding: 0 1;
}

#library-media-edit-form {
    height: auto;
    margin: 0 0 1 0;
}

/* Persistent per-field label: muted, bold, hugging its input above the row. */
.library-media-edit-label {
    width: 100%;
    height: 1;
    color: $ds-text-muted;
    text-style: bold;
    margin: 0;
}

/* Destructive Delete: pushed off the primary actions (a gap) and de-emphasized
   so it is neither adjacent to Edit nor visually competing with it. */
.library-media-action-danger {
    margin: 0 0 0 4;
    color: $ds-text-muted;
}

/* Each highlight is an indented card so its quote, meta, and delete read as
   one unit -- a per-row delete then clearly belongs to a single highlight. */
.library-media-highlight-row {
    width: 100%;
    height: auto;
    border-left: solid $ds-grid-line;
    padding: 0 0 0 1;
    margin: 0 0 1 0;
}

.library-media-highlight-meta {
    width: 100%;
    color: $ds-text-muted;
}

.library-media-highlight-delete {
    color: $ds-text-muted;
}

#library-media-edit-form Input {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-media-edit-form Input:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-media-highlight-add-collapsible {
    height: auto;
    margin: 0 0 1 0;
}

#library-media-highlight-add-collapsible Input {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-media-highlight-add-collapsible Input:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#console-workspace-grid {
    height: $ds-console-workspace-grid-height;
    min-height: 20;
    padding: 0 1;
    margin: 0;
    overflow: hidden;
    border-top: solid $ds-grid-line;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#console-workbench-header {
    display: none;
    height: 0;
    min-height: 0;
    max-height: 0;
    padding: 0;
    margin: 0;
    border: none;
}

#console-workbench-header #workbench-header-subtitle,
#console-workbench-header #workbench-header-status {
    display: none;
    height: 0;
    min-height: 0;
    max-height: 0;
}

#console-workbench-mode-strip,
#console-workbench-command-strip {
    display: none;
    height: 0;
    min-height: 0;
    max-height: 0;
    padding: 0;
    margin: 0;
    border: none;
}

#console-control-bar {
    height: $ds-console-control-bar-height;
    min-height: $ds-console-control-bar-height;
    max-height: $ds-console-control-bar-height;
    padding: 0 1;
    margin: 0;
    border: none;
    background: $ds-surface-panel;
    overflow: hidden;
}

.console-control-chip-row,
.console-control-action-row {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    max-height: 1;
    layout: horizontal;
    align: left middle;
}

.console-control-chip {
    width: auto;
    min-width: 7;
    max-width: 22;
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-overflow: ellipsis;
    text-wrap: nowrap;
}

.console-chip-dim {
    color: $ds-text-muted;
}

.console-chip-alert {
    color: $ds-text-primary;
    text-style: bold;
}

.console-control-action {
    width: auto;
    min-width: 7;
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
    padding: 0 1;
    border: none;
    background: transparent;
    color: $ds-text-primary;
    content-align: left middle;
}

.console-control-action:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-control-summary-line {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
}

.console-hidden-control {
    display: none;
}

#console-staged-context-tray,
#console-workspace-context,
#console-run-inspector {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
}

#console-main-column,
#console-right-rail {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
}

#console-staged-context-tray,
#console-workspace-context {
    width: 100%;
    min-width: 0;
}

#console-staged-context-tray {
    height: auto;
    min-height: 3;
    max-height: 6;
}

#console-workspace-context {
    height: auto;
    min-height: 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

#console-workspace-handoff-rows {
    height: auto;
    min-height: 0;
}

#console-workspace-conversations-header {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    layout: horizontal;
    align: left middle;
}

.console-workspace-action.console-workspace-conversations-toggle {
    width: 3;
    min-width: 3;
    max-width: 3;
    margin: 0;
}

#console-workspace-selected-conversation {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    color: $ds-text-muted;
    background: $ds-surface-panel;
}

#console-workspace-conversation-search-row {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    layout: horizontal;
    align: left middle;
}

#console-workspace-conversation-search {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
}

#console-workspace-conversation-search-clear {
    width: auto;
    min-width: 7;
    height: 1;
    min-height: 1;
    margin: 0;
}

#console-workspace-conversations {
    width: 100%;
    min-width: 0;
    height: auto;
    min-height: 0;
    overflow-y: hidden;
    overflow-x: hidden;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.console-workspace-conversation-row {
    height: auto;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.console-workspace-conversation-row-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-conversation-browser-section-header {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    layout: horizontal;
    align: left middle;
}

.console-conversation-browser-section-title {
    width: 1fr;
    min-width: 0;
}

.console-conversation-browser-group-header {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    layout: horizontal;
    align: left middle;
}

.console-conversation-browser-group-title {
    width: 1fr;
    min-width: 0;
    color: $ds-text-muted;
}

.console-conversation-browser-row-line {
    width: 100%;
    min-width: 0;
    layout: horizontal;
}

.console-conversation-star {
    width: 3;
    min-width: 3;
    max-width: 3;
    height: 2;
    min-height: 2;
    margin: 0 1 1 0;
}

#console-left-rail {
    height: 100%;
    min-height: 0;
    overflow: hidden;
}

#console-left-rail:focus {
    outline: none;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#console-left-rail-body {
    width: 100%;
    min-width: 0;
    height: 1fr;
    min-height: 0;
    padding: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#console-left-rail-body:focus {
    outline: none;
    border: none;
    background: $ds-surface-panel;
}

#console-workspace-context:focus {
    outline: none;
    border: none;
    background: $ds-surface-panel;
}

#console-workspace-conversations:focus {
    outline: none;
    border: none;
    background: $ds-surface-panel;
}

.console-left-rail-section {
    margin: 0 0 1 0;
    padding: 0 1;
}

#console-inspector-rail-body {
    width: 100%;
    min-width: 0;
    height: 1fr;
    min-height: 0;
    padding: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#console-main-column {
    width: 13fr;
    min-width: 60;
    padding: 0;
}

#console-right-rail {
    width: 4fr;
    min-width: 34;
    overflow: hidden;
}

#console-staged-context-tray,
#console-workspace-context,
#console-right-rail,
#console-run-inspector,
#console-transcript-region {
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#console-staged-context-tray.console-frame-quiet,
#console-workspace-context.console-frame-quiet {
    border: none;
    background: $ds-surface-panel;
}

#console-run-inspector {
    width: 100%;
    min-width: 0;
    height: auto;
    min-height: 0;
    border: none;
}

#console-run-inspector-state {
    height: auto;
    min-height: 0;
}

.console-rail-handle {
    width: 13;
    min-width: 13;
    max-width: 13;
    height: 100%;
    min-height: 20;
    padding: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

.console-rail-handle-right {
    width: 11;
    min-width: 11;
    max-width: 11;
    height: auto;
    min-height: 3;
    max-height: 6;
    border: none;
    background: transparent;
}

.console-rail-handle-button {
    width: 11;
    min-width: 0;
    max-width: 11;
    height: 100%;
    min-height: 100%;
    max-height: 100%;
    text-align: center;
    content-align: center middle;
}

.console-rail-handle-button-right {
    width: 11;
    max-width: 11;
    height: 3;
    min-height: 3;
    max-height: 3;
}

.console-rail-collapse-button {
    width: 3;
    min-width: 3;
    max-width: 3;
    height: 1;
    min-height: 1;
    text-align: left;
    content-align: left middle;
}

.console-rail-handle-badge {
    height: auto;
    min-height: 1;
    width: 100%;
    text-align: center;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.console-rail-header {
    height: 1;
    min-height: 1;
    layout: horizontal;
}

.console-rail-title {
    width: 1fr;
    min-width: 0;
    text-align: left;
    content-align: left middle;
}

.console-rail-section-header {
    height: 1;
    margin-top: 1;
}

.console-rail-section-title {
    width: 1fr;
    text-style: bold;
}

.console-rail-section-toggle {
    width: 3;
    min-width: 3;
}

.console-rail-section-body {
    height: auto;
    min-height: 0;
}

.console-model-section-line {
    height: 1;
    color: $ds-text-muted;
}

.console-agent-section-line {
    height: 1;
    color: $ds-text-primary;
}

.console-agent-section-steps,
.console-agent-section-subagents {
    height: auto;
    color: $ds-text-muted;
    text-style: dim;
}

.console-agent-drilldown-back {
    margin-top: 1;
}

#console-rail-system-line {
    height: 1;
    color: $ds-text-primary;
}

#console-rail-system-line.console-rail-system-line-dim {
    color: $ds-text-muted;
}

.console-inspector-group-heading {
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-inspector-status-summary {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-inspector-action {
    height: 1;
    min-height: 1;
    margin: 0;
}

.console-inspector-disabled-reason {
    height: 0;
    min-height: 0;
}

.console-live-work-source-readiness {
    height: auto;
    min-height: 0;
    margin: 1 0 0 0;
}

.console-live-work-source-row {
    height: auto;
    min-height: 1;
}

.console-settings-summary {
    height: auto;
    min-height: 9;
    padding: 0 1;
}

.console-left-rail-section.console-settings-summary {
    margin: 0 0 1 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-panel;
}

.console-inspector-session-settings {
    margin: 1 0 0 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-panel;
}

.console-settings-header {
    height: 1;
    min-height: 1;
    layout: horizontal;
    align: left middle;
}

.console-settings-title {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
    max-height: 1;
}

.console-settings-row {
    height: 1;
    min-height: 1;
    max-height: 1;
    overflow: hidden hidden;
    text-wrap: nowrap;
    text-overflow: ellipsis;
}

#console-settings-open {
    width: auto;
    min-width: 9;
    max-width: 14;
    height: 1;
    min-height: 1;
    margin: 0;
}

#console-transcript-region,
#console-session-surface {
    height: 1fr;
    min-height: 0;
}

#console-session-surface {
    padding: 0;
    margin: 0;
    border: none;
}

#console-transcript-region {
    padding: 0 1;
    border: round $ds-column-line;
    background: $ds-surface-panel;
}

.console-start-here,
.console-action-hints {
    height: auto;
    min-height: 1;
    padding: 0 1;
}

.console-start-here {
    margin: 0;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

#console-start-here,
#console-action-hints {
    display: none;
    height: 0;
    min-height: 0;
    max-height: 0;
    padding: 0;
    margin: 0;
}

.console-action-hints {
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

#console-native-composer {
    height: auto;
    min-height: $ds-console-composer-height;
    max-height: 8;
    padding: 1;
    margin: 0;
    layout: horizontal;
    align: left middle;
    border: round $ds-column-line;
    background: $ds-surface-panel;
}

#console-native-composer.console-composer-has-draft {
    border: round $ds-status-ready;
}

#console-native-composer.console-composer-focused {
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
}

#console-native-composer.console-composer-setup-blocked #console-command-visible-text {
    color: $ds-status-warning;
}

#console-composer-title,
#console-composer-status,
.console-composer-recovery,
.console-send-disabled-reason,
.console-control-label {
    height: 1;
    min-height: 1;
}

#console-composer-title {
    width: 10;
    min-width: 10;
}

#console-command-visible-text {
    width: 1fr;
    min-width: 0;
    height: auto;
    min-height: 1;
    max-height: 4;
    margin: 0 1 0 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    overflow: hidden;
}

#console-native-composer.console-composer-has-draft #console-command-visible-text,
#console-native-composer:focus-within #console-command-visible-text,
#console-command-visible-text:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-composer-actions {
    width: 37;
    min-width: 37;
    max-width: 37;
    height: 1;
    min-height: 1;
    layout: horizontal;
    align: right middle;
}

.console-composer-recovery {
    width: 0;
    min-width: 0;
    max-width: 0;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-status-warning;
    text-style: bold;
    text-overflow: ellipsis;
    text-wrap: nowrap;
}

.console-send-disabled-reason {
    width: 0;
    min-width: 0;
    max-width: 0;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-status-warning;
    text-style: bold;
    text-overflow: ellipsis;
    text-wrap: nowrap;
}

#console-command-input {
    display: none;
    width: 0;
    min-width: 0;
    height: 0;
    min-height: 0;
}

#console-composer-status {
    width: auto;
    min-width: 0;
}

#console-session-surface .chat-input-area {
    display: none;
}

.console-transcript-system-event {
    height: auto;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    border-left: solid $ds-status-warning;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-chat-tabs,
#console-chat-tabs #chat-sessions-container,
#console-chat-tabs .chat-session {
    height: 100%;
    min-height: 0;
}

#console-transcript-surface {
    height: 1fr;
    min-height: 0;
    layers: console-background console-content;
}

#console-transcript-background-effect {
    layer: console-background;
    width: 100%;
    height: 100%;
    color: $ds-text-muted;
    background: transparent;
}

#console-native-transcript {
    height: 1fr;
    min-height: 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
    scrollbar-size: 1 1;
}

#console-transcript-surface #console-native-transcript {
    layer: console-content;
    height: 1fr;
    min-height: 0;
    background: transparent;
}

#console-transcript-title,
.console-transcript-title {
    height: 1;
    min-height: 1;
    max-height: 1;
    margin: 0;
    background: $ds-surface-panel;
    color: $ds-text-muted;
    text-style: none;
}

#console-native-tab-strip,
.console-session-tab-strip {
    height: 1;
    min-height: 1;
    max-height: 1;
    margin: 0;
    margin-bottom: 1;
    background: $ds-surface-panel;
}

.console-session-tab,
#console-new-chat-tab {
    width: auto;
    min-width: 8;
    height: 1;
    min-height: 1;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-session-close-button {
    padding: 0;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.console-session-tab-active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-session-tab-active:hover,
.console-session-tab-active:hover:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

#console-native-transcript:focus {
    border: solid $ds-focus-accent;
    border-bottom: solid $ds-focus-accent;
}

.console-transcript-rule {
    height: 1;
    min-height: 1;
    color: $ds-column-line;
}

.console-transcript-message {
    height: auto;
    min-height: 1;
    padding: 0 1;
    margin: 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.console-transcript-message-selected {
    min-height: 2;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-transcript-message-tool {
    color: $ds-text-muted;
    text-style: dim italic;
}

.console-transcript-message-system {
    color: $ds-text-muted;
}

.console-transcript-action-row {
    height: 3;
    min-height: 3;
    margin: 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-transcript-action-guide {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    color: $ds-text-muted;
}

.console-modal-header {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-transcript-action-button {
    width: auto;
    min-width: 5;
    height: 3;
    min-height: 3;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-transcript-action-button:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

.console-workspace-selector-row {
    margin: 0 0 1 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.console-workspace-status-pair {
    height: auto;
    min-height: 1;
    margin: 0;
}

.console-workspace-status-label {
    color: $ds-text-muted;
    text-style: bold;
}

.console-workspace-status-value {
    color: $ds-text-primary;
}

.console-workspace-action {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
}

#console-transcript-empty-state,
.console-transcript-empty-panel {
    height: 100%;
    min-height: 100%;
    width: 100%;
    layout: vertical;
    padding: 1 2;
    background: transparent;
    color: $ds-text-primary;
}

#console-shell .workbench-recovery-callout,
#console-control-bar,
#console-workspace-grid,
#console-transcript-region,
#console-native-composer {
    opacity: 100%;
}

.console-transcript-empty-body {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0;
    color: $ds-text-muted;
}

.console-setup-step {
    height: 1;
    color: $ds-text-primary;
}

.console-setup-step-done {
    color: $ds-text-muted;
}

.console-setup-step-active {
    text-style: bold;
}

.console-setup-step-pending {
    color: $ds-text-muted;
}

/* First-run blocking setup modal: a Console-scoped overlay layer painted over
 * the whole Console shell (rail + transcript + composer) while setup is
 * incomplete. The app tab bar lives outside the shell and stays reachable. */
#console-shell {
    layers: console-workbench console-setup-overlay;
}

#console-setup-modal {
    layer: console-setup-overlay;
    display: none;
    width: 100%;
    height: 100%;
    align: center middle;
    /* $background is a distinctly darker token than the Console shell's own
     * $ds-surface-panel background, so this alpha fill actually blends to a
     * dimmed shade (verified: ~#191d21 vs the shell's flat #242f38) instead
     * of a same-color no-op like the previous $ds-surface-panel 80% fill. */
    background: $background 60%;
    layers: console-setup-snow console-setup-card;
}

.console-setup-modal-backdrop-snow {
    layer: console-setup-snow;
    width: 100%;
    height: 100%;
    color: $ds-text-muted;
}

/* Console's rendered frame color (#6f7782) — see chat_screen.CONSOLE_FRAME_COLOR. */
.console-setup-modal-card {
    layer: console-setup-card;
    width: 62;
    max-width: 90%;
    height: auto;
    padding: 1 2;
    layout: vertical;
    border: solid #6f7782;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.console-setup-modal-title {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0;
    color: $ds-text-primary;
    text-style: bold;
}

.console-setup-modal-action {
    width: auto;
    min-width: 12;
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    border: none;
    background: $ds-focus-bg;
    color: $ds-text-primary;
    content-align: left middle;
}

.console-setup-modal-action:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

#console-chat-tabs {
    display: none;
}

#console-session-surface .chat-empty-state {
    min-height: 5;
    padding: 0 1;
    text-align: left;
    content-align: left top;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#console-session-surface .chat-log {
    padding: 0 1;
    background: $ds-surface-panel;
    border: tall $ds-grid-line;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
    scrollbar-size: 1 1;
}

#console-send-message,
#console-stop-generation {
    width: 8;
    min-width: 8;
}

#console-send-message,
#console-stop-generation,
#console-attach-context,
#console-save-chatbook {
    height: 1;
    min-height: 1;
}

#console-attach-context {
    width: 10;
    min-width: 10;
}

#console-save-chatbook {
    width: 8;
    min-width: 8;
}

.console-action-primary {
    border: none;
    height: 1;
    min-height: 1;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

.console-action-secondary {
    border: none;
    height: 1;
    min-height: 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-action-subdued {
    border: none;
    height: 1;
    min-height: 1;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: none;
}

.console-action-disabled {
    border: none;
    height: 1;
    min-height: 1;
    background: $ds-surface-panel;
    color: $ds-text-disabled;
    text-style: none;
}

.console-action-disabled:hover,
.console-action-disabled:focus,
.console-action-disabled:hover:focus {
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-disabled;
    text-style: none;
    outline: none;
}

#console-stop-generation.console-stop-active {
    border: none;
    background: $ds-status-warning 20%;
    color: $ds-text-primary;
    text-style: bold;
}

#console-save-chatbook.console-save-chatbook-ready {
    color: $ds-text-primary;
}

.console-control-label,
.console-staged-context-row,
.console-staged-context-summary,
.console-staged-context-recovery {
    width: auto;
    min-width: 0;
    height: auto;
}

.console-compact-model-bar {
    width: auto;
    min-width: 0;
}


#artifacts-workbench,
#personas-workbench,
#watchlists-workbench,
#schedules-workbench,
#workflows-workbench,
#mcp-workbench,
#acp-workbench,
#skills-workbench,
#settings-workbench {
    height: 1fr;
    min-height: 20;
    padding: 1;
    margin: 0;
    overflow: hidden;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#artifacts-list-pane,
#artifacts-detail-pane,
#artifacts-inspector-pane,
#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#mcp-server-tree-pane,
#mcp-detail-pane,
#mcp-readiness-pane,
#acp-list-pane,
#acp-detail-pane {
    margin: 0 1 0 0;
}

#artifacts-inspector-pane,
#personas-inspector-pane,
#watchlists-inspector-pane,
#schedules-inspector-pane,
#workflows-inspector-pane,
#mcp-readiness-pane,
#acp-inspector-pane {
    margin: 0;
}

#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#acp-list-pane,
#acp-detail-pane,
#acp-inspector-pane {
    height: 100%;
    min-height: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#personas-inspector-pane {
    width: 2fr;
    min-width: 30;
    border: solid $ds-grid-line;
    padding: 1;
}

#personas-readiness-console {
    width: 100%;
    min-width: 0;
    height: auto;
    text-wrap: wrap;
}

/* Workbench column split (2:4:2). Required here because the generic
   .destination-workbench-pane width (1fr) outranks the screen's DEFAULT_CSS,
   which would squeeze the work area to a third of its intended width. */
#personas-library-pane {
    width: 2fr;
    min-width: 24;
}

#personas-work-area {
    width: 4fr;
    min-width: 40;
}

#personas-workbench.personas-workbench-compact {
    padding: 0;
}

#personas-library-pane.personas-workbench-compact-pane {
    width: 1fr;
    min-width: 16;
    padding: 0 1;
}

#personas-work-area.personas-workbench-compact-pane {
    width: 3fr;
    min-width: 34;
    padding: 0 1;
}

#personas-inspector-pane.personas-workbench-compact-pane {
    width: 1fr;
    min-width: 22;
    padding: 0 1;
}

#schedules-list-pane,
#workflows-list-pane,
#acp-list-pane {
    width: 2fr;
    min-width: 30;
    border: solid $ds-grid-line;
    padding: 1;
}

#schedules-detail-pane,
#workflows-detail-pane,
#acp-detail-pane {
    width: 4fr;
    min-width: 52;
    border: solid $ds-grid-line;
    padding: 1;
}

#schedules-inspector-pane,
#workflows-inspector-pane,
#acp-inspector-pane {
    width: 2fr;
    min-width: 34;
    border: solid $ds-grid-line;
    padding: 1;
}

.acp-selected-session-row {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.acp-inspector-group-title {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

#personas-list-detail-divider,
#personas-detail-inspector-divider,
#watchlists-list-detail-divider,
#watchlists-detail-inspector-divider,
#schedules-list-detail-divider,
#schedules-detail-inspector-divider,
#workflows-list-detail-divider,
#workflows-detail-inspector-divider,
#acp-list-detail-divider,
#acp-detail-inspector-divider {
    background: $ds-grid-line;
}

.artifacts-column-title,
.personas-column-title,
.watchlists-column-title,
.schedules-column-title,
.workflows-column-title,
.acp-column-title,
.skills-column-title,
.ccp-column-title,
.settings-column-title {
    width: 100%;
    height: 1;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-active-section {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button {
    width: 100%;
    height: 1;
    min-height: 1;
    max-height: 1;
    margin: 0;
    padding: 0 1;
    content-align: left middle;
    text-align: left;
    background: $ds-surface-panel;
}

Button.settings-category-button.settings-active-section {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button:focus {
    outline: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

Button.settings-category-button.settings-active-section:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button.settings-active-section:hover,
Button.settings-category-button.settings-active-section:hover:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button.settings-primary-search-match {
    color: $ds-text-primary;
    text-style: bold;
}

Button.settings-category-button.settings-secondary-search-match {
    color: $ds-text-muted;
}

#settings-category-search {
    width: 100%;
    height: 3;
    min-height: 3;
    max-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

#settings-category-search:focus {
    border: solid $ds-action-focus;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
    outline: none;
}

#settings-category-search.settings-category-search-active {
    border: solid $ds-action-focus;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.settings-category-search-help {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

.settings-category-search-status {
    width: 100%;
    min-height: 2;
    padding: 0 1;
    margin: 0 0 1 0;
    color: $ds-text-primary;
    background: $ds-surface-panel;
}

.settings-search-empty {
    width: 100%;
    min-height: 3;
    padding: 1;
    margin: 1 0 0 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-muted;
}

#settings-shell Button:focus,
#settings-shell Button:hover:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold underline;
    outline: none;
}

.settings-category-group-title {
    width: 100%;
    height: 1;
    min-height: 1;
    padding: 0 1;
    margin: 1 0 0 0;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-state-banner {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-detail-row {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.settings-input-row {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
}

.settings-select-row {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
}

.settings-input-label {
    width: 12;
    min-width: 12;
    height: 1;
    min-height: 1;
    padding: 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-select-row .settings-input-label {
    height: 3;
    min-height: 3;
    content-align: left middle;
}

.settings-compact-input {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.settings-compact-input:focus {
    border: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    /* No underline: it made placeholder copy read as a link (task-185). */
    text-style: bold;
    outline: none;
}

.settings-compact-input.settings-invalid-input,
.settings-compact-select.settings-invalid-input {
    background: $ds-status-error 18%;
    color: $ds-text-primary;
    text-style: bold;
    outline: none;
}

.settings-compact-input.settings-invalid-input:focus,
.settings-compact-select.settings-invalid-input:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-opacity: 1;
    text-style: bold;
    outline: none;
}

.settings-compact-select {
    width: 1fr;
    height: 3;
    min-height: 3;
    margin: 0;
    padding: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.settings-compact-select > SelectCurrent {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
    content-align: left middle;
}

.settings-compact-select:focus {
    border: solid $ds-action-focus;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
    outline: none;
}

.settings-compact-select:focus > SelectCurrent {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-compact-select > SelectOverlay {
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    min-width: 30;
}

.settings-compact-select > SelectOverlay Option {
    padding: 0 2;
    min-height: 3;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.settings-compact-select > SelectOverlay Option:hover {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

.settings-compact-select > SelectOverlay Option.-selected {
    padding: 0 2;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.settings-provider-manual-hidden {
    display: none;
}

/* task-189: generation-profile rows a provider does not support are hidden
   entirely; the Generation defaults disclosure shows one summary line instead
   of per-row "Unavailable for <provider>" placeholders. */
.settings-gated-profile-hidden {
    display: none;
}

.settings-status-row {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-inspector;
    color: $ds-text-muted;
}

.settings-storage-check-result {
    min-height: 7;
}

.settings-category-status-hidden {
    display: none;
}

.settings-dirty-category {
    color: $ds-status-unsaved;
    text-style: bold;
}

.settings-focus-card {
    width: 100%;
    height: auto;
    min-height: 10;
    padding: 1;
    margin: 0 0 1 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#settings-advanced-config-card {
    height: 1fr;
    min-height: 0;
}

.settings-secondary-card {
    width: 100%;
    height: auto;
    min-height: 6;
    padding: 1;
    margin: 0 0 1 0;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#settings-console-behavior-card {
    min-height: 12;
}

.settings-action-row {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 1 0;
}

.settings-action-row Button {
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
}

.settings-action-row Button:focus,
#settings-impact-pane Button:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold underline;
    outline: none;
}

.settings-sync-safety-row {
    width: 100%;
    padding: 0 1;
    background: $ds-surface-raised;
}

.settings-advanced-safety-status {
    background: $ds-status-unsaved 10%;
    color: $ds-status-unsaved;
    text-style: bold;
}

#settings-advanced-config-editor {
    height: 1fr;
    min-height: 10;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#library-source-browser {
    width: $ds-library-source-browser-width;
    min-width: $ds-library-source-browser-width;
    max-width: $ds-library-source-browser-width;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    overflow-y: auto;
}

.library-hub-spacer {
    height: 1;
    min-height: 1;
}

#library-source-inspector {
    width: 2fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    overflow-y: auto;
}

#library-source-detail {
    width: 5fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    overflow-y: auto;
}

.ds-shortcut-bar {
    dock: bottom;
    height: 1;
    padding: 0 1;
    background: $ds-surface-inspector;
    color: $ds-text-muted;
}

.density-compact .ds-panel,
.density-compact .ds-inspector,
.density-compact .ds-approval-card,
.density-compact .ds-recovery-callout {
    padding: 0 1;
    margin: 0 0 1 0;
}

.density-compact .ds-destination-header {
    min-height: 2;
    padding: 0 1;
}

.density-comfortable .ds-panel,
.density-comfortable .ds-inspector,
.density-comfortable .ds-approval-card,
.density-comfortable .ds-recovery-callout {
    padding: 1 2;
    margin: 1 1;
}

.density-comfortable .ds-destination-header {
    min-height: 4;
    padding: 1 2;
}

.is-active {
    border: round $ds-action-focus;
    text-style: bold;
}

.personas-mode-chip.is-active {
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.personas-mode-chip.is-active:focus {
    outline: none;
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Keyboard-browse cursor: visually distinct from the flat subdued bg.
   $ds-grid-line (#26364D) is lighter than $ds-surface-raised/#ds-focus-bg
   (#142033) so browsed rows are visible without special-casing focus state.
   Place BEFORE the .is-active rules so equal-specificity cascade gives
   .is-active the final word. */
ListItem.personas-library-row.-highlight,
ListItem.personas-conversation-row.-highlight {
    background: $ds-grid-line;
    color: $ds-text-primary;
    text-style: bold;
}

/* Selected/active row: wins because it appears later in the sheet. */
ListItem.personas-library-row.is-active {
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
}

/* Active row that is also the browse cursor: .is-active styling wins
   (later in sheet, same specificity as the -highlight rule above). */
ListItem.personas-library-row.is-active.-highlight {
    outline: none;
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
}

.library-source-action {
    width: $ds-library-source-action-width;
    min-width: $ds-library-source-action-min-width;
    height: $ds-library-source-action-height;
    min-height: $ds-library-source-action-height;
    margin: 0;
    padding: 0 1;
    border: none;
    background: transparent;
    color: $ds-text-primary;
    content-align: left middle;
    text-style: none;
}

.library-source-action-spacer {
    height: 0;
    min-height: 0;
}

.library-source-active-marker {
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
}

.library-source-group-rule {
    height: 1;
    min-height: 1;
    margin: 0;
    color: $ds-text-muted;
}

.library-source-action:focus {
    border: none;
    background: transparent;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

.library-source-action.is-active,
.library-source-action.is-active:focus {
    border: none;
    background: transparent;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

#library-collection-form Input {
    height: 3;
    min-height: 3;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-collection-form Input:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-collection-actions {
    height: 1;
    min-height: 1;
    margin-top: 1;
    align: left middle;
}

#library-collection-actions Button {
    height: 1;
    min-height: 1;
    margin-right: 1;
    padding: 0 1;
    border: none;
    background: transparent;
    color: $ds-text-primary;
    content-align: left middle;
    text-style: none;
}

#library-collection-actions Button:focus {
    border: none;
    background: transparent;
    color: $ds-focus-fg;
    outline: none;
    text-style: bold underline;
}

/* Regression fix: #library-canvas (this panel's parent) and this panel's
 * own body never scrolled, so once the Query/Scope/Results/History regions'
 * combined natural height exceeded the fixed canvas box, whatever fell
 * past the bottom edge was silently clipped and permanently unreachable --
 * not just visually cut off, but gone, with no way to scroll to it. That
 * is what made multi-result searches render only the first row: rows past
 * whatever vertical room the Query and Scope regions left behind vanished.
 * Making the panel scrollable keeps every mounted row reachable regardless
 * of how many results (or how much recovery/callout copy) the current
 * state renders. */
#library-search-rag-panel {
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

.library-rag-region {
    width: 100%;
    min-width: 0;
    margin: 0 0 1 0;
}

/* Auto-height: the query row used to be a Horizontal (Input + Button side
 * by side) inside this container, sized with a hand-counted fixed height
 * (14, 17 with the recovery line). Stacking the query Input and Run button
 * as their own full-width rows (house canvas grammar) made that hand count
 * fragile -- content growth (e.g. the mode-toggle button) silently overflowed
 * the fixed height, clipping/overlapping the callout and Run button. Sizing
 * to content avoids re-counting rows by hand every time this region changes. */
#library-rag-query-controls {
    height: auto;
    min-height: 0;
}

/* Auto-height: B2 replaced the fixed pipe-drawn scope table (heading +
 * summary + table header + 7 rows, hand-counted at 13/16 lines) with a
 * heading, a summary line, and three toggle buttons -- a fixed hand count
 * here would re-introduce the exact clipping bug `#library-rag-query-controls`
 * already hit once (see the comment above it). */
#library-rag-source-scope {
    height: auto;
    min-height: 0;
}

#library-rag-results {
    height: auto;
    min-height: 8;
}

#library-rag-query-input {
    width: 100%;
    min-width: 0;
    margin: 0 0 1 0;
    border: solid $ds-grid-line;
    background: $ds-surface-raised;
}

#library-rag-query-input:focus {
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
}

#library-rag-scope-summary {
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.library-rag-scope-toggle {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.library-rag-scope-toggle:hover {
    background: $ds-action-focus 20%;
}

.library-rag-scope-toggle:disabled {
    color: $ds-text-disabled;
    background: $ds-surface-raised;
}

.library-rag-callout {
    width: 100%;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

/* Reserved for real failures only (unsafe query, missing dependencies/
 * index, no provider) -- the ready state has no callout at all (A2), and
 * the empty-query / no-scope gates render `.library-rag-quiet-line`
 * instead (A1), so there is no "is-ready" callout variant to style. */
.library-rag-callout.is-blocked {
    border: solid $ds-status-warning;
    background: $ds-status-warning 10%;
}

.library-rag-quiet-line {
    padding: 0 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

.library-rag-empty-guidance {
    margin: 1 0 0 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#library-rag-run-query {
    width: 18;
    min-width: 16;
    margin: 0 0 1 0;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

#library-rag-run-query:disabled {
    background: $ds-surface-raised;
    color: $ds-text-disabled;
    text-style: none;
}

.library-rag-result-row {
    padding: 0 1;
    margin: 1 0 0 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

.library-rag-result-row.is-selected {
    border: heavy $ds-focus-accent;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
}

.library-rag-result-badges {
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: bold;
}

/* C1: content-first result rows -- Open (primary emphasis, reuses the live
 * `.console-action-primary` colors directly since that class is not
 * Console-screen-scoped) then Select evidence, as a Horizontal of
 * auto-width buttons. */
.library-rag-result-actions {
    width: 100%;
    height: auto;
    margin: 1 0 0 0;
}

.library-rag-result-open {
    width: auto;
    min-width: 10;
    margin: 0 1 0 0;
}

.library-rag-result-action {
    width: auto;
    min-width: 16;
    height: 1;
    min-height: 1;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.library-rag-recovery-action {
    width: 28;
    min-width: 18;
    background: $ds-status-warning 30%;
    color: $ds-text-primary;
    text-style: bold;
}

.library-rag-console-action {
    width: 18;
    min-width: 16;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

.library-rag-center-console-action {
    width: 24;
    min-width: 18;
    margin: 1 0 0 0;
}

.library-rag-console-action:disabled {
    background: $ds-surface-raised;
    color: $ds-text-disabled;
    text-style: none;
}

#library-rag-mode-toggle {
    width: auto;
    min-width: 20;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

#library-rag-mode-toggle:hover {
    background: $ds-action-focus 20%;
}

#library-rag-searching-line {
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: italic;
}

#library-rag-history {
    margin: 1 0 0 0;
}

.library-rag-history-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.library-rag-history-row:hover {
    background: $ds-action-focus 20%;
}

.library-rag-history-empty {
    color: $ds-text-muted;
    padding: 0 1;
}

.library-rag-history-hint {
    color: $ds-text-muted;
    padding: 0 1;
    margin: 0 0 1 0;
}

.library-rag-history-clear {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 1 0 0 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.library-rag-history-clear:hover {
    background: $ds-action-focus 20%;
}

.is-disabled {
    opacity: 0.55;
}

.is-blocked {
    border: round $ds-status-error;
    background: $ds-status-error 10%;
}

.is-running {
    border: round $ds-status-running;
}

.is-paused {
    border: round $ds-status-paused;
}

.is-unsaved {
    border: round $ds-status-unsaved;
}

.is-stale {
    color: $ds-text-muted;
}

.is-conflict {
    border: thick $ds-status-error;
}

.needs-approval {
    border: thick $ds-status-approval-required;
    background: $ds-status-approval-required 12%;
}

.source-local {
    border: round $ds-authority-local;
}

.source-server {
    border: round $ds-authority-server;
}

.source-workspace {
    border: round $ds-authority-workspace;
}

.source-remote-only {
    border: round $ds-authority-remote-only;
}

.source-dry-run {
    border: dashed $ds-grid-line;
    color: $ds-text-muted;
}

/* --- MCP Hub (Phase 1 workbench) ------------------------------------- */

#mcp-mode-strip Button.mcp-mode-chip {
    width: auto;
    min-width: 10;
    height: 1;
    padding: 0 1;
    border: none;
}

#mcp-mode-strip .mcp-mode-chip.is-active {
    text-style: bold underline;
}

/* A1: focus must not impersonate .is-active above (bold underline). Kept in
   lockstep with the lower-specificity baseline copy in MCPScreen.DEFAULT_CSS
   (mcp_screen.py) -- see that copy's comment for why it uses raw
   $surface/$text/$text-muted tokens instead of these $ds- aliases. */
#mcp-mode-strip .mcp-mode-chip:focus,
#mcp-mode-strip .mcp-mode-chip:hover:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
    outline: none;
}

#mcp-mode-strip .mcp-mode-chip.is-active:focus,
#mcp-mode-strip .mcp-mode-chip.is-active:hover:focus {
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: bold underline;
    outline: none;
}

#mcp-hub-rail {
    width: 3fr;
    min-width: 24;
}

#mcp-hub-rail .mcp-rail-heading {
    height: 1;
    min-height: 1;
    margin-top: 1;
}

/* Override border away from the generic `.is-active` rule (`border: round
   $ds-action-focus`, earlier in this sheet). Button.mcp-rail-row rows are
   fixed at height 1 (see MCPRail.DEFAULT_CSS); a round border needs at
   least 2 lines to render, so on a height-1 button it consumes the row's
   only line and the content area collapses to height 0 -- the label never
   renders, leaving a blank bordered box for the selected row. Mirrors the
   sibling `.mcp-mode-chip.is-active` rule below (and MCPScreen.DEFAULT_CSS's
   copy of it), which already carries this same `border: none` override. */
#mcp-hub-rail Button.mcp-rail-row.is-active {
    border: none;
    text-style: bold;
}

#mcp-hub-canvas {
    width: 5fr;
    min-width: 38;
}

#mcp-hub-inspector {
    width: 3fr;
    min-width: 28;
}

/* A5: the row wrapping the aggregate summary's colored glyph + neutral
   sentence (kept in lockstep with the width rules in
   MCPServersMode.DEFAULT_CSS, mcp_servers_mode.py -- required in EVERY
   harness, not just the bundled one: without an explicit width split, both
   Static children of the Horizontal default to 1fr/full-width and the
   second one renders entirely off-screen). */
#mcp-overview-summary-row,
#mcp-detail-title {
    height: 1;
    min-height: 1;
}

#mcp-overview-callouts .ds-recovery-callout {
    margin-top: 1;
}

/* A2: disabled inspector action buttons must stay legible. The generic
   `Button:disabled` rule above (from _buttons.tcss, same "user CSS" tier as
   this file -- see MCPInspector.DEFAULT_CSS's matching rule and comment for
   why a widget-level DEFAULT_CSS override alone can never win this fight)
   stacks `opacity: 50%` on `$text-disabled` on a dark surface, which reads
   as functionally invisible on top of `.console-action-secondary`. Restore
   full opacity and use a dim-but-still-readable color instead. */
#mcp-hub-inspector Button.mcp-inspector-action:disabled {
    opacity: 100%;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: none;
}

#mcp-hub-inspector Button.mcp-inspector-action:disabled:hover {
    opacity: 100%;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: none;
}

/* A3: same Button center-default lesson as Button.mcp-rail-row
   (MCPRail.DEFAULT_CSS) and Button.mcp-callout below -- left-align the
   inspector's action stack. Kept in lockstep with the baseline copy in
   MCPInspector.DEFAULT_CSS (mcp_inspector.py). */
Button.mcp-inspector-action {
    text-align: left;
    content-align: left middle;
}

/* --- MCP Hub Phase 2 ------------------------------------------------- */
.mcp-status-ready { color: $ds-status-ready; }
.mcp-status-warning { color: $ds-status-warning; }
.mcp-status-error { color: $ds-status-error; }
.mcp-status-info { color: $ds-status-info; }

.ds-info-callout {
    border: round $ds-status-info;
    background: $ds-status-info 10%;
    padding: 0 1;
    height: auto;
}

Button.mcp-callout {
    width: 100%;
    height: 1;
    min-height: 1;
    padding: 0 1;
    border: none;
    /* Button defaults BOTH text-align AND content-align to center (see
       Textual's own Button.DEFAULT_CSS, and the same lesson documented on
       Button.mcp-rail-row in MCPRail.DEFAULT_CSS) -- text-align alone does
       not left-align a one-line Button label; without content-align the
       whole callout line still rendered centered under the table. */
    text-align: left;
    content-align: left middle;
}

#mcp-servers-form {
    height: auto;
    min-height: 0;
}

/* Kept in lockstep with the baseline copy in MCPServersMode.DEFAULT_CSS
   (mcp_servers_mode.py) -- T7 (P3 UX batch) gave the overview table
   `height: auto; max-height: 70%;` so it hugs its own row count instead of
   a `1fr` table ballooning to fill the pane and stranding
   #mcp-overview-callouts dozens of rows below its last row (same bug class
   as #mcp-detail-builtin-toggles below). Without this bundle-layer copy,
   app-loaded CSS cascading on top of DEFAULT_CSS could silently
   reintroduce that regression. */
#mcp-servers-table {
    height: auto;
    max-height: 70%;
}

/* Kept in lockstep with the baseline copy in MCPToolsMode.DEFAULT_CSS
   (mcp_tools_mode.py) -- same fix, same rationale, as #mcp-servers-table
   immediately above. */
#mcp-tools-table {
    height: auto;
    max-height: 70%;
}

/* T9 (P4): kept in lockstep with the baseline copy in
   MCPPermissionsMode.DEFAULT_CSS (mcp_permissions_mode.py) -- same fix,
   same rationale, as #mcp-servers-table/#mcp-tools-table above: the matrix
   hugs its own row count instead of ballooning to fill the canvas, leaving
   room for the policy-preview strip below it. */
#mcp-perm-table {
    height: auto;
    max-height: 70%;
}

/* T9 (P4): kept in lockstep with the baseline copy in
   MCPPermissionsMode.DEFAULT_CSS -- the policy-preview strip below the
   matrix is a single Static (a sentence or two at most); without this,
   Vertical's own default sizing could let it compete with the matrix table
   above for the canvas's remaining space instead of hugging its own
   content, same bug class as #mcp-detail-builtin-toggles/#mcp-import-list
   below. */
#mcp-perm-preview {
    height: auto;
    min-height: 0;
}

/* Defect 1 fix (QA round mcp-hub-phase3-2026-07): kept in lockstep with the
   baseline copy in MCPToolsMode.DEFAULT_CSS (mcp_tools_mode.py), but here
   it's load-bearing, not just defensive. Textual's cascade always treats
   every CSS_PATH-sourced rule (this bundle) as higher priority than any
   widget's own DEFAULT_CSS, regardless of selector specificity -- so
   _conversations.tcss's global, unscoped `Select { width: 100%; }` rule
   (intended for a completely different screen's sidebar forms) was
   silently winning over MCPToolsMode's own, far more specific override,
   collapsing the filter-server Select to a 0x0 region against its
   `width: auto` slot parent (the sibling filter Input already claims the
   full bar at `width: 1fr`). This copy must live in the bundle itself,
   with equal-or-higher specificity than that bare rule, to actually win. */
#mcp-tools-filter-server-slot Select {
    width: 28;
}

/* Kept in lockstep with the baseline copy in MCPServersMode.DEFAULT_CSS
   (mcp_servers_mode.py) -- without an explicit height override here too,
   Textual's Vertical default (height: 1fr) expands this container to fill
   the rest of #mcp-detail-scroll, pushing its sibling "Copy client config"
   Button roughly 800px below the built-in enable/expose checkboxes it
   should sit directly under. QA defect 1, mcp-hub-phase2-2026-07 round. */
#mcp-detail-builtin-toggles {
    height: auto;
    min-height: 0;
}

#mcp-detail-toolbar Button {
    height: 1;
    min-height: 1;
    border: none;
}

/* A1: kept in lockstep with the baseline copy in MCPImportPanel.DEFAULT_CSS
   (mcp_profile_form.py) -- without an explicit height override here too,
   Textual's Vertical default (height: 1fr) expands this container to
   consume whatever vertical space the panel has left, stranding the
   sibling "Import N servers"/Cancel action row far below the preview list
   on a real terminal window (same bug class as #mcp-detail-builtin-toggles,
   QA defect 1, mcp-hub-phase2-2026-07 round). */
#mcp-import-list {
    height: auto;
    min-height: 0;
}

/* T7 (P3 UX batch): quiet focus treatment for the hub's scrollable content
   panes. Both are VerticalScroll (can_focus=True by default, via
   ScrollableContainer) and, without a rule here, fall back to the generic
   `*:focus { outline: solid $ds-focus-accent; }` fallback (core/_reset.tcss)
   -- a heavy boxed cue for panes that just scroll read-only detail text /
   the legacy Advanced form. Mirrors the idiom already established for
   Console content panes elsewhere in this file (#console-left-rail-body:
   focus, #console-workspace-context:focus, #console-workspace-
   conversations:focus): drop the outline/border and shift the background
   instead, so keyboard focus stays visible without boxing the pane. Uses
   $ds-surface-panel (this codebase's quiet-surface token) rather than
   Textual's built-in $boost, which nothing else in this design system
   references. */
#mcp-detail-scroll:focus,
#mcp-adv-scroll:focus {
    outline: none;
    border: none;
    background: $ds-surface-panel;
}

/* --- MCP Hub Phase 5 (T9: Audit mode + Console batch approvals) ------ */

/* Kept in lockstep with the baseline copy in MCPAuditMode.DEFAULT_CSS
   (mcp_audit_mode.py) -- same fix, same rationale, as #mcp-servers-table/
   #mcp-tools-table/#mcp-perm-table above: the execution-log table hugs its
   own row count instead of ballooning to fill the canvas. */
#mcp-audit-table {
    height: auto;
    max-height: 70%;
}

/* Kept in lockstep with the baseline copy in MCPAuditMode.DEFAULT_CSS --
   same fix, same rationale, for the T8 Findings sub-view table. */
#mcp-audit-findings-table {
    height: auto;
    max-height: 70%;
}

/* Kept in lockstep with the baseline copy in MCPAuditMode.DEFAULT_CSS.
   The T8 Executions/Findings sub-view toggle strip is a Horizontal, which
   defaults to `height: 1fr` -- without this override it would expand to
   compete with the table below it for the canvas's remaining space
   instead of hugging its own two-button content, same bug class as
   #mcp-perm-preview/#mcp-detail-builtin-toggles/#mcp-import-list above. */
#mcp-audit-subview-strip {
    height: auto;
    min-height: 0;
}

/* Same Defect-1 Select-width lesson as #mcp-tools-filter-server-slot
   Select above (QA round mcp-hub-phase3-2026-07): `_conversations.tcss`'s
   bare `Select { width: 100%; }` rule always beats DEFAULT_CSS regardless
   of source order, so an id-scoped bundle rule is required for it to
   actually win. MCPAuditMode.DEFAULT_CSS already avoids the 0x0 collapse a
   different way for these two Selects (each lives in its own definite-
   width slot Vertical, not a bare auto-sized one -- see that file's own
   comment) -- these two rules are additional, defensive, EXPLICIT-width
   pins directly on the Selects' own ids (mirroring their slots' widths,
   24/20), kept in lockstep with the matching pair T9 added to
   MCPAuditMode.DEFAULT_CSS itself, so the Selects stay correctly sized
   even if the slot wrapper's own CSS were ever removed or the Select were
   ever mounted outside it. */
#mcp-audit-filter-decision {
    width: 24;
}
#mcp-audit-filter-initiator {
    width: 20;
}

/* The Console MCP batch-approval card's per-row layout
   (`ChatApprovalCard.set_batch()`, chat_approval_card.py -- T5 deferred
   this CSS to T9's phase gate). This card carries no `DEFAULT_CSS` of its
   own at all (unlike the MCP mode widgets above) -- these rules are the
   ONLY styling `.approval-row*` has anywhere, bundle or otherwise.

   `.approval-row` is a Horizontal, which defaults to `height: 1fr` --
   live-repro'd ballooning to the full card height (and its decision
   Select claiming the full ROW width in turn) before this fix, the same
   fr-inside-flex bug class as the MCP lockstep rules above. `height:
   auto` makes each row hug its own single line of content instead.

   `#approval-batch-rows` (the Vertical wrapping all rows) gets the same
   `height: auto` treatment as #mcp-perm-preview/#mcp-detail-builtin-
   toggles/#mcp-import-list above -- without it, its own `height: 1fr`
   default would balloon it to fill the card and push the sibling
   Approve-all/Submit/Deny-all action bar (#approval-batch-actions) far
   below the visible rows.

   `.approval-row-header`/`.approval-row-args` (Statics, natively `width:
   auto`) get an explicit `1fr` share each so unbounded text (a long
   tool/server header, or an args summary up to 80 chars) can't hog the
   row and squeeze the decision Select out of view. `.approval-row-
   decision` (the class selector on the row's Select) gets an explicit
   fixed width -- a CLASS selector already outranks the bare `Select {
   width: 100%; }` type selector on specificity alone, so (unlike the two
   MCP Select fixes above) no id-scoped selector is needed here for it to
   win; without this rule the Select would otherwise claim the row's FULL
   width instead of its own bounded share, overlapping/clipping behind the
   header and args text laid out before it. */
#approval-batch-rows {
    height: auto;
    min-height: 0;
}
.approval-row {
    height: auto;
    min-height: 1;
    width: 1fr;
}
.approval-row-header {
    width: 1fr;
}
.approval-row-args {
    width: 1fr;
}
.approval-row-decision {
    width: 26;
}
