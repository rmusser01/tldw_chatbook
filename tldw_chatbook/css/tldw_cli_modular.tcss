/* ===== MODULE: core/_variables.tcss ===== */
/* ========================================
 * CORE: Variables and Constants
 * ======================================== 
 * CSS variables, color definitions, and sizing constants
 * Used throughout the application
 * ======================================== */

$ds-surface-panel: $panel;
$ds-surface-raised: $surface;
$ds-surface-inspector: $surface;
$ds-grid-line: $surface-lighten-1;
$ds-column-line: $surface-lighten-2;
$ds-text-primary: $text;
$ds-text-muted: $text-muted;
$ds-text-disabled: $text-disabled;
$ds-action-focus: $primary;
$ds-focus-fg: $ds-text-primary;
$ds-focus-bg: $ds-surface-raised;
$ds-focus-accent: $primary;
$ds-input-focus-border: $primary;
$ds-input-focus-bg: $ds-surface-raised;
$ds-input-focus-accent: $primary;
$ds-status-ready: $success;
$ds-status-running: $primary;
$ds-status-info: $accent;
$ds-status-warning: $warning;
$ds-status-approval-required: $warning;
$ds-status-blocked: $error;
$ds-status-error: $error;
$ds-status-paused: $warning;
$ds-status-unsaved: $warning;
$ds-status-recovered: $success;
$ds-authority-local: $success;
$ds-authority-server: $primary;
$ds-authority-workspace: $accent;
$ds-authority-remote-only: $warning;
$ds-source-role-context: $accent;
$ds-source-role-evidence: $accent;
$ds-source-role-editable-target: $warning;
$ds-source-role-output-seed: $secondary;
$ds-destination-header-height: 1;
$ds-destination-compact-strip-height: 1;
$ds-home-dashboard-grid-height: 18;
$ds-home-control-button-height: 1;
$ds-home-compact-row-height: 1;
$ds-home-followup-row-height: 6;
$ds-console-workspace-grid-height: 1fr;
$ds-console-control-bar-height: 2;
$ds-console-composer-height: 5;
$ds-library-mode-bar-height: 1;
$ds-library-mode-label-width: 8;
$ds-library-mode-chip-height: 1;
$ds-library-mode-chip-min-width: 10;
$ds-library-source-action-width: auto;
$ds-library-source-action-min-width: 0;
$ds-library-source-action-height: 1;
$ds-library-source-browser-width: 31;

/* ===== MODULE: core/_reset.tcss ===== */
/* ========================================
 * CORE: Reset/Normalize
 * ======================================== 
 * Base resets and default styles
 * ======================================== */

/* Visible non-obscuring keyboard focus fallback. */
*:focus {
    outline: solid $ds-focus-accent;
}

/* REMOVED: These rules were causing layout shifts and visual issues */
/* *:hover { border: none; } */
/* *:focus-within { border: none; } */

/* Widgets should maintain consistent dimensions across all states */
/* Focus and hover states should only change colors, not layout */

/* ===== MODULE: core/_base.tcss ===== */
/* ========================================
 * CORE: Base Styles
 * ======================================== 
 * Root elements: Screen, Header, Footer
 * Foundation for the entire application
 * ======================================== */

Screen { layout: vertical; }
Header { dock: top; height: 1; background: $panel; }
Footer { dock: bottom; height: 1; background: $panel; }
#content { height: 1fr; width: 100%; }

/* ===== MODULE: core/_typography.tcss ===== */
/* ========================================
 * CORE: Typography
 * ======================================== 
 * Text styles, fonts, and text decorations
 * ======================================== */

/* ===== MODULE: layout/_windows.tcss ===== */
/* ========================================
 * LAYOUT: Windows
 * ======================================== 
 * Base window styles and window management
 * ======================================== */

/* Base style for ALL windows. The watcher will set display: True/False */
.window {
    height: 100%;
    width: 100%;
    layout: horizontal; /* Or vertical if needed by default */
    overflow: hidden;
}

.placeholder-window { 
    align: center middle; 
    background: $panel; 
    display: none;  /* Placeholders should always be hidden */
}

/* ===== MODULE: layout/_tabs.tcss ===== */
/* ========================================
 * LAYOUT: Tab System
 * ======================================== 
 * Tab navigation and tab button styles
 * ======================================== */

#tabs { dock: top; height: 4; background: $background; padding: 0 1; }
#tabs Button { 
    width: 1fr; 
    height: 100%; 
    min-height: 4;
    border: none;  /* No border for tab buttons */
    background: $panel; 
    color: $text-muted; 
    padding: 0 1;
}
#tabs Button:hover { 
    background: $panel-lighten-1; 
    color: $text;
}
#tabs Button.-active { 
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Single-line tab links navigation */
#tab-links-container {
    dock: top;
    height: 4;
    background: $panel;
    padding: 0 1;
    border: solid $accent;
}

#tab-links-inner {
    layout: horizontal;
    height: auto;
    width: auto;
    background: transparent;
    margin: 0;
    padding: 0;
}

#tab-links-inner > Static {
    width: auto;
    height: 1;
    margin: 0;
}

.tab-link {
    color: $text-muted;
    padding: 0 1;
    text-style: none;
    width: auto;
    height: auto;
}

.tab-link:hover {
    color: $text;
    text-style: underline;
    background: $panel-lighten-1;
}

.tab-link.-active {
    color: $ds-focus-fg;
    text-style: bold underline;
    background: transparent;
}

.tab-link.-active:hover {
    text-style: bold underline;
}

Tab.-active,
Tabs:focus .-active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.tab-separator {
    color: $text-muted;
    padding: 0;
    width: auto;
    height: 1;
}

/* Group separators - visually heavier than within-group separators */
.tab-group-separator {
    color: $accent;
    padding: 0 2;
    width: auto;
    height: 1;
    text-style: bold;
}

/* Group separator in button-based tab bar */
#tabs .tab-group-separator {
    width: auto;
    min-width: 3;
    height: 100%;
    min-height: 4;
    background: transparent;
    color: $accent;
    border: none;
    padding: 0 1;
}

/* ===== MODULE: layout/_sidebars.tcss ===== */
/* ========================================
 * LAYOUT: Sidebars
 * ======================================== 
 * Generic sidebar patterns and collapsible behavior
 * Used across multiple features
 * ======================================== */

/* ----------------------------------------
 * Enhanced Sidebar Styles
 * ---------------------------------------- */

/* Enhanced sidebar container */
.enhanced-sidebar {
    height: 100%;
    background: $boost;
}

/* Sidebar header with improved visibility */
.sidebar-header {
    height: 3;
    padding: 0 1;
    background: $surface;
    border-bottom: solid $surface-lighten-1;
    align: center middle;
}

.sidebar-title {
    text-style: bold;
    color: $text;
    text-align: left;
}

/* Preset bar for quick configuration */
.preset-bar {
    height: 3;
    padding: 0 1;
    background: $surface 15%;
    border-bottom: solid $surface-lighten-1;
    align: left middle;
}

.preset-button {
    width: auto;
    min-width: 10;
    margin: 0 1;
    padding: 0 1;
    background: $surface;
    border: tall $surface-lighten-1;
}

.preset-button.active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    border: tall $ds-focus-accent;
    text-style: bold underline;
}

.preset-button:hover {
    background: $surface-lighten-1;
    color: $text;
}

.preset-button.active:hover {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    border: tall $ds-focus-accent;
    text-style: bold underline;
}

/* Search container with better visibility */
.search-container {
    height: 3;
    padding: 0 1;
    background: transparent;
    border-bottom: none;
}

.search-input {
    width: 100%;
    border: round $surface-lighten-1;
    background: $background;
}

/* ----------------------------------------
 * Visual Grouping & Organization
 * ---------------------------------------- */

/* Quick Actions Bar */
.quick-actions-bar {
    height: 3;
    padding: 0 1;
    margin-bottom: 1;
    background: $primary 10%;
    border-bottom: solid $primary;
}

.quick-action-btn {
    width: auto;
    margin: 0 1;
    padding: 0 1;
}

/* Search Input */
.sidebar-search-input {
    width: 100%;
    margin: 1 0;
    border: round $accent;
}

/* Group Headers */
.group-header {
    text-style: bold;
    color: $text-muted;
    margin: 1 0;
    padding: 0 1;
}

/* Section Dividers */
.sidebar-section-divider {
    height: 1;
    margin: 2 0;
    border-top: solid $primary 30%;
    opacity: 50%;
}

/* Settings Groups with Enhanced Visibility */
.settings-group {
    padding-left: 1;
    margin: 1 0;
}

/* Improved contrast - from 5% to 15-20% */
.primary-group {
    background: $success 15%;
}

.secondary-group {
    background: $primary 15%;
}

.advanced-group {
    background: $warning 15%;
}

/* Enhanced setting groups with clear visual hierarchy */
.setting-group {
    margin: 2 0;
    padding: 1;
}

.setting-group-essential {
    border-left: solid $success;
    background: transparent;
}

.setting-group-common {
    border-left: solid $primary;
    background: transparent;
}

.setting-group-advanced {
    border-left: solid $warning;
    background: transparent;
}

/* Priority Indicators */
.priority-high > CollapsibleTitle {
    text-style: bold;
    border-left: thick $success;
    padding-left: 1;
}

/* Nested indentation */
.settings-group .settings-collapsible {
    margin-left: 1;
}

/* Fix for Collapsible widgets in sidebars */
.settings-collapsible {
    height: auto;
    min-height: 3;  /* Ensure title is visible */
}

.settings-collapsible CollapsibleTitle {
    height: auto;
    min-height: 1;
    padding: 0 1;
}

.settings-collapsible Contents {
    height: auto;
    padding: 1;
}

/* Ensure checkboxes and other controls are visible */
.settings-collapsible Checkbox {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
}

.settings-collapsible Input {
    height: auto;
    min-height: 3;
    margin: 0 0 1 0;
}

.settings-collapsible Select {
    height: auto;
    min-height: 3;
    margin: 0 0 1 0;
}

/* Sidebar Styling */
/* Generic .sidebar (used by #chat-left-sidebar and potentially others) */
.sidebar {
    dock: left;
    width: 25%; /* Reduced from 35% for better chat area space */
    min-width: 35; /* Reduced from 45 */
    max-width: 80; /* Maximum width (optional) */
    background: $boost;
    padding: 0 1;
    border-right: solid $surface;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
}
/* Collapsed state for the existing left sidebar */
.sidebar.collapsed {
    width: 0 !important;
    min-width: 0 !important; /* Ensure min-width is also 0 */
    border-right: none !important;
    padding: 0 !important;
    overflow: hidden !important;
    display: none; /* ensures it doesn't grab focus */
}

/* Right sidebar (chat-right-sidebar) */
#chat-right-sidebar {
    dock: right;
    width: 25%;  /* Default width, will be dynamically updated */
    min-width: 15%; /* Minimum width - absolute units work better */
    max-width: 50%; /* Maximum width */
    background: $boost;
    padding: 1 2;
    border-left: thick $background-darken-1; /* Border on the left */
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
}

/* Collapsed state for the new right sidebar */
#chat-right-sidebar.collapsed {
    width: 0 !important;
    min-width: 0 !important; /* Ensure min-width is also 0 */
    border-left: none !important;
    padding: 0 !important;
    overflow: hidden !important;
    display: none; /* Ensures it doesn't take space or grab focus */
}

/* Common sidebar elements */
.sidebar-title { text-style: bold; margin-bottom: 1; width: 100%; text-align: left; }

/* Sidebar header with resize controls */
.sidebar-header-with-resize {
    height: 2;
    align: left middle;
    margin-bottom: 1;
}

.sidebar-header-with-resize .flex-grow {
    width: 1fr;
}

/* Sidebar resize buttons */
.sidebar-resize-button {
    width: 8;
    min-width: 8;
    height: 3;
    padding: 0 1;
    margin: 0 1;
    text-align: center;
    background: $primary;
    color: $text;
    text-style: bold;
    border: tall $primary;
}

.sidebar-resize-button:hover {
    background: $surface-lighten-1;
    color: $text;
    text-style: bold;
}
.sidebar-label { margin-top: 1; text-style: bold; }
.sidebar-input {
    width: 100%;
    margin-bottom: 1;
    border: solid $primary-lighten-2;
    border-bottom: solid $primary-lighten-2;
}
.sidebar-textarea { 
    width: 100%; 
    height: 5;  /* Default height for text areas */
    border: round $surface; 
    margin-bottom: 1; 
}

/* Notes content header and expand button */
.notes-content-header {
    height: 2;
    align: left middle;
    margin-bottom: 0;
}

.notes-content-label {
    width: auto;
}

.notes-expand-button {
    width: auto;
    min-width: 12;
    height: 3;
    margin-left: 1;
    padding: 0 2;
    color: $text;
    background: $surface;
    text-style: bold;
    text-align: center;
}

/* Ensure button text is visible */
#chat-notes-expand-button {
    color: $text !important;
}

/* General sidebar button styling */
.sidebar-button {
    width: 100%;
    height: 3;
    margin: 1 0;
    padding: 0 2;
    text-align: center;
}

/* Notes textarea states */
.notes-textarea-normal {
    height: 10;
}

.notes-textarea-expanded {
    height: 25;
    border: round $accent;
}
.sidebar Select { 
    width: 100%; 
    margin-bottom: 1; 
    border: solid $primary-lighten-2;
    border-bottom: solid $primary-lighten-2;
}

.prompt-display-textarea {
    height: 7; /* Example height */
    border: round $primary-lighten-2;
    background: $primary-background;
}

.sidebar-listview {
    height: 10; /* Example height for listviews in sidebars */
    border: round $primary-lighten-2;
    background: $primary-background;
}

/* World Books specific styling */
.worldbook-association-controls {
    height: 3;
    align: center middle;
    margin: 1 0;
}

.worldbook-priority-select {
    width: 30%;
    min-width: 15;
    margin-left: 1;
}

#chat-worldbook-available-listview {
    height: 5;
    border: round $primary-lighten-2;
    background: $primary-background;
    margin-bottom: 1;
}

#chat-worldbook-active-listview {
    height: 5;
    border: round $accent;
    background: $primary-background;
    margin-bottom: 1;
}

#chat-worldbook-details-display {
    height: 8;
    border: round $secondary;
    background: $primary-background;
    /* font-size: 11; - not supported in TCSS */
}

/* Chat Dictionaries specific styling */
#chat-dictionary-available-listview {
    height: 5;
    border: round $primary-lighten-2;
    background: $primary-background;
    margin-bottom: 1;
}

#chat-dictionary-active-listview {
    height: 5;
    border: round $accent-lighten-1;
    background: $primary-background;
    margin-bottom: 1;
}

#chat-dictionary-details-display {
    height: 8;
    border: round $secondary-lighten-1;
    background: $primary-background;
}

/* Enhanced sidebar sections with UX improvements */
.sidebar-section-collapsible {
    margin-bottom: 1;
    border: round $surface-lighten-1;
    background: $surface;
}

.sidebar-section-collapsible:focus-within {
    border: round $ds-focus-accent;
    background: $ds-focus-bg;
}

/* Section loading state */
.section-loading {
    align: center middle;
    height: 3;
}

.loading-fade {
    opacity: 50%;
}

/* Search mode indicator */
.sidebar.search-active {
    border: solid $warning;
}

/* ----------------------------------------
 * Enhanced Sidebar Components
 * ---------------------------------------- */

/* Tab content styling */
.tab-content {
    padding: 1;
    height: 100%;
}

/* Setting labels and inputs with better spacing */
.setting-label {
    margin-top: 1;
    margin-bottom: 0;
    text-style: bold;
    color: $text-muted;
    text-align: left;
}

.setting-input {
    width: 100%;
    margin-bottom: 1;
    border: solid $primary-lighten-1;
    border-bottom: solid $primary-lighten-1;
}

/* Modified settings indicator */
.setting-modified {
    border: solid $accent !important;
    background: $accent 10% !important;
}

/* Temperature visual indicator */
.temperature-container {
    height: 3;
    align: left middle;
}

.temperature-input {
    width: 70%;
}

.temp-indicator {
    width: 30%;
    text-align: center;
    padding-left: 1;
}

/* System prompt styling */
.system-prompt-input {
    width: 100%;
    height: 8;
    border: round $surface;
    margin-bottom: 1;
    background: $background 5%;
}

/* New chat buttons */
.new-chat-buttons {
    height: 3;
    margin: 1 0;
    align: center middle;
}

.primary-button {
    width: 45%;
    margin: 0 1;
}

.secondary-button {
    width: 45%;
    margin: 0 1;
}

/* Info display fields */
.info-display {
    width: 100%;
    margin-bottom: 1;
    background: $surface 20%;
    color: $text-muted;
}

/* Checkbox styling */
.streaming-toggle, .advanced-toggle {
    margin: 1 0;
    padding: 0 1;
}

/* TabbedContent customization */
TabbedContent {
    height: auto;
}

TabbedContent > TabPane {
    padding: 0;
    height: auto;
}

TabbedContent Tabs {
    background: $surface 10%;
    height: 3;
}

TabbedContent Tab {
    padding: 0 1;
}

TabbedContent Tab.-active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Hide the tab underline indicator */
TabbedContent Underline {
    height: 0;
    display: none;
}

/* Search results styling */
.search-results {
    padding: 1;
}

.search-result-item {
    margin: 1 0;
    padding: 1;
    background: $surface 10%;
    border: round $surface-lighten-1;
}

.search-result-item:hover {
    background: $surface-lighten-1;
    color: $text;
    border: round $surface-lighten-2;
}

/* Highlight matched text in search */
.search-highlight {
    background: $warning 30%;
    text-style: bold;
}

/* Loading indicator for lazy tabs */
.tab-loading {
    align: center middle;
    height: 10;
}

.loading-spinner {
    color: $primary;
    text-style: bold;
}

/* Reset button styling */
.reset-button {
    width: auto;
    min-width: 3;
    height: 2;
    padding: 0 1;
    background: $warning 20%;
    border: tall $warning;
}

.reset-button:hover {
    background: $surface-lighten-1;
    color: $text;
}

/* Note: Textual doesn't support @media queries for responsive design
   These rules would need to be applied programmatically based on screen size */

/* --- End of Sidebar Styling --- */

/* ===== MODULE: layout/_panes.tcss ===== */
/* ========================================
 * LAYOUT: Panes
 * ======================================== 
 * Multi-pane layouts (2-pane, 3-pane, etc)
 * ======================================== */

.destination-workbench {
    height: 1fr;
    min-height: 0;
    width: 100%;
}

.destination-workbench-pane {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
    padding: 0 1;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
}

.destination-pane-title {
    height: 1;
    min-height: 1;
    text-style: bold;
    color: $ds-text-primary;
}

.destination-mode-strip,
.destination-filter-strip,
.destination-footer-row {
    height: 1;
    min-height: 1;
    padding: 0 1;
}

/* ===== MODULE: layout/_containers.tcss ===== */
/* ========================================
 * LAYOUT: Containers
 * ======================================== 
 * Section containers, subsections, and content areas
 * ======================================== */

/* TabbedContent height fixes */
#config-tabs {
    height: 100%;
    width: 100%;
}

#config-tabs TabPane {
    height: 100%;
    width: 100%;
    padding: 1;
}

/* Container for the HorizontalScroll, this takes the original #tabs styling for docking */
#tabs-outer-container {
    dock: top;
    height: 3; /* Or your desired tab bar height */
    background: $background; /* Or your tab bar background */
    padding: 0 1; /* Padding for the overall bar */
    width: 100%;
    margin-top: 1; /* Add buffer space above the tab bar */
}

/* The HorizontalScroll itself, which will contain the buttons */
#tabs {
    width: 100%;
    height: 100%; /* Fill the outer container's height */
    overflow-x: auto !important; /* Ensure horizontal scrolling is enabled */
    /* overflow-y: hidden; /* Usually not needed for a single row of tabs */
}

#tabs Button {
    width: auto;         /* Let button width be determined by content + padding */
    min-width: 10;       /* Minimum width to prevent squishing too much */
    height: 100%;        /* Fill the height of the scrollable area */
    border: none; /* Your existing style */
    background: $panel;  /* Your existing style */
    color: $text-muted;  /* Your existing style */
    padding: 0 2;        /* Add horizontal padding to buttons */
    margin: 0 1 0 0;     /* Small right margin between buttons */
}

#tabs Button:last-of-type { /* No margin for the last button */
    margin-right: 0;
}

#tabs Button:hover {
    background: $panel-lighten-1; /* Your existing style */
    color: $text;                 /* Your existing style */
}

/* ===== MODULE: components/_buttons.tcss ===== */
/* ========================================
 * COMPONENTS: Buttons
 * ======================================== 
 * All button variants and states
 * ======================================== */

/* Base button style with enhanced UX */
Button {
    /* No border by default - rely on background color for visual appearance */
    border: none;
}

/* Shared hover state with readable, non-obscuring cues */
Button:hover {
    background: $surface-lighten-1;
    color: $text;
    text-style: bold;
}

/* Enhanced focus state with visible, non-obscuring cues */
Button:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

/* When both hovering AND focused */
Button:hover:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

/* Disabled state */
Button:disabled {
    opacity: 50%;
    background: $surface-darken-1;
    color: $text-disabled;
}

Button:disabled:hover {
    background: $surface-darken-1;
    text-style: none;
}

/* microphone button – same box as Send but subdued colour */
.mic-button {
    width: 1;
    height: 3;
    margin-right: 1;           /* gap before Send */
    border: none;
    background: $surface-darken-1;
    color: $text-muted;
}
.mic-button:hover {
    background: $surface;
    color: $text;
}
.sidebar-toggle {
    width: 1fr;              /* Equal flexible width */
    height: 3;
    /* margin-right: 1; Removed default margin, apply specific below */
    border: none;
    background: $surface-darken-1;
    color: $text;
}
.sidebar-toggle:hover { background: $surface; }

/* Specific margins for sidebar toggles based on position */
#toggle-chat-left-sidebar {
    margin-right: 1; /* Original toggle on the left of input area */
}

#toggle-chat-right-sidebar {
    margin-left: 1; /* New toggle on the right of input area */
}

/* ===== MODULE: components/_forms.tcss ===== */
/* ========================================
 * COMPONENTS: Forms
 * ======================================== 
 * Form elements: inputs, textareas, selects
 * ======================================== */

.form-label {
    margin-bottom: 1;
    text-style: bold;
}

.form-section-title {
    text-style: bold;
    color: $secondary;
    margin: 2 0 1 0;
    border-bottom: solid $primary-background;
    padding-bottom: 1;
}

.form-description {
    color: $text-muted;
    margin-bottom: 2;
    text-style: italic;
}

.form-actions {
    margin-top: 2;
    layout: horizontal;
    height: auto;
    align: center middle;
}

.form-actions Button {
    margin: 0 1 0 0;
}

.provider-models-textarea {
    height: 5;
    margin-bottom: 1;
}

/* Standardized form components */
.form-input {
    width: 100%;
    margin-bottom: 1;
}

.form-textarea {
    width: 100%;
    height: auto;
    min-height: 5;
    margin-bottom: 1;
}


.form-checkbox {
    margin: 1 0;
}

/* Form layout helpers */
.form-row {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

.form-col {
    width: 1fr;
    padding: 0 1;
}

.form-col:first-child {
    padding-left: 0;
}

.form-col:last-child {
    padding-right: 0;
}

/* Form sections */
.form-section-collapsible {
    margin: 1 0;
}

/* Button groups */
.button-group {
    width: 100%;
    height: auto;
    margin: 2 0;
}

.button-group-left {
    align: left top;
}

.button-group-center {
    align: center top;
}

.button-group-right {
    align: right top;
}

.form-button {
    margin: 0 1;
}

/* Status areas */
.status-label {
    margin-top: 2;
    margin-bottom: 0;
    color: $text-muted;
}

.status-area {
    width: 100%;
    background: $surface;
    border: round $border;
    padding: 1;
    margin-top: 1;
}

/* Title/Author input fields fix */
.title-author-row Input {
    height: 3;
    width: 100%;
    margin-bottom: 1;
}

Input:focus,
TextArea:focus,
Select:focus {
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

ToggleButton:focus {
    border: solid $ds-focus-accent;
    background: $surface;
}

ToggleButton:focus > .toggle--label,
ToggleButton.-textual-compact:focus > .toggle--label,
ToggleButton:blur:hover > .toggle--label {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Switch:focus {
    border: solid $ds-focus-accent;
    background: $ds-focus-bg;
}

/* New base media ingestion form styling */
.form-input {
    height: 3;
    width: 100%;
    margin-bottom: 1;
    border: solid $primary;
    padding: 0 1;
}

.form-input:focus {
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

.form-input.error {
    border: solid $error;
    background: $error 10%;
}

.form-select {
    height: 3;
    width: 100%;
    margin-bottom: 1;
}

.form-checkbox {
    margin: 1 0;
}

.form-label-primary {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
    border-bottom: solid $primary;
    padding-bottom: 1;
}

/* Responsive metadata columns */
.metadata-row {
    layout: horizontal;
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

.metadata-col {
    width: 1fr;
    height: auto;
}

/* Mode toggle section - CRITICAL for visibility */
.mode-toggle-container {
    width: 100%;
    height: auto;
    margin-bottom: 1;
    padding: 1;
}

.mode-title {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
}

.mode-toggle {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

/* Essential container sections - CRITICAL for Input widget visibility */
.essential-section {
    width: 100%;
    height: auto;        /* Allow container to size to content */
    margin-bottom: 2;
    padding: 1;
}

.media-options-section {
    width: 100%;
    height: auto;
    margin-bottom: 2;
}

.options-section {
    width: 100%;
    height: auto;
    margin-bottom: 2;
    padding: 1;
}

.process-button-section {
    width: 100%;
    height: auto;
    margin-top: 2;
    padding: 1;
    align: center middle;
}

/* Time range inputs layout */
.time-range-row {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

.time-col {
    width: 1fr;
    height: auto;
    padding: 0 1;
}

.time-col:first-child {
    padding-left: 0;
}

.time-col:last-child {
    padding-right: 0;
}

/* Advanced mode visibility controls */
.advanced-only {
    display: block;
}

.simple-mode .advanced-only {
    display: none;
}

.advanced-mode .advanced-only {
    display: block;
}

/* Form textarea styling */
.form-textarea {
    width: 100%;
    min-height: 5;
    max-height: 10;
    margin-bottom: 1;
    border: solid $primary;
    padding: 1;
}

.form-textarea:focus {
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

/* Note: Textual doesn't support @media queries
   Responsive behavior must be handled programmatically
   in the Python code using terminal size detection */

/* ===== MODULE: components/_lists.tcss ===== */
/* ========================================
 * COMPONENTS: Lists
 * ======================================== 
 * ListViews, list items, and list patterns
 * ======================================== */

ListView ListItem {
    padding: 0 1;
    height: auto;
}

ListView ListItem:hover {
    background: $surface-lighten-1;
    color: $text;
}

ListView ListItem.-highlight {
    background: $surface;
    color: $text;
    text-style: bold underline;
}

DataTable > .datatable--cursor {
    background: $surface;
    color: $text;
    text-style: bold underline;
}

DataTable > .datatable--hover {
    background: $surface-lighten-1;
    color: $text;
}

DataTable > .datatable--selected {
    background: $surface;
    color: $text;
    text-style: bold underline;
}

OptionList > .option-list--option-highlighted,
OptionList:focus > .option-list--option-highlighted,
SelectionList > .selection-list--button-highlighted,
SelectionList > .selection-list--button-selected,
SelectionList > .selection-list--button-selected-highlighted,
Tree > .tree--cursor,
Tree:focus > .tree--cursor {
    background: $surface;
    color: $text;
    text-style: bold underline;
}

OptionList > .option-list--option-hover,
Tree > .tree--highlight-line {
    background: $surface-lighten-1;
    color: $text;
}

/* ===== MODULE: components/_navigation.tcss ===== */
/* ========================================
 * COMPONENTS: Navigation
 * ======================================== 
 * Navigation patterns and menus
 * ======================================== */

/* ===== MODULE: components/_messages.tcss ===== */
/* ========================================
 * COMPONENTS: Messages
 * ======================================== 
 * Message display components
 * ======================================== */

ChatMessage {
    width: 100%;
    height: auto;
    max-height: 50vh;  /* Limit message height to 50% of viewport */
    margin-bottom: 1;
    overflow-y: auto;  /* Allow scrolling within long messages */
}
ChatMessage > Vertical {
    border: round $surface;
    background: $panel;
    padding: 0 1;
    width: 100%;
    height: auto;
}
ChatMessage.-user > Vertical {
    background: $boost; /* Different background for user */
    border: round $accent;
}
ChatMessage.-tool-call > Vertical {
    background: $surface-lighten-1;
    border: round $warning;
}
ChatMessage.-tool-result > Vertical {
    background: $surface-lighten-1;
    border: round $success;
}
.message-header {
    width: 100%;
    padding: 0 1;
    background: $surface-darken-1;
    text-style: bold;
    height: 1; /* Ensure header is minimal height */
}
.message-text {
    padding: 1; /* Padding around the text itself */
    width: 100%;
    height: auto;
    max-height: 40vh;  /* Limit text area to 40% of viewport */
    overflow-y: auto;  /* Allow scrolling within long text */
}

.message-text.tts-generating {
    opacity: 0.8;
    border-left: thick $accent;
}
.message-actions {
    height: auto;
    width: 100%;
    padding: 1; /* Add padding around buttons */
    /* Use a VALID border type */
    border-top: solid $surface-lighten-1; /* CHANGED thin to solid */
    align: right middle; /* Align buttons to the right */
    display: block; /* Default display state */
}
.message-actions Button {
    min-width: 8;
    height: 1;
    margin: 0 0 0 1; /* Space between buttons */
    border: none;
    background: $surface-lighten-2;
    color: $text-muted;
}
.message-actions Button:hover {
    background: $surface;
    color: $text;
}
.message-actions Button:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}
.message-actions Button:focus:hover {
    background: $ds-surface-raised;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}
/* Initially hide AI actions until generation is complete */
ChatMessage.-ai .message-actions.-generating {
    display: none;
}

/* ===== MODULE: components/_dialogs.tcss ===== */
/* ========================================
 * COMPONENTS: Dialogs
 * ======================================== 
 * Modal dialogs and popup styles
 * ======================================== */

/* ===== MODULE: components/_status.tcss ===== */
/* ========================================
 * COMPONENTS: Status
 * ======================================== 
 * Status indicators and displays
 * ======================================== */

/* ===== MODULE: components/_agentic_terminal.tcss ===== */
/* ========================================
 * COMPONENTS: Agentic Terminal Design System
 * ========================================
 * Shared shell primitives for Home, Console, destination wrappers, status,
 * recovery, source authority, approvals, events, forms, toolbars, and shortcuts.
 *
 * Semantic token contract:
 * ds-surface-panel, ds-text-primary, ds-action-focus,
 * ds-status-ready, ds-status-running, ds-status-warning, ds-status-error,
 * ds-status-paused, ds-status-blocked, ds-status-approval-required,
 * ds-authority-local, ds-authority-server, ds-authority-workspace,
 * ds-source-role-context, ds-source-role-evidence,
 * ds-source-role-editable-target, ds-source-role-output-seed.
 *
 * Required readable status labels:
 * Ready, Running, Paused, Blocked, Unavailable, Approval required, Unsaved, Recovered.
 * ======================================== */

.ds-destination-header {
    height: auto;
    min-height: 3;
    padding: 1 2;
    margin: 0 0 1 0;
    border: tall $ds-action-focus;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.ds-panel {
    height: auto;
    min-height: 3;
    padding: 1 2;
    margin: 0 0 1 0;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.ds-inspector {
    height: auto;
    min-width: 24;
    padding: 1;
    border: round $ds-grid-line;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.ds-status-badge {
    width: auto;
    height: 1;
    padding: 0 1;
    text-style: bold;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.ds-recovery-callout {
    height: auto;
    padding: 1 2;
    border: round $ds-status-warning;
    background: $ds-status-warning 10%;
    color: $ds-text-primary;
}

.ds-source-role {
    width: auto;
    height: 1;
    padding: 0 1;
    border: round $ds-source-role-context;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.ds-approval-card {
    height: auto;
    padding: 1 2;
    border: thick $ds-status-approval-required;
    background: $ds-status-approval-required 12%;
    color: $ds-text-primary;
}

.ds-event-row {
    height: auto;
    min-height: 1;
    padding: 0 1;
    border-bottom: solid $ds-grid-line;
    color: $ds-text-primary;
}

/* Field rows are label-above-value: every current user (Personas card and
   editors) composes them as Vertical containers, so the row must not force a
   horizontal layout (it jammed "Name"+value side by side and squeezed Inputs
   into the leftover width). */
.ds-field-row {
    height: auto;
    min-height: 2;
    padding: 0 1;
}

.ds-toolbar {
    height: auto;
    min-height: 1;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

ConsoleSettingsModal {
    align: center middle;
}

#console-settings-modal {
    width: 92;
    max-width: 95%;
    height: 90%;
    max-height: 95%;
    overflow: hidden;
    scrollbar-size: 1 1;
    border: round $ds-grid-line;
    background: $ds-surface-panel;
    padding: 1 2;
}

#console-settings-body {
    height: 1fr;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

.console-settings-modal-section {
    height: auto;
    margin: 1 0 0 0;
}

.console-settings-primary-section {
    padding: 0 1;
    border: round $ds-action-focus;
    background: $ds-surface-raised;
}

.console-settings-modal-row {
    height: auto;
    min-height: 1;
}

.console-settings-modal-label {
    width: 16;
    min-width: 16;
    max-width: 16;
    height: 1;
    min-height: 1;
    content-align: left middle;
}

.console-settings-control {
    width: 1fr;
    min-width: 0;
}

ConsoleSettingsModal Input {
    width: 1fr;
    min-width: 0;
    height: 3;
    min-height: 3;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

ConsoleSettingsModal Checkbox {
    height: 1;
    min-height: 1;
}

ConsoleSettingsModal Select > SelectCurrent {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    content-align: left middle;
}

ConsoleSettingsModal Select > SelectCurrent Static#label {
    width: 1fr;
    height: 1;
    background: transparent;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select > SelectCurrent .arrow {
    background: transparent;
    color: $ds-text-muted;
}

ConsoleSettingsModal Input:focus {
    height: 3;
    min-height: 3;
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

ConsoleSettingsModal Input > .input--cursor {
    background: $ds-input-focus-accent;
    color: $ds-surface-panel;
}

ConsoleSettingsModal Input > .input--selection {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
}

ConsoleSettingsModal Select:focus {
    border: none;
    border-bottom: none;
    outline: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select:focus > SelectCurrent {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

ConsoleSettingsModal Select > SelectOverlay {
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    min-width: 30;
}

ConsoleSettingsModal Select > SelectOverlay Option {
    padding: 0 2;
    min-height: 3;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select > SelectOverlay Option:hover {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

ConsoleSettingsModal Select > SelectOverlay Option.-selected {
    padding: 0 2;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-settings-modal-actions {
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    align-horizontal: right;
}

#console-settings-cancel,
#console-settings-save {
    width: 12;
    min-width: 12;
    height: 1;
    min-height: 1;
}

.console-settings-error {
    height: auto;
    min-height: 1;
    max-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-status-error 10%;
    color: $ds-text-primary;
}

#home-dashboard,
#console-shell,
#library-shell,
#notes-shell,
#artifacts-shell,
#personas-shell,
#watchlists-collections-shell,
#schedules-shell,
#mcp-shell,
#acp-shell,
#skills-shell,
#settings-shell {
    height: 100%;
    min-height: 0;
}

#home-title,
#console-title,
#library-title,
#notes-title,
#artifacts-title,
#personas-title,
#watchlists-collections-title,
#schedules-title,
#workflows-title,
#mcp-title,
#acp-title,
#skills-title,
#settings-title {
    height: $ds-destination-header-height;
    min-height: $ds-destination-header-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#home-purpose,
#console-purpose,
#library-purpose,
#artifacts-purpose,
#mcp-purpose,
#console-status-row,
#library-status-row,
#notes-mode-strip,
#console-mode-bar,
#artifacts-mode-strip,
#personas-mode-strip,
#watchlists-filter-strip,
#schedules-filter-strip,
#workflows-mode-strip,
#mcp-mode-strip,
#acp-purpose,
#acp-mode-strip,
#skills-mode-strip,
#settings-category-strip {
    height: $ds-destination-compact-strip-height;
    min-height: $ds-destination-compact-strip-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

.destination-action-button {
    height: 1;
    min-height: 1;
    padding: 0 1;
}

.home-dashboard-region,
.library-region,
#artifacts-list-pane,
#artifacts-detail-pane,
#artifacts-inspector-pane,
#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#mcp-server-tree-pane,
#mcp-detail-pane,
#mcp-readiness-pane,
#acp-list-pane,
#acp-detail-pane,
#acp-inspector-pane,
#skills-list-pane,
#skills-detail-pane,
#skills-inspector-pane,
#settings-category-pane,
#settings-detail-pane,
#settings-impact-pane,
#ccp-character-library-pane,
#ccp-behavior-detail-pane,
#ccp-attachment-inspector-pane {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

/* Console's runtime frame (_frame_console_region) is the single border
   source for .console-region; no CSS border here to avoid a doubled frame. */
.console-region {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
    padding: 1;
    background: $ds-surface-panel;
}

#settings-category-pane {
    width: 3fr;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#settings-detail-pane {
    width: 6fr;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#settings-impact-pane {
    width: 2fr;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#home-triage-grid {
    padding: 0 1;
    margin: 0;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#home-header-line {
    height: $ds-home-compact-row-height;
    min-height: $ds-home-compact-row-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#home-rail,
#home-canvas {
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

.home-rail-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.home-rail-row-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.home-rail-section-body {
    height: auto;
    min-height: 0;
}

.home-rail-empty-copy {
    color: $ds-text-muted;
    padding: 0 1;
}

#home-next-action-callout {
    color: $ds-text-muted;
    padding: 0 1;
}

.destination-pane-divider {
    width: 1;
    min-width: 1;
    height: 100%;
    min-height: 0;
    background: $ds-grid-line;
}

#home-canvas-actions .ds-toolbar {
    height: auto;
    min-height: $ds-home-control-button-height;
    padding: 0 1;
    margin: 0;
    border: none;
    background: $ds-surface-panel;
}

.home-canvas-action {
    height: $ds-home-control-button-height;
    min-height: $ds-home-control-button-height;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    border: none;
}

#library-shell-grid {
    padding: 0 1;
    margin: 0;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#library-header-line {
    height: $ds-home-compact-row-height;
    min-height: $ds-home-compact-row-height;
    padding: 0 1;
    margin: 0;
    border: none;
}

#library-rail {
    border: solid $ds-column-line;
    background: $ds-surface-panel;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#library-canvas {
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

.library-rail-empty-copy {
    color: $ds-text-muted;
    padding: 0 1;
}

.library-details-group {
    text-style: bold;
    color: $ds-text-primary;
    margin: 1 0 0 0;
    padding: 0 1;
}

.library-details-group-first {
    margin: 0;
}

.library-details-row {
    padding: 0 1;
}

.library-rail-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.library-rail-row-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Flashcards-due emphasis on the create-flashcards rail row. Bright mirrors
   .console-action-primary's accent treatment (there is due work); dim uses
   the muted text color already used for rail hints elsewhere in this file
   (e.g. #library-notes-sync-status) so a zero-due state reads as quiet. */
.library-rail-row-due-bright {
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

.library-rail-row-due-dim {
    color: $ds-text-muted;
    text-style: none;
}

.library-conversation-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.library-conversation-row-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.library-media-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.library-media-row-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.library-notes-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

/* Same look as .library-notes-row, on a separate class: the notes Create
   view's Blank note / template rows must not also match the list view's
   ".library-notes-row" press handler (opening the editor for the pressed
   row's note_id), which would double-dispatch alongside the Create view's
   own handlers on every press. */
.library-notes-create-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

/* "From a template" group label: separates the primary Blank note action
   from the template rows (same top-rule section grammar as the media
   viewer's Content/Analysis/Highlights headers). */
#library-notes-template-section {
    width: 100%;
    text-style: bold;
    color: $ds-text-primary;
    border-top: solid $ds-grid-line;
    padding: 1 0 0 0;
    margin: 1 0 1 0;
}

.library-canvas-action {
    height: $ds-home-control-button-height;
    min-height: $ds-home-control-button-height;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    border: none;
}

#library-search-input {
    margin: 0 0 1 0;
}

#library-conversations-filter {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-notes-header {
    width: 100%;
    min-width: 0;
    height: auto;
    content-align: left middle;
}

#library-notes-filter {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-notes-filter:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-notes-status {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

#library-notes-empty {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

#library-notes-create-header {
    width: 100%;
    min-width: 0;
    height: auto;
    content-align: left middle;
}

/* Note editor: title/keywords Inputs match the filter box's field look
   (tall border, focus accent) rather than defaulting to Textual's bare
   Input styling. */
#library-note-title,
#library-note-keywords {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-note-title:focus,
#library-note-keywords:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

/* Bounded editor: a bare TextArea in this scrolling canvas defaults to
   height:1fr, which would balloon to fill available space and crowd out
   the keywords/meta/action row beneath it. height:auto with a floor and a
   generous ceiling keeps short notes compact while long notes scroll
   inside the field itself instead of pushing the rest of the editor off
   screen. */
#library-note-body {
    height: auto;
    min-height: 12;
    max-height: 20;
    margin: 0 0 1 0;
}

/* The read-only Markdown preview takes the TextArea's place one-for-one
   when Preview is toggled on, so it gets the same bounded footprint (plus
   its own scroll region, since Markdown has no implicit one here). */
#library-note-preview-body {
    height: auto;
    min-height: 12;
    max-height: 20;
    margin: 0 0 1 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    overflow-y: auto;
}

/* Muted meta line: same tier as the media viewer's metadata block
   (#library-media-viewer-meta) so both editors read consistently. */
#library-note-meta {
    width: 100%;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

#library-note-conflict-copy,
#library-note-delete-confirm-copy {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

/* Notes sync panel: section header matches the create view's group-label
   grammar; the folder Input matches the filter box's field look; status/
   activity are muted like the note editor's meta line. */
#library-notes-sync-header {
    width: 100%;
    text-style: bold;
    color: $ds-text-primary;
    margin: 0 0 1 0;
}

/* Purpose line: one-line explainer directly under the header, dim like the
   note editor's meta line. */
#library-notes-sync-purpose {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

/* Dim lowercase label above the folder Input, same muted tier as the
   activity log directly below it. */
#library-notes-sync-folder-label {
    width: 100%;
    height: auto;
    color: $ds-text-muted;
}

#library-notes-sync-folder {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-notes-sync-folder:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

/* Starts the direction/conflict/auto-sync settings group right after
   Browse…, visually separating "where" (folder) from "how" (options). */
#library-notes-sync-direction {
    margin-top: 1;
}

/* Separates the primary action from the settings group above it. Accent
   treatment mirrors .console-action-primary (the project's live "primary
   action button" convention) so Sync now reads as the one button that
   matters on this panel. */
#library-notes-sync-run {
    margin-top: 1;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

#library-notes-sync-status {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 1 0 0 0;
    color: $ds-text-muted;
}

/* Failed status gets the same error color already used elsewhere in this
   file (e.g. Button.notes-delete-action) -- status is the headline, so a
   failure must read as unambiguously bad. */
#library-notes-sync-status.library-notes-sync-status-failed {
    color: $ds-status-error;
}

/* Activity is the log, status is the headline -- one muted tier dimmer
   than #library-notes-sync-status so the hierarchy is visible even though
   both are "muted" text. */
#library-notes-sync-activity {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-disabled;
}

#library-media-title {
    width: 100%;
    min-width: 0;
    height: auto;
    content-align: left middle;
}

#library-media-type-filter {
    width: auto;
    min-width: 0;
    margin: 0 0 1 0;
}

/* Title: brightest + bold so it anchors the viewer; metadata recedes (muted)
   so the two read as distinct tiers instead of one wall of text. */
#library-media-viewer-title {
    width: 100%;
    text-style: bold;
    color: $ds-text-primary;
    margin: 0 0 1 0;
}

#library-media-viewer-meta {
    width: 100%;
    color: $ds-text-muted;
    margin: 0 0 1 0;
}

/* Section headers: bold + a thin top rule so Content / Analysis / Highlights
   read as real section boundaries the eye can find without reading. */
#library-media-viewer-content-title,
#library-media-viewer-analysis-title,
#library-media-viewer-highlights-title {
    width: 100%;
    text-style: bold;
    color: $ds-text-primary;
    border-top: solid $ds-grid-line;
    padding: 1 0 0 0;
    margin: 1 0 1 0;
}

#library-media-content-search {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-media-content-search:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-media-content-search-status {
    width: 100%;
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

#library-media-viewer {
    height: 100%;
    overflow-y: auto;
    /* Never scroll horizontally: without this the vertical scroll container
       sizes its content to the widest child's natural width, so a long
       unbroken line (analysis summary, URL) sets a wide virtual width and
       width:100% children match it instead of wrapping. Constrain to the
       visible width so long lines wrap. */
    overflow-x: hidden;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

/* Text bodies default to width:auto (shrink-to-content); fill the width so
   long lines wrap within the (now horizontally-constrained) viewer. */
#library-media-viewer Static {
    width: 100%;
}

#library-media-viewer-content {
    /* Bounded so short content stays compact and long content scrolls inside
       this region; height:1fr here ballooned the pane and split the sections.
       max-height is generous so typical content shows in full (only long
       transcripts engage the inner scroll), reducing nested-scroll friction. */
    height: auto;
    max-height: 18;
    min-height: 3;
    margin: 0 0 1 0;
    border: solid $ds-grid-line;
    padding: 0 1;
}

#library-media-edit-form {
    height: auto;
    margin: 0 0 1 0;
}

/* Persistent per-field label: muted, bold, hugging its input above the row. */
.library-media-edit-label {
    width: 100%;
    height: 1;
    color: $ds-text-muted;
    text-style: bold;
    margin: 0;
}

/* Destructive Delete: pushed off the primary actions (a gap) and de-emphasized
   so it is neither adjacent to Edit nor visually competing with it. */
.library-media-action-danger {
    margin: 0 0 0 4;
    color: $ds-text-muted;
}

/* Each highlight is an indented card so its quote, meta, and delete read as
   one unit -- a per-row delete then clearly belongs to a single highlight. */
.library-media-highlight-row {
    width: 100%;
    height: auto;
    border-left: solid $ds-grid-line;
    padding: 0 0 0 1;
    margin: 0 0 1 0;
}

.library-media-highlight-meta {
    width: 100%;
    color: $ds-text-muted;
}

.library-media-highlight-delete {
    color: $ds-text-muted;
}

#library-media-edit-form Input {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-media-edit-form Input:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-media-highlight-add-collapsible {
    height: auto;
    margin: 0 0 1 0;
}

#library-media-highlight-add-collapsible Input {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-media-highlight-add-collapsible Input:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#console-workspace-grid {
    height: $ds-console-workspace-grid-height;
    min-height: 20;
    padding: 0 1;
    margin: 0;
    overflow: hidden;
    border-top: solid $ds-grid-line;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#console-workbench-header {
    display: none;
    height: 0;
    min-height: 0;
    max-height: 0;
    padding: 0;
    margin: 0;
    border: none;
}

#console-workbench-header #workbench-header-subtitle,
#console-workbench-header #workbench-header-status {
    display: none;
    height: 0;
    min-height: 0;
    max-height: 0;
}

#console-workbench-mode-strip,
#console-workbench-command-strip {
    display: none;
    height: 0;
    min-height: 0;
    max-height: 0;
    padding: 0;
    margin: 0;
    border: none;
}

#console-control-bar {
    height: $ds-console-control-bar-height;
    min-height: $ds-console-control-bar-height;
    max-height: $ds-console-control-bar-height;
    padding: 0 1;
    margin: 0;
    border: none;
    background: $ds-surface-panel;
    overflow: hidden;
}

.console-control-chip-row,
.console-control-action-row {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    max-height: 1;
    layout: horizontal;
    align: left middle;
}

.console-control-chip {
    width: auto;
    min-width: 7;
    max-width: 22;
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-overflow: ellipsis;
    text-wrap: nowrap;
}

.console-chip-dim {
    color: $ds-text-muted;
}

.console-chip-alert {
    color: $ds-text-primary;
    text-style: bold;
}

.console-control-action {
    width: auto;
    min-width: 7;
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
    padding: 0 1;
    border: none;
    background: transparent;
    color: $ds-text-primary;
    content-align: left middle;
}

.console-control-action:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-control-summary-line {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
}

.console-hidden-control {
    display: none;
}

#console-staged-context-tray,
#console-workspace-context,
#console-run-inspector {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 0;
}

#console-main-column,
#console-right-rail {
    width: 1fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
}

#console-staged-context-tray,
#console-workspace-context {
    width: 100%;
    min-width: 0;
}

#console-staged-context-tray {
    height: auto;
    min-height: 3;
    max-height: 6;
}

#console-workspace-context {
    height: auto;
    min-height: 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

#console-workspace-handoff-rows {
    height: auto;
    min-height: 0;
}

#console-workspace-conversations-header {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    layout: horizontal;
    align: left middle;
}

.console-workspace-action.console-workspace-conversations-toggle {
    width: 3;
    min-width: 3;
    max-width: 3;
    margin: 0;
}

#console-workspace-selected-conversation {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    color: $ds-text-muted;
    background: $ds-surface-panel;
}

#console-workspace-conversation-search-row {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    layout: horizontal;
    align: left middle;
}

#console-workspace-conversation-search {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
}

#console-workspace-conversation-search-clear {
    width: auto;
    min-width: 7;
    height: 1;
    min-height: 1;
    margin: 0;
}

#console-workspace-conversations {
    width: 100%;
    min-width: 0;
    height: auto;
    min-height: 0;
    overflow-y: hidden;
    overflow-x: hidden;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.console-workspace-conversation-row {
    height: auto;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.console-workspace-conversation-row-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-conversation-browser-section-header {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    layout: horizontal;
    align: left middle;
}

.console-conversation-browser-section-title {
    width: 1fr;
    min-width: 0;
}

.console-conversation-browser-group-header {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    layout: horizontal;
    align: left middle;
}

.console-conversation-browser-group-title {
    width: 1fr;
    min-width: 0;
    color: $ds-text-muted;
}

.console-conversation-browser-row-line {
    width: 100%;
    min-width: 0;
    layout: horizontal;
}

.console-conversation-star {
    width: 3;
    min-width: 3;
    max-width: 3;
    height: 2;
    min-height: 2;
    margin: 0 1 1 0;
}

#console-left-rail {
    height: 100%;
    min-height: 0;
    overflow: hidden;
}

#console-left-rail:focus {
    outline: none;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#console-left-rail-body {
    width: 100%;
    min-width: 0;
    height: 1fr;
    min-height: 0;
    padding: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#console-left-rail-body:focus {
    outline: none;
    border: none;
    background: $ds-surface-panel;
}

#console-workspace-context:focus {
    outline: none;
    border: none;
    background: $ds-surface-panel;
}

#console-workspace-conversations:focus {
    outline: none;
    border: none;
    background: $ds-surface-panel;
}

.console-left-rail-section {
    margin: 0 0 1 0;
    padding: 0 1;
}

#console-inspector-rail-body {
    width: 100%;
    min-width: 0;
    height: 1fr;
    min-height: 0;
    padding: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#console-main-column {
    width: 13fr;
    min-width: 60;
    padding: 0;
}

#console-right-rail {
    width: 4fr;
    min-width: 34;
    overflow: hidden;
}

#console-staged-context-tray,
#console-workspace-context,
#console-right-rail,
#console-run-inspector,
#console-transcript-region {
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#console-staged-context-tray.console-frame-quiet,
#console-workspace-context.console-frame-quiet {
    border: none;
    background: $ds-surface-panel;
}

#console-run-inspector {
    width: 100%;
    min-width: 0;
    height: auto;
    min-height: 0;
    border: none;
}

#console-run-inspector-state {
    height: auto;
    min-height: 0;
}

.console-rail-handle {
    width: 13;
    min-width: 13;
    max-width: 13;
    height: 100%;
    min-height: 20;
    padding: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

.console-rail-handle-right {
    width: 11;
    min-width: 11;
    max-width: 11;
    height: auto;
    min-height: 3;
    max-height: 6;
    border: none;
    background: transparent;
}

.console-rail-handle-button {
    width: 11;
    min-width: 0;
    max-width: 11;
    height: 100%;
    min-height: 100%;
    max-height: 100%;
    text-align: center;
    content-align: center middle;
}

.console-rail-handle-button-right {
    width: 11;
    max-width: 11;
    height: 3;
    min-height: 3;
    max-height: 3;
}

.console-rail-collapse-button {
    width: 3;
    min-width: 3;
    max-width: 3;
    height: 1;
    min-height: 1;
    text-align: left;
    content-align: left middle;
}

.console-rail-handle-badge {
    height: auto;
    min-height: 1;
    width: 100%;
    text-align: center;
    color: $ds-text-primary;
    background: $ds-surface-raised;
}

.console-rail-header {
    height: 1;
    min-height: 1;
    layout: horizontal;
}

.console-rail-title {
    width: 1fr;
    min-width: 0;
    text-align: left;
    content-align: left middle;
}

.console-rail-section-header {
    height: 1;
    margin-top: 1;
}

.console-rail-section-title {
    width: 1fr;
    text-style: bold;
}

.console-rail-section-toggle {
    width: 3;
    min-width: 3;
}

.console-rail-section-body {
    height: auto;
    min-height: 0;
}

.console-model-section-line {
    height: 1;
    color: $ds-text-muted;
}

.console-inspector-group-heading {
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-inspector-status-summary {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-inspector-action {
    height: 1;
    min-height: 1;
    margin: 0;
}

.console-inspector-disabled-reason {
    height: 0;
    min-height: 0;
}

.console-live-work-source-readiness {
    height: auto;
    min-height: 0;
    margin: 1 0 0 0;
}

.console-live-work-source-row {
    height: auto;
    min-height: 1;
}

.console-settings-summary {
    height: auto;
    min-height: 9;
    padding: 0 1;
}

.console-left-rail-section.console-settings-summary {
    margin: 0 0 1 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-panel;
}

.console-inspector-session-settings {
    margin: 1 0 0 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-panel;
}

.console-settings-header {
    height: 1;
    min-height: 1;
    layout: horizontal;
    align: left middle;
}

.console-settings-title {
    width: 1fr;
    min-width: 0;
    height: 1;
    min-height: 1;
    max-height: 1;
}

.console-settings-row {
    height: 1;
    min-height: 1;
    max-height: 1;
    overflow: hidden hidden;
    text-wrap: nowrap;
    text-overflow: ellipsis;
}

#console-settings-open {
    width: auto;
    min-width: 9;
    max-width: 14;
    height: 1;
    min-height: 1;
    margin: 0;
}

#console-transcript-region,
#console-session-surface {
    height: 1fr;
    min-height: 0;
}

#console-session-surface {
    padding: 0;
    margin: 0;
    border: none;
}

#console-transcript-region {
    padding: 0 1;
    border: round $ds-column-line;
    background: $ds-surface-panel;
}

.console-start-here,
.console-action-hints {
    height: auto;
    min-height: 1;
    padding: 0 1;
}

.console-start-here {
    margin: 0;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

#console-start-here,
#console-action-hints {
    display: none;
    height: 0;
    min-height: 0;
    max-height: 0;
    padding: 0;
    margin: 0;
}

.console-action-hints {
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

#console-native-composer {
    height: auto;
    min-height: $ds-console-composer-height;
    max-height: 8;
    padding: 1;
    margin: 0;
    layout: horizontal;
    align: left middle;
    border: round $ds-column-line;
    background: $ds-surface-panel;
}

#console-native-composer.console-composer-has-draft {
    border: round $ds-status-ready;
}

#console-native-composer.console-composer-focused {
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
}

#console-native-composer.console-composer-setup-blocked #console-command-visible-text {
    color: $ds-status-warning;
}

#console-composer-title,
#console-composer-status,
.console-composer-recovery,
.console-send-disabled-reason,
.console-control-label {
    height: 1;
    min-height: 1;
}

#console-composer-title {
    width: 10;
    min-width: 10;
}

#console-command-visible-text {
    width: 1fr;
    min-width: 0;
    height: auto;
    min-height: 1;
    max-height: 4;
    margin: 0 1 0 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    overflow: hidden;
}

#console-native-composer.console-composer-has-draft #console-command-visible-text,
#console-native-composer:focus-within #console-command-visible-text,
#console-command-visible-text:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-composer-actions {
    width: 37;
    min-width: 37;
    max-width: 37;
    height: 1;
    min-height: 1;
    layout: horizontal;
    align: right middle;
}

.console-composer-recovery {
    width: 0;
    min-width: 0;
    max-width: 0;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-status-warning;
    text-style: bold;
    text-overflow: ellipsis;
    text-wrap: nowrap;
}

.console-send-disabled-reason {
    width: 0;
    min-width: 0;
    max-width: 0;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-status-warning;
    text-style: bold;
    text-overflow: ellipsis;
    text-wrap: nowrap;
}

#console-command-input {
    display: none;
    width: 0;
    min-width: 0;
    height: 0;
    min-height: 0;
}

#console-composer-status {
    width: auto;
    min-width: 0;
}

#console-session-surface .chat-input-area {
    display: none;
}

.console-transcript-system-event {
    height: auto;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    border-left: solid $ds-status-warning;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#console-chat-tabs,
#console-chat-tabs #chat-sessions-container,
#console-chat-tabs .chat-session {
    height: 100%;
    min-height: 0;
}

#console-transcript-surface {
    height: 1fr;
    min-height: 0;
    layers: console-background console-content;
}

#console-transcript-background-effect {
    layer: console-background;
    width: 100%;
    height: 100%;
    color: $ds-text-muted;
    background: transparent;
}

#console-native-transcript {
    height: 1fr;
    min-height: 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
    scrollbar-size: 1 1;
}

#console-transcript-surface #console-native-transcript {
    layer: console-content;
    height: 1fr;
    min-height: 0;
    background: transparent;
}

#console-transcript-title,
.console-transcript-title {
    height: 1;
    min-height: 1;
    max-height: 1;
    margin: 0;
    background: $ds-surface-panel;
    color: $ds-text-muted;
    text-style: none;
}

#console-native-tab-strip,
.console-session-tab-strip {
    height: 1;
    min-height: 1;
    max-height: 1;
    margin: 0;
    margin-bottom: 1;
    background: $ds-surface-panel;
}

.console-session-tab,
#console-new-chat-tab {
    width: auto;
    min-width: 8;
    height: 1;
    min-height: 1;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-session-close-button {
    padding: 0;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.console-session-tab-active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-session-tab-active:hover,
.console-session-tab-active:hover:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

#console-native-transcript:focus {
    border: solid $ds-focus-accent;
    border-bottom: solid $ds-focus-accent;
}

.console-transcript-rule {
    height: 1;
    min-height: 1;
    color: $ds-column-line;
}

.console-transcript-message {
    height: auto;
    min-height: 1;
    padding: 0 1;
    margin: 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.console-transcript-message-selected {
    min-height: 2;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.console-transcript-action-row {
    height: 3;
    min-height: 3;
    margin: 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-transcript-action-guide {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    color: $ds-text-muted;
}

.console-modal-header {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-transcript-action-button {
    width: auto;
    min-width: 5;
    height: 3;
    min-height: 3;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-transcript-action-button:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

.console-workspace-selector-row {
    margin: 0 0 1 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.console-workspace-status-pair {
    height: auto;
    min-height: 1;
    margin: 0;
}

.console-workspace-status-label {
    color: $ds-text-muted;
    text-style: bold;
}

.console-workspace-status-value {
    color: $ds-text-primary;
}

.console-workspace-action {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
}

#console-transcript-empty-state,
.console-transcript-empty-panel {
    height: 100%;
    min-height: 100%;
    width: 100%;
    layout: vertical;
    padding: 1 2;
    background: transparent;
    color: $ds-text-primary;
}

#console-shell .workbench-recovery-callout,
#console-control-bar,
#console-workspace-grid,
#console-transcript-region,
#console-native-composer {
    opacity: 100%;
}

.console-transcript-empty-body {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0;
    color: $ds-text-muted;
}

.console-setup-step {
    height: 1;
    color: $ds-text-primary;
}

.console-setup-step-done {
    color: $ds-text-muted;
}

.console-setup-step-active {
    text-style: bold;
}

.console-setup-step-pending {
    color: $ds-text-muted;
}

/* First-run blocking setup modal: a Console-scoped overlay layer painted over
 * the whole Console shell (rail + transcript + composer) while setup is
 * incomplete. The app tab bar lives outside the shell and stays reachable. */
#console-shell {
    layers: console-workbench console-setup-overlay;
}

#console-setup-modal {
    layer: console-setup-overlay;
    display: none;
    width: 100%;
    height: 100%;
    align: center middle;
    /* $background is a distinctly darker token than the Console shell's own
     * $ds-surface-panel background, so this alpha fill actually blends to a
     * dimmed shade (verified: ~#191d21 vs the shell's flat #242f38) instead
     * of a same-color no-op like the previous $ds-surface-panel 80% fill. */
    background: $background 60%;
    layers: console-setup-snow console-setup-card;
}

.console-setup-modal-backdrop-snow {
    layer: console-setup-snow;
    width: 100%;
    height: 100%;
    color: $ds-text-muted;
}

.console-setup-modal-card {
    layer: console-setup-card;
    width: 62;
    max-width: 90%;
    height: auto;
    padding: 1 2;
    layout: vertical;
    border: solid #6f7782;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.console-setup-modal-title {
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0;
    color: $ds-text-primary;
    text-style: bold;
}

.console-setup-modal-action {
    width: auto;
    min-width: 12;
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    border: none;
    background: $ds-focus-bg;
    color: $ds-text-primary;
    content-align: left middle;
}

.console-setup-modal-action:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

#console-chat-tabs {
    display: none;
}

#console-session-surface .chat-empty-state {
    min-height: 5;
    padding: 0 1;
    text-align: left;
    content-align: left top;
    border-bottom: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#console-session-surface .chat-log {
    padding: 0 1;
    background: $ds-surface-panel;
    border: tall $ds-grid-line;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
    scrollbar-size: 1 1;
}

#console-send-message,
#console-stop-generation {
    width: 8;
    min-width: 8;
}

#console-send-message,
#console-stop-generation,
#console-attach-context,
#console-save-chatbook {
    height: 1;
    min-height: 1;
}

#console-attach-context {
    width: 10;
    min-width: 10;
}

#console-save-chatbook {
    width: 8;
    min-width: 8;
}

.console-action-primary {
    border: none;
    height: 1;
    min-height: 1;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

.console-action-secondary {
    border: none;
    height: 1;
    min-height: 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.console-action-subdued {
    border: none;
    height: 1;
    min-height: 1;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: none;
}

.console-action-disabled {
    border: none;
    height: 1;
    min-height: 1;
    background: $ds-surface-panel;
    color: $ds-text-disabled;
    text-style: none;
}

.console-action-disabled:hover,
.console-action-disabled:focus,
.console-action-disabled:hover:focus {
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-disabled;
    text-style: none;
    outline: none;
}

#console-stop-generation.console-stop-active {
    border: none;
    background: $ds-status-warning 20%;
    color: $ds-text-primary;
    text-style: bold;
}

#console-save-chatbook.console-save-chatbook-ready {
    color: $ds-text-primary;
}

.console-control-label,
.console-staged-context-row,
.console-staged-context-summary,
.console-staged-context-recovery {
    width: auto;
    min-width: 0;
    height: auto;
}

.console-compact-model-bar {
    width: auto;
    min-width: 0;
}


#notes-status-row {
    width: 1fr;
    min-width: 0;
    height: $ds-destination-compact-strip-height;
    min-height: $ds-destination-compact-strip-height;
    text-align: right;
    color: $ds-text-muted;
}

Button.notes-mode-chip {
    width: auto;
    min-width: $ds-library-mode-chip-min-width;
    height: $ds-library-mode-chip-height;
    min-height: $ds-library-mode-chip-height;
    padding: 0 1;
    border: none;
}

.notes-mode-chip:focus {
    outline: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

#artifacts-workbench,
#personas-workbench,
#watchlists-workbench,
#schedules-workbench,
#workflows-workbench,
#mcp-workbench,
#acp-workbench,
#skills-workbench,
#settings-workbench {
    height: 1fr;
    min-height: 20;
    padding: 1;
    margin: 0;
    overflow: hidden;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

/* Notes mode regions hold framed panes (Console rail framing), so the
   regions themselves stay chrome-free like Console's main area. */
#notes-mode-region-notes,
#notes-mode-region-sync,
#notes-mode-region-templates {
    height: 1fr;
    min-height: 20;
    padding: 0;
    margin: 0;
    overflow: hidden;
    border: none;
    background: transparent;
}

#artifacts-list-pane,
#artifacts-detail-pane,
#artifacts-inspector-pane,
#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#mcp-server-tree-pane,
#mcp-detail-pane,
#mcp-readiness-pane,
#acp-list-pane,
#acp-detail-pane {
    margin: 0 1 0 0;
}

#artifacts-inspector-pane,
#personas-inspector-pane,
#watchlists-inspector-pane,
#schedules-inspector-pane,
#workflows-inspector-pane,
#mcp-readiness-pane,
#acp-inspector-pane {
    margin: 0;
}

#personas-list-pane,
#personas-detail-pane,
#personas-inspector-pane,
#watchlists-list-pane,
#watchlists-detail-pane,
#watchlists-inspector-pane,
#schedules-list-pane,
#schedules-detail-pane,
#schedules-inspector-pane,
#workflows-list-pane,
#workflows-detail-pane,
#workflows-inspector-pane,
#acp-list-pane,
#acp-detail-pane,
#acp-inspector-pane {
    height: 100%;
    min-height: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#personas-inspector-pane {
    width: 2fr;
    min-width: 30;
    border: solid $ds-grid-line;
    padding: 1;
}

#personas-readiness-console {
    width: 100%;
    min-width: 0;
    height: auto;
    text-wrap: wrap;
}

/* Workbench column split (2:4:2). Required here because the generic
   .destination-workbench-pane width (1fr) outranks the screen's DEFAULT_CSS,
   which would squeeze the work area to a third of its intended width. */
#personas-library-pane {
    width: 2fr;
    min-width: 24;
}

#personas-work-area {
    width: 4fr;
    min-width: 40;
}

#personas-workbench.personas-workbench-compact {
    padding: 0;
}

#personas-library-pane.personas-workbench-compact-pane {
    width: 1fr;
    min-width: 16;
    padding: 0 1;
}

#personas-work-area.personas-workbench-compact-pane {
    width: 3fr;
    min-width: 34;
    padding: 0 1;
}

#personas-inspector-pane.personas-workbench-compact-pane {
    width: 1fr;
    min-width: 22;
    padding: 0 1;
}

#schedules-list-pane,
#workflows-list-pane,
#acp-list-pane {
    width: 2fr;
    min-width: 30;
    border: solid $ds-grid-line;
    padding: 1;
}

#schedules-detail-pane,
#workflows-detail-pane,
#acp-detail-pane {
    width: 4fr;
    min-width: 52;
    border: solid $ds-grid-line;
    padding: 1;
}

#schedules-inspector-pane,
#workflows-inspector-pane,
#acp-inspector-pane {
    width: 2fr;
    min-width: 34;
    border: solid $ds-grid-line;
    padding: 1;
}

.acp-selected-session-row {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
    padding: 0 1;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.acp-inspector-group-title {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

#personas-list-detail-divider,
#personas-detail-inspector-divider,
#watchlists-list-detail-divider,
#watchlists-detail-inspector-divider,
#schedules-list-detail-divider,
#schedules-detail-inspector-divider,
#workflows-list-detail-divider,
#workflows-detail-inspector-divider,
#acp-list-detail-divider,
#acp-detail-inspector-divider {
    background: $ds-grid-line;
}

.artifacts-column-title,
.personas-column-title,
.watchlists-column-title,
.schedules-column-title,
.workflows-column-title,
.acp-column-title,
.skills-column-title,
.ccp-column-title,
.settings-column-title {
    width: 100%;
    height: 1;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-active-section {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button {
    width: 100%;
    height: 1;
    min-height: 1;
    max-height: 1;
    margin: 0;
    padding: 0 1;
    content-align: left middle;
    text-align: left;
    background: $ds-surface-panel;
}

Button.settings-category-button.settings-active-section {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button:focus {
    outline: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

Button.settings-category-button.settings-active-section:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button.settings-active-section:hover,
Button.settings-category-button.settings-active-section:hover:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

Button.settings-category-button.settings-primary-search-match {
    color: $ds-text-primary;
    text-style: bold;
}

Button.settings-category-button.settings-secondary-search-match {
    color: $ds-text-muted;
}

#settings-category-search {
    width: 100%;
    height: 3;
    min-height: 3;
    max-height: 3;
    margin: 0 0 1 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

#settings-category-search:focus {
    border: solid $ds-action-focus;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
    outline: none;
}

#settings-category-search.settings-category-search-active {
    border: solid $ds-action-focus;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.settings-category-search-help {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    color: $ds-text-muted;
}

.settings-category-search-status {
    width: 100%;
    min-height: 2;
    padding: 0 1;
    margin: 0 0 1 0;
    color: $ds-text-primary;
    background: $ds-surface-panel;
}

.settings-search-empty {
    width: 100%;
    min-height: 3;
    padding: 1;
    margin: 1 0 0 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-muted;
}

#settings-shell Button:focus,
#settings-shell Button:hover:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold underline;
    outline: none;
}

.settings-category-group-title {
    width: 100%;
    height: 1;
    min-height: 1;
    padding: 0 1;
    margin: 1 0 0 0;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-state-banner {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-detail-row {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.settings-input-row {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 0 0 1 0;
}

.settings-select-row {
    width: 100%;
    height: 3;
    min-height: 3;
    margin: 0 0 1 0;
}

.settings-input-label {
    width: 12;
    min-width: 12;
    height: 1;
    min-height: 1;
    padding: 0;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-select-row .settings-input-label {
    height: 3;
    min-height: 3;
    content-align: left middle;
}

.settings-compact-input {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.settings-compact-input:focus {
    border: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold underline;
    outline: none;
}

.settings-compact-input.settings-invalid-input,
.settings-compact-select.settings-invalid-input {
    background: $ds-status-error 18%;
    color: $ds-text-primary;
    text-style: bold;
    outline: none;
}

.settings-compact-input.settings-invalid-input:focus,
.settings-compact-select.settings-invalid-input:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-opacity: 1;
    text-style: bold;
    outline: none;
}

.settings-compact-select {
    width: 1fr;
    height: 3;
    min-height: 3;
    margin: 0;
    padding: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.settings-compact-select > SelectCurrent {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
    content-align: left middle;
}

.settings-compact-select:focus {
    border: solid $ds-action-focus;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
    outline: none;
}

.settings-compact-select:focus > SelectCurrent {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

.settings-compact-select > SelectOverlay {
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
    min-width: 30;
}

.settings-compact-select > SelectOverlay Option {
    padding: 0 2;
    min-height: 3;
    background: $ds-surface-inspector;
    color: $ds-text-primary;
}

.settings-compact-select > SelectOverlay Option:hover {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

.settings-compact-select > SelectOverlay Option.-selected {
    padding: 0 2;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.settings-provider-manual-hidden {
    display: none;
}

.settings-status-row {
    width: 100%;
    min-height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
    background: $ds-surface-inspector;
    color: $ds-text-muted;
}

.settings-storage-check-result {
    min-height: 7;
}

.settings-category-status-hidden {
    display: none;
}

.settings-dirty-category {
    color: $ds-status-unsaved;
    text-style: bold;
}

.settings-focus-card {
    width: 100%;
    height: auto;
    min-height: 10;
    padding: 1;
    margin: 0 0 1 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#settings-advanced-config-card {
    height: 1fr;
    min-height: 0;
}

.settings-secondary-card {
    width: 100%;
    height: auto;
    min-height: 6;
    padding: 1;
    margin: 0 0 1 0;
    border: solid $ds-column-line;
    background: $ds-surface-panel;
}

#settings-console-behavior-card {
    min-height: 12;
}

.settings-action-row {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 1 0;
}

.settings-action-row Button {
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
}

.settings-action-row Button:focus,
#settings-impact-pane Button:focus {
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold underline;
    outline: none;
}

.settings-sync-safety-row {
    width: 100%;
    padding: 0 1;
    background: $ds-surface-raised;
}

.settings-advanced-safety-status {
    background: $ds-status-unsaved 10%;
    color: $ds-status-unsaved;
    text-style: bold;
}

#settings-advanced-config-editor {
    height: 1fr;
    min-height: 10;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#library-source-browser {
    width: $ds-library-source-browser-width;
    min-width: $ds-library-source-browser-width;
    max-width: $ds-library-source-browser-width;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    overflow-y: auto;
}

.library-hub-spacer {
    height: 1;
    min-height: 1;
}

/* Notes form controls mirror the Console settings control language exactly:
   quiet tall-bordered inputs, single-row flattened selects, accent focus. */
#notes-shell Input {
    height: 3;
    min-height: 3;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#notes-shell Input:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#notes-shell Input > .input--cursor {
    background: $ds-input-focus-accent;
    color: $ds-surface-panel;
}

#notes-shell Select {
    height: 1;
    min-height: 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#notes-shell Select > SelectCurrent {
    width: 1fr;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    border: none;
    background: $ds-surface-raised;
    color: $ds-text-primary;
    content-align: left middle;
}

#notes-shell Select > SelectCurrent Static#label {
    width: 1fr;
    height: 1;
    background: transparent;
    color: $ds-text-primary;
}

#notes-shell Select > SelectCurrent .arrow {
    background: transparent;
    color: $ds-text-muted;
}

#notes-shell Select:focus {
    border: none;
    border-bottom: none;
    outline: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

#notes-shell TextArea {
    border: tall $ds-surface-panel;
    background: $ds-surface-panel;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#notes-shell TextArea:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
}

/* The keywords editor reads as a form control, not an editor surface. */
#notes-shell TextArea.notes-keywords-textarea {
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
}


#notes-shell ListView {
    border: none;
    background: $ds-surface-panel;
    padding: 0;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

Button.notes-delete-action {
    color: $ds-status-error;
}

/* Docked Notes action bar mirrors the Console composer chrome. */
#notes-action-bar {
    height: 3;
    min-height: 3;
    max-height: 3;
    padding: 0 1;
    margin: 0;
    border: round #6f7782;
    background: $ds-surface-panel;
    align: left middle;
}

.notes-action-bar-group {
    width: 100%;
    min-width: 0;
    height: 1;
    min-height: 1;
    align: left middle;
}

.notes-action-bar-spacer {
    width: 1fr;
    min-width: 0;
    height: 1;
}

.notes-action-bar-group Button {
    height: 1;
    min-height: 1;
    margin-left: 1;
}

/* Sync mode: framed setup form + Console-transcript-style activity log. */
#notes-sync-pane {
    height: 1fr;
    min-height: 0;
    padding: 0;
    border: none;
    background: transparent;
}

#notes-sync-setup {
    width: 44;
    min-width: 30;
    height: 100%;
    padding: 0 1;
    margin: 0 1 0 0;
    border: solid #6f7782;
    background: $ds-surface-panel;
}

#notes-sync-activity {
    width: 1fr;
    min-width: 0;
    height: 100%;
    padding: 0 1;
    border: solid #6f7782;
    background: $ds-surface-panel;
}

.notes-sync-field-label {
    height: 1;
    min-height: 1;
    margin-top: 1;
    color: $ds-text-muted;
    text-style: bold;
}

.notes-sync-auto-label {
    width: auto;
    height: 1;
    min-height: 1;
    color: $ds-text-muted;
    text-style: bold;
}

#notes-sync-activity-log {
    height: 1fr;
    min-height: 0;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

.notes-sync-activity-line {
    height: auto;
    min-height: 1;
    color: $ds-text-muted;
}

.notes-sync-activity-line.activity-success {
    color: $ds-status-ready;
}

.notes-sync-activity-line.activity-error {
    color: $ds-status-error;
}

/* Templates mode: framed list beside a framed full-height preview. */
#notes-templates-pane {
    height: 1fr;
    min-height: 0;
    padding: 0;
    border: none;
    background: transparent;
}

#notes-templates-list-pane {
    width: 36;
    min-width: 24;
    height: 100%;
    padding: 0 1;
    margin: 0 1 0 0;
    border: solid #6f7782;
    background: $ds-surface-panel;
}

#notes-template-preview-pane {
    width: 1fr;
    min-width: 0;
    height: 100%;
    padding: 0 1;
    border: solid #6f7782;
    background: $ds-surface-panel;
}

#notes-template-preview-scroll {
    height: 1fr;
    min-height: 0;
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

/* Navigator scope lists stay dense and top-aligned like Console rails. */
#notes-navigator-pane ListView {
    height: auto;
    min-height: 1;
    max-height: 10;
}

/* Sort row: the global `Select { width: 100%; }` rule would otherwise
   inflate the select and push the order toggle out of the row. */
#notes-sort-row {
    height: 1;
    min-height: 1;
    margin-bottom: 1;
    align: left middle;
}

#notes-sort-row > Static {
    width: 6;
    min-width: 6;
    color: $ds-text-muted;
}

#notes-sort-row Select {
    width: 1fr;
    min-width: 0;
    margin: 0;
}

#notes-sort-row Button {
    margin-left: 1;
}


#library-source-inspector {
    width: 2fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    overflow-y: auto;
}

/* Console's rendered frame color (#6f7782) — see chat_screen.CONSOLE_FRAME_COLOR. */
#notes-navigator-pane,
#notes-inspector-pane {
    width: 2fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid #6f7782;
    background: $ds-surface-panel;
    overflow-y: auto;
}

#notes-navigator-pane,
#notes-inspector-pane {
    scrollbar-size: 1 1;
    scrollbar-background: $ds-surface-panel;
    scrollbar-color: $ds-grid-line;
    scrollbar-color-hover: $ds-grid-line;
    scrollbar-color-active: $ds-action-focus;
}

#library-source-detail {
    width: 5fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    overflow-y: auto;
}

#notes-editor-pane {
    width: 5fr;
    min-width: 0;
    height: 100%;
    min-height: 20;
    padding: 1;
    border: solid #6f7782;
    background: $ds-surface-panel;
    overflow-y: auto;
}

#notes-editor-pane {
    overflow-y: hidden;
}

.ds-shortcut-bar {
    dock: bottom;
    height: 1;
    padding: 0 1;
    background: $ds-surface-inspector;
    color: $ds-text-muted;
}

.density-compact .ds-panel,
.density-compact .ds-inspector,
.density-compact .ds-approval-card,
.density-compact .ds-recovery-callout {
    padding: 0 1;
    margin: 0 0 1 0;
}

.density-compact .ds-destination-header {
    min-height: 2;
    padding: 0 1;
}

.density-comfortable .ds-panel,
.density-comfortable .ds-inspector,
.density-comfortable .ds-approval-card,
.density-comfortable .ds-recovery-callout {
    padding: 1 2;
    margin: 1 1;
}

.density-comfortable .ds-destination-header {
    min-height: 4;
    padding: 1 2;
}

.is-active {
    border: round $ds-action-focus;
    text-style: bold;
}

.library-mode-chip.is-active,
.notes-mode-chip.is-active,
.personas-mode-chip.is-active {
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.library-mode-chip.is-active:focus,
.notes-mode-chip.is-active:focus,
.personas-mode-chip.is-active:focus {
    outline: none;
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Keyboard-browse cursor: visually distinct from the flat subdued bg.
   $ds-grid-line (#26364D) is lighter than $ds-surface-raised/#ds-focus-bg
   (#142033) so browsed rows are visible without special-casing focus state.
   Place BEFORE the .is-active rules so equal-specificity cascade gives
   .is-active the final word. */
ListItem.personas-library-row.-highlight,
ListItem.personas-conversation-row.-highlight {
    background: $ds-grid-line;
    color: $ds-text-primary;
    text-style: bold;
}

/* Selected/active row: wins because it appears later in the sheet. */
ListItem.personas-library-row.is-active {
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
}

/* Active row that is also the browse cursor: .is-active styling wins
   (later in sheet, same specificity as the -highlight rule above). */
ListItem.personas-library-row.is-active.-highlight {
    outline: none;
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
}

.library-source-action {
    width: $ds-library-source-action-width;
    min-width: $ds-library-source-action-min-width;
    height: $ds-library-source-action-height;
    min-height: $ds-library-source-action-height;
    margin: 0;
    padding: 0 1;
    border: none;
    background: transparent;
    color: $ds-text-primary;
    content-align: left middle;
    text-style: none;
}

.library-source-action-spacer {
    height: 0;
    min-height: 0;
}

.library-source-active-marker {
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
}

.library-source-group-rule {
    height: 1;
    min-height: 1;
    margin: 0;
    color: $ds-text-muted;
}

.library-source-action:focus {
    border: none;
    background: transparent;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

.library-source-action.is-active,
.library-source-action.is-active:focus {
    border: none;
    background: transparent;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

#library-collection-form Input {
    height: 3;
    min-height: 3;
    padding: 0 1;
    border: tall $ds-grid-line;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

#library-collection-form Input:focus {
    border: tall $ds-input-focus-accent;
    outline: none;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    text-style: bold;
}

#library-collection-actions {
    height: 1;
    min-height: 1;
    margin-top: 1;
    align: left middle;
}

#library-collection-actions Button {
    height: 1;
    min-height: 1;
    margin-right: 1;
    padding: 0 1;
    border: none;
    background: transparent;
    color: $ds-text-primary;
    content-align: left middle;
    text-style: none;
}

#library-collection-actions Button:focus {
    border: none;
    background: transparent;
    color: $ds-focus-fg;
    outline: none;
    text-style: bold underline;
}

.library-rag-region {
    width: 100%;
    min-width: 0;
    margin: 0 0 1 0;
}

#library-rag-query-controls {
    height: 14;
    min-height: 14;
}

#library-rag-query-controls.has-recovery {
    height: 17;
    min-height: 17;
}

#library-rag-source-scope {
    height: 13;
    min-height: 13;
}

#library-rag-source-scope.has-recovery {
    height: 16;
    min-height: 16;
}

#library-rag-query-row {
    width: 100%;
    height: 3;
    min-height: 3;
}

#library-rag-results {
    height: 1fr;
    min-height: 8;
}

#library-rag-query-input {
    width: 1fr;
    min-width: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-raised;
}

#library-rag-query-input:focus {
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
}

#library-rag-scope-summary {
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.library-rag-section-rule {
    color: $ds-text-muted;
    text-style: bold;
}

.library-rag-callout {
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.library-rag-callout.is-blocked {
    border: solid $ds-status-warning;
    background: $ds-status-warning 10%;
}

.library-rag-callout.is-ready {
    border: solid $ds-status-ready;
    background: $ds-status-ready 10%;
}

.library-rag-disabled-reason {
    color: $ds-text-muted;
}

.library-rag-table-header,
.library-rag-scope-row {
    padding: 0 1;
}

.library-rag-table-header {
    background: $ds-surface-raised;
    color: $ds-text-primary;
    text-style: bold;
}

.library-rag-empty-guidance {
    margin: 1 0 0 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

#library-rag-run-query {
    width: 18;
    min-width: 16;
    margin: 0 0 0 1;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

#library-rag-run-query:disabled {
    background: $ds-surface-raised;
    color: $ds-text-disabled;
    text-style: none;
}

.library-rag-result-row {
    padding: 0 1;
    margin: 1 0 0 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

.library-rag-result-row.is-selected {
    border: heavy $ds-focus-accent;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
}

.library-rag-result-badges {
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: bold;
}

.library-rag-recovery-action {
    width: 28;
    min-width: 18;
    background: $ds-status-warning 30%;
    color: $ds-text-primary;
    text-style: bold;
}

.library-rag-console-action {
    width: 18;
    min-width: 16;
    background: $ds-action-focus 35%;
    color: $ds-text-primary;
    text-style: bold;
}

.library-rag-center-console-action {
    width: 24;
    min-width: 18;
    margin: 1 0 0 0;
}

.library-rag-console-action:disabled {
    background: $ds-surface-raised;
    color: $ds-text-disabled;
    text-style: none;
}

#library-rag-mode-toggle {
    width: auto;
    min-width: 20;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

#library-rag-mode-toggle:hover {
    background: $ds-action-focus 20%;
}

#library-rag-searching-line {
    padding: 0 1;
    background: $ds-surface-raised;
    color: $ds-text-muted;
    text-style: italic;
}

#library-rag-history {
    margin: 1 0 0 0;
}

.library-rag-history-row {
    width: 100%;
    min-width: 0;
    height: 2;
    min-height: 2;
    margin: 0 0 1 0;
    padding: 0 1;
    text-align: left;
    content-align: left middle;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    border: none;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.library-rag-history-row:hover {
    background: $ds-action-focus 20%;
}

.library-rag-history-empty {
    color: $ds-text-muted;
    padding: 0 1;
}

.is-disabled {
    opacity: 0.55;
}

.is-blocked {
    border: round $ds-status-error;
    background: $ds-status-error 10%;
}

.is-running {
    border: round $ds-status-running;
}

.is-paused {
    border: round $ds-status-paused;
}

.is-unsaved {
    border: round $ds-status-unsaved;
}

.is-stale {
    color: $ds-text-muted;
}

.is-conflict {
    border: thick $ds-status-error;
}

.needs-approval {
    border: thick $ds-status-approval-required;
    background: $ds-status-approval-required 12%;
}

.source-local {
    border: round $ds-authority-local;
}

.source-server {
    border: round $ds-authority-server;
}

.source-workspace {
    border: round $ds-authority-workspace;
}

.source-remote-only {
    border: round $ds-authority-remote-only;
}

.source-dry-run {
    border: dashed $ds-grid-line;
    color: $ds-text-muted;
}

/* ===== MODULE: components/_workbench.tcss ===== */
/* ========================================
 * COMPONENTS: Workbench
 * ========================================
 * Shared destination workbench frame, command, mode, recovery, pane,
 * state, and density contracts.
 * ======================================== */

.workbench-frame {
    width: 100%;
    height: 100%;
    min-height: 0;
    layout: vertical;
    overflow: hidden;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.workbench-header {
    height: auto;
    min-height: 2;
    padding: 0 1;
    margin: 0;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
    color: $ds-text-primary;
}

.workbench-header-title {
    height: 1;
    min-height: 1;
    text-style: bold;
}

.workbench-header-subtitle {
    height: 1;
    min-height: 1;
    color: $ds-text-muted;
}

.workbench-header.has-empty-subtitle .workbench-header-subtitle {
    display: none;
}

.workbench-header-status {
    width: auto;
    height: 1;
    min-height: 1;
}

.workbench-command-strip,
.workbench-mode-strip {
    height: 1;
    min-height: 1;
    padding: 0 1;
    margin: 0;
    layout: horizontal;
    background: $ds-surface-raised;
    color: $ds-text-primary;
}

.workbench-action,
.workbench-mode {
    width: auto;
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
}

.workbench-action {
    padding: 0 1;
}

.workbench-action.is-primary {
    text-style: bold;
}

.workbench-action.is-disabled {
    color: $ds-text-disabled;
}

.workbench-mode {
    padding: 0 1;
    color: $ds-text-muted;
}

.workbench-mode.is-active {
    border: none;
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold;
}

.workbench-recovery-callout {
    height: auto;
    min-height: 0;
    padding: 0 1;
    margin: 0;
    border: solid $ds-status-warning;
    background: $ds-status-warning 10%;
    color: $ds-text-primary;
}

.workbench-recovery-callout.is-hidden {
    display: none;
}

.workbench-recovery-title {
    height: 1;
    min-height: 1;
    text-style: bold;
}

.workbench-recovery-body {
    height: auto;
    min-height: 1;
    color: $ds-text-primary;
}

.workbench-recovery-action {
    width: auto;
    height: 1;
    min-height: 1;
    margin: 1 0 0 0;
}

.workbench-pane-region {
    height: 1fr;
    min-height: 0;
    layout: horizontal;
    overflow: hidden;
}

.workbench-pane {
    width: 1fr;
    height: 1fr;
    min-width: 0;
    min-height: 0;
    padding: 0 1;
    border: solid $ds-grid-line;
    background: $ds-surface-panel;
}

.workbench-pane.is-collapsed {
    width: 3;
    min-width: 3;
}

.workbench-pane-title,
.workbench-pane-status {
    height: 1;
    min-height: 1;
}

.workbench-pane-title {
    text-style: bold;
}

.workbench-state-block {
    height: 1;
    min-height: 1;
    padding: 0 1;
    layout: horizontal;
    background: $ds-surface-raised;
    color: $ds-text-muted;
}

.workbench-state-route,
.workbench-state-density {
    width: auto;
    height: 1;
    min-height: 1;
    margin: 0 1 0 0;
}

.workbench-frame .status-ready {
    border-title-color: $ds-status-ready;
}

.workbench-frame .status-running,
.workbench-frame .status-loading {
    border-title-color: $ds-status-running;
}

.workbench-frame .status-blocked,
.workbench-frame .status-error {
    border-title-color: $ds-status-error;
}

.workbench-frame .status-paused,
.workbench-frame .status-empty {
    border-title-color: $ds-status-warning;
}

.density-normal .workbench-header {
    min-height: 2;
    padding: 0 1;
}

.density-normal .workbench-pane {
    padding: 1;
}

.density-compact .workbench-header {
    min-height: 1;
    padding: 0 1;
}

.density-compact .workbench-header-subtitle {
    display: none;
}

.density-compact .workbench-pane {
    padding: 0 1;
}

/* ===== MODULE: components/_widgets.tcss ===== */
/* ========================================
 * COMPONENTS: Widgets
 * ======================================== 
 * Miscellaneous reusable widgets
 * ======================================== */

#app-titlebar {
    dock: top;
    height: 1;                 /* single line */
    background: $panel;        /* Use panel background color */
    color: $text;
    text-align: center;
    text-style: bold;
    padding: 0 1;
}

/* Collapsible widget styling with enhanced UX */
Collapsible {
    height: auto;
    min-height: 3;
    margin: 0 0 1 0;
    border: round $surface-lighten-1;
    background: $surface;
}

Collapsible > .collapsible--header {
    height: 2;
    min-height: 2;
    padding: 0 1;
    background: $surface-lighten-1;
    color: $text;
}

Collapsible > .collapsible--header:hover {
    background: $surface;
    color: $text;
}

Collapsible > .collapsible--header:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    border-bottom: solid $ds-focus-accent;
    outline: none;
}

Collapsible.-collapsed > .collapsible--header {
    border-bottom: none;
}

Collapsible.-collapsed > .collapsible--header:focus {
    border-bottom: solid $ds-focus-accent;
}

Collapsible > .collapsible--header {
    border-bottom: solid $border;
}

Collapsible > Contents {
    height: auto;
    padding: 1;
    background: $surface;
}

/* Half height for RAG Settings collapsible header */
#chat-rag-panel > .collapsible--header,
#character-rag-panel > .collapsible--header {
    height: 1;
    min-height: 1;
}

/* Fix for settings collapsibles in sidebars */
.settings-collapsible {
    height: auto !important;
    min-height: 3 !important;
}

.settings-collapsible > Contents {
    height: auto !important;
    padding: 1;
}

/* Ensure controls inside collapsibles are visible */
.settings-collapsible Checkbox {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
}

.settings-collapsible Toggle {
    height: auto;
    min-height: 1;
    margin: 0 0 1 0;
}

.chat-system-prompt-styling {
    width: 100%;
    height: auto;
    min-height: 3;
    max-height: 10; /* Limit height */
    border: round $surface;
    margin-bottom: 1;
}

/* --- Window Footer Widget --- */

AppFooterStatus {
    dock: bottom;
    height: 1;  /* Single row height */
    background: $primary-background-darken-1;
    width: 100%;
    layout: horizontal;
    padding: 0 1;
    /* Removed align: right middle; from parent, will control children individually */
}

#footer-key-palette {
    width: auto;
    padding: 0 1; /* Padding around each key binding */
    color: $text-muted;
    dock: left; /* Dock key bindings to the left */
    visibility: visible;
    display: initial;
}

#footer-key-quit {
    width: auto;
    height: 1;
    padding: 0 1; /* Padding around each key binding */
    color: $text-muted;
    dock: left; /* Dock key bindings to the left */
}

#footer-spacer {
    width: 1fr; /* Takes up remaining space in the middle */
    height: 1;
}

#footer-word-count {
    width: auto;
    height: 1;
    padding: 0 1;
    color: $text-muted;
    display: block;
}

#footer-token-count {
    width: auto;
    height: 1;
    padding: 0 1;
    color: $text-muted;
    display: block;
}

#internal-db-size-indicator { /* This is for the DB sizes */
    width: auto;
    height: 1;
    /* content-align: right; Textual doesn't have content-align for Static directly */
    /* dock: right; Docking within Horizontal might be tricky, align on parent is better */
    color: $text-muted;
    dock: right; /* Dock DB sizes to the right */
    padding: 0 1; /* Add padding to the right of DB sizes as well */
    margin-left: 2; /* Add buffer before DB status */
}
/* --- End of Window Footer Widget --- */

/* --- Loading States --- */
.loading-state-container {
    width: 100%;
    height: auto;
    min-height: 10;
}

.loading-view {
    align: center middle;
    padding: 2;
}

.loading-text {
    margin-top: 1;
    color: $text-muted;
}

.error-view {
    align: center middle;
    padding: 2;
    background: $error 10%;
    border: round $error;
}

.error-icon {
    color: $error;
    text-style: bold;
}

.error-message {
    margin: 1 0;
    color: $error;
    text-align: center;
}

.error-actions {
    margin-top: 1;
    align: center middle;
}

.error-actions Button {
    margin: 0 1;
}

/* Skeleton loader styles */
.skeleton-container {
    width: 100%;
    padding: 1;
}

.skeleton-avatar {
    width: 8;
    height: 4;
    background: $surface-lighten-2;
    border: round $surface-lighten-2;
}

.skeleton-title {
    width: 60%;
    height: 1;
    background: $surface-lighten-2;
    margin-bottom: 1;
}

.skeleton-subtitle {
    width: 40%;
    height: 1;
    background: $surface-lighten-1;
}

.skeleton-line {
    height: 1;
    background: $surface-lighten-1;
    margin-bottom: 1;
}

.skeleton-line-full {
    width: 100%;
}

.skeleton-line-90 {
    width: 90%;
}

.skeleton-line-80 {
    width: 80%;
}

.skeleton-line-70 {
    width: 70%;
}

/* Skeleton loader visual indication */
.skeleton-line,
.skeleton-avatar,
.skeleton-title,
.skeleton-subtitle {
    opacity: 70%;
}

/* Inline loader states */
InlineLoader.loading {
    color: $primary;
}

InlineLoader.success {
    color: $success;
}

InlineLoader.error {
    color: $error;
}

/* --- End of Loading States --- */

/* ===== MODULE: components/stats_screen.css ===== */
/* Statistics Screen Styling */

/* Main container */
#stats-container {
    background: $surface;
    height: 100%;
    width: 100%;
    padding: 1;
}

/* Header */
.stats-header {
    text-align: center;
    text-style: bold;
    background: $primary-background-lighten-2;
    color: $text;
    padding: 1 2;
    margin-bottom: 1;
    border: solid $primary;
}

/* Scrollable content */
#stats-scroll {
    height: 100%;
    background: $surface;
}

#stats-content {
    padding: 0 2;
}

/* Section headers */
.section-header {
    text-style: bold;
    color: $primary;
    margin-top: 2;
    margin-bottom: 1;
    padding-left: 1;
    border-left: thick $primary;
}

.subsection-header {
    color: $text-muted;
    margin: 1 0;
    padding-left: 2;
}

/* Grid layouts */
.stats-grid {
    layout: grid;
    grid-size: 2 2;
    grid-gutter: 1 1;
    margin-bottom: 1;
}

.stats-grid.overview-grid {
    grid-size: 2 2;
}

.stats-grid.activity-grid {
    grid-size: 2 2;
}

.stats-grid.prefs-grid {
    grid-size: 2 2;
}

.stats-grid.ranges-grid {
    grid-size: 2 2;
}

.stats-grid.fun-grid {
    grid-size: 2 2;
}

/* Stat Card Component */
StatCard {
    background: $panel;
    border: solid $border;
    height: auto;
    min-height: 6;
    padding: 1;
}

StatCard:hover {
    background: $primary-background-lighten-1;
    border: solid $primary;
}

.stat-card-inner {
    layout: vertical;
    align: center middle;
    width: 100%;
    height: 100%;
}

.stat-card-icon {
    text-align: center;
    text-style: none;
    margin-bottom: 0;
}

.stat-card-title {
    text-align: center;
    color: $text-muted;
    text-style: none;
    margin-bottom: 0;
}

.stat-card-value {
    text-align: center;
    text-style: bold;
    color: $primary;
    margin: 0;
}

.stat-card-subtitle {
    text-align: center;
    color: $text-disabled;
    text-style: italic;
    margin-top: 0;
}

/* Topic Bar Component */
.topic-bar-container {
    width: 100%;
    height: 3;
    margin-bottom: 1;
    align: left middle;
}

.topic-label {
    min-width: 20;
    text-align: left;
    color: $text;
}

.topic-bar-bg {
    width: 1fr;
    height: 1;
    background: $surface-lighten-1;
    margin-left: 1;
}

.topic-bar-fill {
    height: 1;
    background: $primary;
    transition: width 500ms;
}

/* Topics container */
.topics-container {
    background: $panel;
    border: solid $border;
    padding: 1;
    margin-bottom: 1;
}

/* Topic range cards */
.topic-range-card {
    height: auto;
    min-height: 4;
}

.topic-range-card .stat-card-value {
    text-style: none;
}

/* Character stats */
.character-stats-container {
    background: $panel;
    border: solid $border;
    padding: 1;
    margin-bottom: 1;
}

.character-total {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
}

.character-item {
    padding: 0 1;
    margin-bottom: 1;
}

.character-name {
    text-style: bold;
    color: $text;
}

.character-stats {
    color: $text-muted;
    text-style: italic;
    padding-left: 2;
}

/* Loading states */
.loading-container {
    align: center middle;
    height: 20;
}

.loading-text {
    margin-top: 2;
    color: $text-muted;
}

/* Error states */
.error-container {
    align: center middle;
    padding: 4;
}

.error-message {
    color: $error;
    text-style: bold;
    margin-bottom: 2;
}

.retry-button {
    margin-top: 1;
}

/* No data message */
.no-data-message {
    text-align: center;
    color: $text-muted;
    padding: 4;
}

/* Note: Textual doesn't support media queries
   Grid will automatically adjust based on available space */

/* ===== MODULE: components/splash_viewer.css ===== */
/* Splash Screen Viewer Styles */

/* Main container */
.splash-viewer {
    width: 100%;
    height: 100%;
    padding: 1;
}

SplashScreenViewer {
    width: 100%;
    height: 100%;
    layout: vertical;
}

.splash-viewer-container {
    width: 100%;
    height: 1fr;
    layout: vertical;
}

/* Header */
.viewer-header {
    text-align: center;
    text-style: bold;
    padding: 1;
    background: $primary-darken-3;
    color: $text;
    height: 3;
    dock: top;
}

/* Main section layout */
.viewer-main {
    height: 1fr;
    layout: horizontal;
    padding: 1;
}

/* Main horizontal container */
SplashScreenViewer > Horizontal {
    height: 25;
    width: 100%;
    min-height: 20;
}

/* Card list section - responsive with min/max */
.card-list-container {
    width: 40%;
    min-width: 30;
    max-width: 50;
    height: 100%;
    border: solid $primary;
    padding: 1;
    margin-right: 1;
    layout: vertical;
}

.card-list {
    height: 1fr;
    scrollbar-size: 1 1;
}

/* Panel layouts */
.card-list-panel {
    width: 35%;
    min-width: 30;
    height: 100%;
    border: solid $primary;
    padding: 1;
    margin-right: 1;
}

.preview-panel {
    width: 1fr;
    height: 100%;
    border: solid $primary;
    padding: 1;
}

/* Preview section - takes remaining space */
.preview-container {
    width: 1fr;
    layout: vertical;
    border: solid $primary;
    padding: 1;
}

.preview-widget {
    height: 20;
    min-height: 15;
    border: solid $primary-lighten-2;
    margin-bottom: 1;
}

.preview-content {
    padding: 1;
    text-align: center;
}

/* Card info section */
.card-info {
    height: 5;
    padding: 1;
    background: $surface;
    border: solid $primary-lighten-2;
}

/* Settings section */
.settings-section {
    height: auto;
    padding: 1;
    margin-top: 1;
    border-top: solid $primary;
}

.setting-row {
    height: 3;
    layout: horizontal;
    align: center middle;
    margin-bottom: 1;
}

.setting-label {
    width: 20;
    text-align: right;
    margin-right: 1;
}

.setting-control {
    width: 1fr;
    max-width: 40;
}

.value-label {
    width: 10;
    margin-left: 1;
    text-align: left;
}

/* Active cards section */
.active-cards-container {
    height: auto;
    max-height: 10;
    border: solid $primary-lighten-2;
    padding: 1;
    margin-bottom: 1;
}

.checkbox-button {
    width: 100%;
    text-align: left;
    margin: 0 0 1 0;
    height: 3;
}

/* Action buttons */
.action-buttons {
    height: 3;
    layout: horizontal;
    align: center middle;
    padding: 1;
    margin-top: 1;
}

.action-buttons Button {
    margin: 0 1;
}

/* Section headers */
.section-header {
    text-style: bold;
    color: $primary;
    padding: 1 0;
}

/* Help text */
.help-text {
    text-style: italic;
    color: $text-muted;
    padding: 0 0 1 0;
    text-align: center;
}

/* Modal styles */
.modal-container {
    width: 80%;
    height: 80%;
    max-width: 100;
    max-height: 40;
    align: center middle;
    background: $surface;
    border: double $primary;
    padding: 2;
}

.splash-gallery-modal {
    width: 100%;
    height: 100%;
    layout: vertical;
}

/* Simplified card list */
SplashScreenViewer .card-list {
    height: 20;
    width: 100%;
    border: solid $primary;
    margin: 1 0;
}

/* Card info display */
SplashScreenViewer .card-info {
    height: 5;
    width: 100%;
    padding: 1;
    margin: 1 0;
    border: solid $primary-lighten-2;
    background: $surface;
}

/* Scrollbar styling */
VerticalScroll {
    scrollbar-color: $primary;
    scrollbar-color-hover: $primary-lighten-1;
    scrollbar-color-active: $primary-lighten-2;
}

/* ===== MODULE: features/_chat.tcss ===== */
/* ========================================
 * FEATURES: Chat
 * ======================================== 
 * Chat tab specific styles
 * ======================================== */

/* --- Chat sidebar toggle buttons --- */
.chat-sidebar-toggle-button {
    width: 3;
    height: 100%;
    min-width: 3;
    max-width: 3;
    border: none;
    background: $background;
    color: $text-muted;
    padding: 1 0 0 0;
    margin: 0;
    content-align: center top;
}

.chat-sidebar-toggle-button:hover {
    background: $surface;
    color: $text;
}

.chat-sidebar-toggle-button:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    border: none;
    outline: none;
}

/* --- Chat Window specific layouts --- */
#chat-main-content {
    layout: vertical;
    height: 100%;
    width: 1fr; /* Takes remaining space */
    min-width: 40; /* Prevent squashing */
}

/* --- Compact Model Bar --- */
#compact-model-bar {
    height: 3;
    width: 100%;
    padding: 0 1;
    background: $surface;
    border-bottom: solid $surface-lighten-1;
    align: left middle;
}

#compact-model-bar Select {
    width: 1fr;
    margin: 0 1 0 0;
    height: 3;
}

.compact-bar-label {
    width: auto;
    padding: 0 1;
    color: $text-muted;
}

.compact-bar-temp {
    width: 12;
    margin: 0 1 0 0;
    height: 3;
}

.compact-bar-toggle {
    width: auto;
    min-width: 5;
    height: 3;
    border: none;
    background: $surface-darken-1;
    color: $text-muted;
}

.compact-bar-toggle:hover {
    background: $surface;
    color: $text;
}

/* --- Empty State --- */
#chat-empty-state {
    width: 100%;
    height: 1fr;
    padding: 4 2;
    text-align: center;
    color: $text-muted;
    content-align: center middle;
}

#chat-empty-state.hidden {
    display: none;
}

/* Explicit sidebar styling for the enhanced sidebar */
#chat-enhanced-sidebar {
    width: 25%;
    min-width: 35;
    max-width: 35%;
    height: 100%;
    dock: left;
    border-right: none;
}
/* VerticalScroll for chat messages */
#chat-log {
    height: 1fr; /* Takes remaining space */
    width: 100%;
    overflow-y: auto;  /* Ensure proper scrolling */
    overflow-x: hidden;  /* Hide horizontal overflow */
    /* border: round $surface; Optional: Add border to scroll area */
    padding: 0 1; /* Padding around messages */
}

/* Input area styling (shared by chat and character) */
#chat-input-area, #conv-char-input-area { /* Updated from #character-input-area */
    height: auto;    /* Allow height to adjust */
    max-height: 12;  /* Limit growth */
    width: 100%;
    align: left top; /* Align children to top-left */
    padding: 1; /* Consistent padding */
    border-top: round $surface;
}

/* All buttons in chat input area should have equal flexible width */
#chat-input-area Button {
    width: 1fr;      /* Equal flexible width for all buttons */
    height: 3;       /* Standard button height */
}
/* Input widget styling (shared) */

/* ========================================
 * ChatWindowEnhanced specific styles
 * ======================================== */

ChatWindowEnhanced {
    layout: horizontal;
    height: 100%;
}

/* Image attachment indicator */
#image-attachment-indicator {
    margin: 0 1;
    padding: 0 1;
    background: $surface;
    color: $text-muted;
    height: 3;
    display: none;
}

#image-attachment-indicator.visible {
    display: block;
}

/* Send button states */
.send-button {
    width: 2fr;
    margin-left: 1;
    text-style: bold;
}

.send-button.stop-state {
    background: $error;
}

/* Attachment button */
.attach-button {
    width: auto;
    margin-left: 1;
}

/* Microphone button */
.mic-button {
    width: auto;
    margin-left: 1;
}

/* Voice input widget styles */
.voice-input-widget {
    padding: 1;
    background: $surface;
    border: solid $primary;
}

/* Attachment preview styles */
.attachment-preview {
    padding: 1;
    margin: 1;
    background: $surface-lighten-1;
    border: solid $primary;
}

/* Notes area expansion states */
.notes-textarea-normal {
    height: 10;
}

.notes-textarea-expanded {
    height: 25;
}

/* Chat message type-specific styles */
.chat-message.user {
    background: $primary-lighten-2;
    text-align: right;
}

.chat-message.assistant {
    background: $surface-lighten-1;
    text-align: left;
}

/* Loading and error states */
.loading-indicator {
    text-align: center;
    padding: 2;
    color: $text-muted;
}

.error-message {
    color: $error;
    padding: 1;
    margin: 1;
    border: solid $error;
}
.chat-input { /* Targets TextArea */
    width: 6fr;        /* Take 6x the space compared to other flex items */
    height: auto;      /* Allow height to adjust */
    max-height: 100%;  /* Don't overflow parent */
    margin-right: 1;   /* Space before button */
    border: round $surface;
}

/* Send button styling (shared) */
.send-button { /* Targets Button */
    width: 1fr;      /* Equal flexible width */
    height: 3;       /* Fixed height for consistency */
    /* align-self: stretch; REMOVED */
    margin-top: 0;
    padding: 0;      /* No padding for button */
    transition: background 0.2s, color 0.2s;
}

/* Stop button state - when button is in stop mode */
.send-button:disabled {
    opacity: 0.7;
}

/* Visual feedback for stop state */
.send-button.stop-state {
    background: $error;
    color: white;
}

.stop-button {
    width: 1fr;      /* Equal flexible width */
    height: 3;
    margin-top: 0;
}

/* Action buttons in chat input area (attach, respond-for-me) */
#chat-input-area .action-button {
    width: 1fr;      /* Equal flexible width */
    height: 3;       /* Standard button height */
    border: none;
    background: $surface-darken-1;
    color: $text;
}

/* Save Chat Button in chat-right-sidebar in Chat Tab */
.save-chat-button { /* Class used in character_sidebar.py */
    margin-top: 2;   /* Add 1 cell/unit of space above the button */
    /*width: 100%;      Optional: make it full width like other sidebar buttons */
}

/* Clone Chat Button in chat-right-sidebar */
.clone-chat-button {
    margin-top: 1;   /* Add space above the button */
    width: 100%;     /* Full width like other sidebar buttons */
}

/* chat-right-sidebar Specific Styles */
#chat-right-sidebar #chat-conversation-title-input { /* Title input */
    /* width: 100%; (from .sidebar-input) */
    /* margin-bottom: 1; (from .sidebar-input) */
}

#chat-right-sidebar .chat-keywords-textarea { /* Keywords TextArea specific class */
    height: 4;  /* Or 3 to 5, adjust as preferred */
    /* width: 100%; (from .sidebar-textarea) */
    /* border: round $surface; (from .sidebar-textarea) */
    /* margin-bottom: 1; (from .sidebar-textarea) */
}

/* Styling for the new "Save Details" button */
#chat-right-sidebar .save-details-button {
    margin-top: 1; /* Space above this button */
    /* width: 100%;    Make it full width */
}

/* Ensure the Save Current Chat button also has clear styling if needed */
#chat-right-sidebar .save-chat-button {
    margin-top: 1; /* Ensure it has some space if it's after keywords */
    /* width: 100%; */
}

/* Chat Sidebar - Prompts Section */
#chat-prompts-collapsible Input,
#chat-prompts-collapsible ListView,
#chat-prompts-collapsible Button {
    margin-bottom: 1; /* Consistent spacing */
}
#chat-prompt-list-view { /* ID for the prompt list in chat sidebar */
    height: 8; /* Adjust as needed */
    border: round $surface;
    margin-bottom: 1;
}
.loaded-prompt-area { /* Container for loaded prompt details in chat sidebar */
    margin-top: 1;
    padding: 0 1;        /* Padding for content inside */
    background: $surface; /* Slightly different background to group elements */
    /* To get rounded corners for the area itself, apply a border style */
    border: round $primary-background-lighten-1; /* Example: round border with a light color */
                                               /* Or use 'round $surface' if you want it less distinct */
                                               /* Or 'none' if you only want background and no explicit border */
}
/* End of Character Sidebar Specific Styles */

/* --- Chat Settings Mode Styles --- */

/* Settings mode toggle container */
.settings-mode-container {
    layout: horizontal;
    height: 3;
    width: 100%;
    align: center middle;
    margin-bottom: 1;
    padding: 0 1;
}

/* Mode labels */
.mode-label {
    margin: 0 1;
    color: $text-muted;
}

/* Settings mode toggle switch */
.settings-mode-toggle {
    margin: 0 1;
}

/* Settings search input */
.settings-search-input {
    width: 100%;
    margin-bottom: 2;
    border: round $primary;
}

/* Quick settings section */
.quick-settings-section {
    padding: 1;
    border: round $surface;
    margin-bottom: 1;
}

.rag-settings-panel-advanced {
    padding: 1;
    border: round $accent;
    background: $boost;
    margin-bottom: 1;
}

/* RAG panel header with icon */
.rag-panel-header {
    text-style: bold;
    color: $accent;
    margin-bottom: 1;
    text-align: center;
}

/* RAG toggle row */
.rag-toggle-row {
    layout: horizontal;
    height: 3;
    align: left middle;
    margin-bottom: 1;
}

/* RAG main toggle */
.rag-main-toggle {
    margin-right: 2;
}

/* RAG preset select */
.rag-preset-select {
    width: 50%;
}

/* RAG scope container */
.rag-scope-container {
    padding-left: 2;
    margin-bottom: 1;
}

/* Section headers */
.section-header {
    text-style: bold underline;
    color: $primary;
    margin-bottom: 1;
    margin-top: 1;
}

.subsection-header {
    text-style: bold;
    color: $secondary;
    margin-bottom: 1;
    margin-top: 1;
}

/* Info text */
.info-text {
    color: $text-muted;
    text-style: italic;
    margin-bottom: 1;
}

/* Hidden class for mode switching */
.hidden {
    display: none;
}

/* Search highlighting */
.search-hidden {
    display: none;
}

.search-highlighted {
    background: $warning 20%;
    border: round $warning;
}

/* Settings containers for mode switching */
#chat-basic-settings-container {
    width: 100%;
}

#chat-advanced-settings-container {
    width: 100%;
}

/* --- End Chat Settings Mode Styles ---*/

/* --- Enhanced Chat Settings Styles --- */

/* Mode toggle container */
.mode-toggle-container {
    layout: horizontal;
    height: 4;  /* Increased height to prevent cutoff */
    width: 100%;
    align: center middle;
    margin-bottom: 1;
    padding: 0 0 1 0;  /* Add bottom padding */
}

/* Mode labels */
.mode-label {
    margin: 0 1;
    color: $text-muted;
}

/* Settings mode toggle switch */
.settings-mode-toggle {
    margin: 0 1;
    /* Custom styling for better visibility */
    background: $panel;
    border: solid $primary;
}

/* Switch widget styling for better visibility */
.settings-mode-toggle > .switch--slider {
    background: $primary;  /* Neutral blue when off (Basic mode) */
}

.settings-mode-toggle.-on > .switch--slider {
    background: $accent;  /* Accent color when on (Advanced mode) */
}

/* Switch thumb/handle styling */
.settings-mode-toggle .switch--slider {
    border: solid $primary;
}

/* Advanced Settings checkbox styling */
.advanced-settings-checkbox {
    margin-top: 1;
    margin-bottom: 1;
}

.advanced-settings-checkbox > Checkbox {
    color: $text;
}

.advanced-settings-checkbox:hover {
    color: $accent;
}

/* Settings search input */
.settings-search-input {
    width: 100%;
    margin-bottom: 2;
    border: round $primary;
}

/* RAG Settings Panel - Prominent styling */
.rag-settings-panel {
    padding: 1;
    border: round $surface;  /* Changed to match other panels */
    background: $panel;      /* Changed to standard panel background */
    margin-bottom: 1;
}

/* Remove extra padding from RAG panel content */
.rag-settings-panel Container {
    padding: 0;
    height: auto;
}

/* Highlight RAG panel when focused */
.rag-settings-panel:focus-within {
    border: round $ds-focus-accent;
    background: $panel;
}

/* Remove highlight when collapsed */
.rag-settings-panel.collapsed {
    border: round $surface !important;
    background: $panel !important;
}

/* RAG panel header with icon */
.rag-panel-header {
    text-style: bold;
    color: $accent;
    margin-bottom: 1;
    text-align: center;
}

/* RAG enable toggle */
.rag-enable-toggle {
    margin-bottom: 1;
}

/* RAG preset select */
.rag-preset-select {
    width: 100%;
    margin-bottom: 1;
}

/* RAG scope options */
.rag-scope-options {
    margin-bottom: 1;
}

.rag-scope-options Checkbox {
    margin-bottom: 0;
}

/* Ensure proper spacing for sidebar labels in RAG panel */
.rag-settings-panel .sidebar-label {
    margin-top: 0;
    margin-bottom: 0;
}

/* Advanced only sections - hidden by default in basic mode */
.advanced-only {
    display: none;
}

/* Show advanced sections when in advanced mode */
.sidebar.advanced-mode .advanced-only {
    display: block;
}

/* Hide advanced-only when in basic mode */
.sidebar.basic-mode .advanced-only {
    display: none;
}

/* Search highlighting */
.search-highlight {
    background: $warning 20%;
    border: round $warning;
}

/* --- End Enhanced Chat Settings Styles ---*/

/* --- Visual Polish: Standardized Button Classes --- */

/* Primary action buttons (Send, Submit) */
.btn-primary {
    background: $primary;
    color: $text;
    text-style: bold;
    border: none;
}

.btn-primary:hover {
    background: $primary-lighten-1;
}

/* Secondary action buttons (Clone, Cancel) */
.btn-secondary {
    background: $surface;
    color: $text;
    border: solid $surface-lighten-1;
}

.btn-secondary:hover {
    background: $surface-lighten-1;
}

/* Ghost buttons (text-only, minimal) */
.btn-ghost {
    background: transparent;
    color: $text-muted;
    border: none;
}

.btn-ghost:hover {
    background: $surface;
    color: $text;
}

/* --- End Visual Polish ---*/

/* ===== MODULE: features/_chat_tabs.tcss ===== */
/* Chat Tabs Styling */

/* Tab bar container */
#chat-tab-bar {
    height: 2;
    background: $panel;
    border-bottom: tall $primary;
}

/* Tab scroll container */
.chat-tabs-scroll {
    height: 2;
    width: 100%;
}

/* Individual tab container */
.chat-tab-container {
    height: 2;
    layout: horizontal;
    margin: 0 1;
}

/* Tab buttons */
.chat-tab {
    min-width: 15;
    max-width: 30;
    height: 2;
    padding: 0 1;
    margin: 0;
    background: $panel;
    color: $text-muted;
    border: none;
    text-align: center;
}

.chat-tab:hover {
    background: $boost;
    color: $text;
}

.chat-tab.active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.chat-tab.active:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    outline: none;
}

.chat-tab.active:hover,
.chat-tab.active:hover:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Close tab button */
.close-tab-button {
    width: 3;
    min-width: 3;
    max-width: 3;
    height: 2;
    padding: 0;
    margin-left: 1;
    background: transparent;
    color: $text-muted;
    border: none;
}

.close-tab-button:hover {
    background: $surface-lighten-1;
    color: $text;
}

/* New tab button */
.new-tab-button {
    width: 11;
    min-width: 11;
    height: 2;
    padding: 0;
    margin: 0 1;
    background: $boost;
    color: $text;
    text-style: bold;
    border: none;
}

.new-tab-button:hover {
    background: $surface-lighten-1;
    color: $text;
}

/* Chat sessions container */
.chat-sessions-container {
    width: 100%;
    height: 100%;
}

/* Individual chat session */
.chat-session {
    width: 100%;
    height: 100%;
    display: none;
}

/* No sessions placeholder */
.no-sessions-placeholder {
    width: 100%;
    height: 100%;
    content-align: center middle;
    text-style: italic;
    color: $text-muted;
}

/* First-run guidance inside tabbed chat sessions */
.chat-session .chat-empty-state {
    width: 100%;
    height: auto;
    min-height: 5;
    padding: 1 2;
    text-align: center;
    color: $text-muted;
    content-align: center middle;
}

.chat-session .chat-empty-state.hidden {
    display: none;
}

/* Chat log in tabbed interface */
.chat-session .chat-log {
    height: 1fr;
    overflow-y: scroll;
    padding: 1;
    background: $surface;
}

/* Chat input area in tabbed interface */
.chat-session .chat-input-area {
    height: 5;
    layout: horizontal;
    padding: 1;
    background: $panel;
}

/* Responsive adjustments for small screens */
/* Note: Textual doesn't support @media queries, so these rules are applied directly */
/* @media (max-width: 100) { */
/*     .chat-tab { */
/*         min-width: 10; */
/*         max-width: 20; */
/*     } */
/*      */
/*     .chat-tab-container { */
/*         margin: 0; */
/*     } */
/* } */

/* Animation for tab switching */
.chat-session {
    transition: opacity 200ms;
}

/* Image attachment indicator in tabbed mode */
.chat-session .image-attachment-indicator {
    height: 3;
    margin: 0 1;
    padding: 0 1;
    background: $surface;
    color: $text-muted;
}

/* ===== MODULE: features/_conversations.tcss ===== */
/* ========================================
 * FEATURES: Conversations (Refactored)
 * ======================================== 
 * Conversations, Characters, and Prompts tab
 * Single sidebar design following best practices
 * ======================================== */

/* --- Main container layout --- */
#conversations_characters_prompts-window {
    layout: horizontal;
    height: 100%;
}

/* --- Sidebar Styling (Single, unified sidebar) --- */
.ccp-sidebar {
    width: 30%;
    min-width: 25;
    max-width: 40%;
    height: 100%;
    background: $boost;
    padding: 1;
    border-right: thick $background-darken-1;
    overflow-y: auto;
    overflow-x: hidden;
}

/* Collapsed state for sidebar */
.ccp-sidebar.collapsed {
    width: 0 !important;
    min-width: 0 !important;
    border-right: none !important;
    padding: 0 !important;
    overflow: hidden !important;
    display: none !important;
}

/* Sidebar toggle button */
.ccp-sidebar-toggle-button {
    width: 3;
    height: 100%;
    min-width: 3;
    border: none;
    background: $surface-darken-1;
    color: $text;
    dock: left;
}

.ccp-sidebar-toggle-button:hover {
    background: $surface;
}

/* --- Content Area Styling --- */
.ccp-content-area {
    width: 1fr; /* Takes remaining space after sidebar */
    height: 100%;
    padding: 1;
    overflow-y: auto;
}

/* --- View Areas within Content --- */
.ccp-view-area {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 1;
}

/* Hidden class for view switching */
.ccp-view-area.hidden {
    display: none !important;
}

.hidden {
    display: none !important;
}

/* --- Title Styling --- */
.pane-title {
    text-style: bold;
    margin-bottom: 1;
    text-align: center;
    width: 100%;
    background: $primary-background-darken-1;
    padding: 0 1;
    height: 3;
}

.sidebar-title {
    text-style: bold;
    margin-bottom: 1;
    text-align: center;
    color: $primary;
}

/* --- Sidebar Components --- */
.sidebar-label {
    margin-top: 1;
    margin-bottom: 0;
    color: $text-muted;
}

.sidebar-input {
    width: 100%;
    margin-bottom: 1;
    border: solid $primary-lighten-2;
    border-bottom: solid $primary-lighten-2;
}

.sidebar-textarea {
    width: 100%;
    height: 5;
    margin-bottom: 1;
    border: round $surface;
}

.sidebar-textarea.small {
    height: 3;
}

.sidebar-button {
    width: 100%;
    margin-bottom: 1;
    height: 3;
}

.sidebar-button.small {
    width: 45%;
    margin-right: 1;
}

.sidebar-button.danger {
    background: $error-darken-1;
}

.sidebar-button.danger:hover {
    background: $error;
}

.sidebar-listview {
    height: 10;
    margin-bottom: 1;
    border: round $surface;
}

/* Export buttons container */
.export-buttons {
    layout: horizontal;
    height: 3;
    width: 100%;
    margin-bottom: 1;
}

.export-buttons Button {
    width: 1fr;
    margin-right: 1;
}

.export-buttons Button:last-child {
    margin-right: 0;
}

/* --- Editor Styling --- */
.editor-scroll {
    width: 100%;
    height: 1fr;
    overflow-y: auto;
    padding: 1;
}

.field-label {
    margin-top: 1;
    margin-bottom: 0;
    color: $text-muted;
    text-style: bold;
}

.field-value {
    margin-bottom: 1;
    padding: 0 1;
}

.field-textarea {
    width: 100%;
    height: 8;
    margin-bottom: 1;
    border: round $surface;
}

.editor-input {
    width: 100%;
    margin-bottom: 1;
}

.editor-textarea {
    width: 100%;
    height: 10;
    margin-bottom: 1;
    border: round $surface;
}

.editor-textarea.small {
    height: 5;
}

/* AI Generation buttons */
.field-with-ai {
    layout: horizontal;
    height: auto;
    width: 100%;
    margin-bottom: 1;
}

.field-with-ai TextArea {
    width: 85%;
    margin-right: 1;
}

.ai-generate-button {
    width: 12%;
    height: 3;
    margin-top: 0;
    background: $primary;
}

.ai-generate-button:hover {
    background: $primary-lighten-1;
}

.ai-generate-button.full-width {
    width: 100%;
    margin-bottom: 1;
}

/* Image controls */
.image-controls {
    layout: horizontal;
    height: 3;
    width: 100%;
    margin-bottom: 1;
}

.image-controls Button {
    width: 1fr;
    margin-right: 1;
}

.image-controls Button:last-child {
    margin-right: 0;
}

.image-status {
    margin-bottom: 1;
    padding: 0 1;
    color: $text-muted;
}

.character-image {
    width: 100%;
    height: 15;
    border: round $surface;
    margin-bottom: 1;
    align: center middle;
    background: $surface-darken-1;
}

/* Editor action buttons */
.editor-actions {
    layout: horizontal;
    height: 3;
    width: 100%;
    margin-top: 2;
    margin-bottom: 1;
}

.editor-actions Button {
    width: 1fr;
    margin-right: 1;
}

.editor-actions Button:last-child {
    margin-right: 0;
}

.primary-button {
    background: $success;
}

.primary-button:hover {
    background: $success-lighten-1;
}

.secondary-button {
    background: $surface;
}

.secondary-button:hover {
    background: $surface-lighten-1;
}

/* Dictionary specific styles */
.dict-entries-list {
    height: 12;
    margin-bottom: 1;
    border: round $surface;
}

.dict-entry-controls {
    layout: horizontal;
    height: 3;
    width: 100%;
    margin-top: 1;
    margin-bottom: 1;
}

.dict-entry-controls Button {
    width: 1fr;
    margin-right: 1;
}

.dict-entry-controls Button:last-child {
    margin-right: 0;
}

/* Collapsible styling enhancements */
Collapsible {
    margin-bottom: 1;
}

Collapsible > .collapsible--header {
    background: $primary-background-darken-1;
    color: $text;
    padding: 0 1;
    height: 3;
}

Collapsible.-active > .collapsible--header {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
    border-bottom: solid $ds-focus-accent;
}

/* Select widget styling */
Select {
    width: 100%;
    margin-bottom: 1;
}

/* Checkbox styling */
Checkbox {
    width: 100%;
    margin-bottom: 0;
    height: 2;
}

/* Message display area */
#ccp-conversation-messages-view {
    padding: 1;
}

/* Ensure proper scrolling */
VerticalScroll {
    scrollbar-background: $surface-darken-1;
    scrollbar-color: $primary;
    scrollbar-size: 1 1;
}

/* Note: Textual doesn't support @media queries for responsive design */
/* Width adjustments would need to be handled programmatically */

/* --- End of refactored Conversations, Characters & Prompts styles --- */

/* ===== MODULE: features/_notes.tcss ===== */
/* ========================================
 * FEATURES: Notes
 * ======================================== 
 * Notes tab specific styles
 * ======================================== */

/* --- Notes Tab Window --- */
/* (Assuming #notes-window has layout: horizontal; by default from .window or is set in Python) */

#notes-main-content { /* Parent of the editor and controls */
    layout: vertical; /* This is what I inferred based on your Python structure */
    width: 1fr;       /* Takes space between sidebars */
    height: 100%;
}

.notes-editor { /* Targets your #notes-editor-area by class */
    width: 100%;
    height: 1fr; /* This makes it take available vertical space */
}

#notes-controls-area { /* The container for buttons below the editor */
    height: auto;
    width: 100%;
    padding: 1;
    border-top: round $surface;
    align: center middle; /* Aligns buttons horizontally if Horizontal container */
                           /* If this itself is a Vertical container, this might not do much */
}

/* --- Auto-save status indicators --- */
.unsaved-indicator {
    margin: 0 1;
    text-style: bold;
}

.unsaved-indicator.has-unsaved {
    color: $error;
}

.unsaved-indicator.auto-saving {
    color: $primary;
    text-style: italic;
}

.unsaved-indicator.saved {
    color: $success;
    text-style: bold;
}

.auto-save-label {
    margin-left: 1;
    color: $text-muted;
}

/* --- End of Notes Tab Window --- */

/* ===== MODULE: features/_media.tcss ===== */
/* ========================================
 * FEATURES: Media
 * ========================================
 * Media tab specific styles
 * ======================================== */

/* --- Media Tab --- */
/* MediaWindow v2 - Component-based architecture */
/* Individual component styles are defined in their respective DEFAULT_CSS */

/* Legacy styles for compatibility - will be removed once MediaWindow_v2 is fully integrated */

/* --- Legacy Media Tab Styles --- */
/* DEPRECATED: MediaWindow_v2 has its own layout
#media-window {
    layout: horizontal;
    width: 100%;
}
*/

.media-nav-pane {
    dock: left;
    width: auto;
    min-width: 20;
    max-width: 40;
    background: $boost;
    padding: 1;
    border-right: thick $background-darken-1;
    overflow-y: auto;
    overflow-x: hidden;
}

.media-nav-pane.collapsed {
    width: 0 !important;
    min-width: 0 !important;
    border-right: none !important;
    padding: 0 !important;
    overflow: hidden !important;
    display: none !important;
}

.media-nav-pane .media-nav-button {
    width: 100%;
    margin-bottom: 1;
    border: none;
    height: 3;
    text-align: left;
    padding: 0 1;
}
.media-nav-pane .media-nav-button:hover {
    background: $surface-lighten-1;
    color: $text;
}

.media-content-pane {
    padding: 0;
    layout: vertical;
    width: 1fr;
}

/* Ensure media views fill vertical space when shown */
.media-content-pane > .media-view-area {
    height: 1fr;
}

#media-sidebar-toggle-button {
    dock: top;
    height: 3;
    width: 5;
    margin: 0 0 1 1;
}

.media-view-area {
    width: 100%;
    height: 1fr;
}

/* Grid layout for content area within each media view */
/* DEPRECATED: MediaWindow_v2 uses Horizontal layout, not Grid
.media-view-area > Grid {
    layout: grid;
    grid-size: 2 1;
    grid-columns: 35% 65%;
    grid-gutter: 1;
    height: 1fr;
    width: 100%;
}
*/

/* Target ListItems inside the media list to control their height */
.media-items-list > ListItem {
    width: 100%;
    height: auto; /* This prevents a single item from stretching to fill the whole ListView */
    padding: 0;
    margin: 0 0 1 0;
}

/* Styles for media item components */
.media-item-title {
    height: auto;
    text-style: bold;
}

.media-item-snippet {
    height: auto;
    color: $text-muted;
    max-height: 2;
    overflow-y: hidden;
}

.media-item-meta {
    height: auto;
    text-style: italic;
    color: $text-disabled;
}

/* Style for the Vertical container inside ListItems */
.media-items-list > ListItem > Vertical {
    height: auto;
    width: 100%;
}

/* Ensure all child elements inside media items take full width */
.media-items-list > ListItem > Vertical > * {
    width: 100%;
}

/* DEPRECATED: MediaWindow_v2 uses different class names
.media-content-left-pane {
    width: 35%
}
*/

/* Children of .media-content-left-pane */
.media-content-left-pane > Label.pane-title {
    height: auto;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}
.media-content-left-pane > Input.media-search-input {
    height: 3;
    width: 100%;
    margin-bottom: 1;
}

/* Keyword filter styles */
.keyword-filter-label {
    height: auto;
    margin-bottom: 1;
}

.keyword-filter-input {
    height: 3;
    width: 100%;
    margin-bottom: 1;
}

/* ListView for media items */
/* DEPRECATED: MediaWindow_v2 components have their own styling
.media-items-list {
    width: 100%;
    height: 1fr;
    border: round $primary-lighten-2;
    background: $primary-background;
    margin-bottom: 1;
    overflow-y: auto;
    overflow-x: hidden;
    min-height: 10;
}
*/

.media-pagination-bar {
    height: 3;
    width: 100%;
    align-horizontal: center;
}
.media-pagination-bar Button {
    width: auto;
    min-width: 10;
    margin: 0 1;
}
.media-pagination-bar .media-page-label {
    width: 1fr;
    text-align: center;
    padding: 0 1;
}

/* DEPRECATED: MediaWindow_v2 uses MediaViewerPanel with its own styling
.media-content-right-pane {
    width: 1fr;
    height: 1fr;
    padding: 1;
    overflow-y: auto;
    layout: vertical;
}
*/

.media-details-theme {
    height: 1fr;
    width: 100%;
    overflow-y: auto !important;
    min-height: 0;
}

/* Force Markdown content in Media tab to expand fully */
.media-content-right-pane Markdown {
    height: 1fr !important;
    overflow-y: auto !important;
}

/* Additional override for any potential Textual default constraints */
VerticalScroll.media-content-right-pane {
    height: 1fr !important;
}

VerticalScroll.media-content-right-pane > Markdown {
    height: 1fr !important;
}

/* --- Media Details Widget --- */
MediaDetailsWidget {
    height: 1fr;
    width: 100%;
    layout: vertical;
}

.metadata-section {
    width: 100%;
    height: auto;
    padding: 1;
    background: $boost;
    border-bottom: thick $background-darken-1;
}

.metadata-view {
    layout: vertical;
    height: auto;
}

.metadata-section {
    height: auto;
    width: 100%;
    layout: vertical;
    margin-bottom: 1;
}

.metadata-view {
    layout: vertical;
    height: auto;
    width: 100%;
}

.metadata-display {
    padding: 0 1;
    margin-bottom: 0;
    height: auto;
}

.metadata-edit {
    layout: vertical;
    padding: 1;
    height: auto;
    min-height: 30;
}

.edit-fields {
    layout: vertical;
    margin-bottom: 1;
}

.edit-fields Label {
    margin-top: 0;
    margin-bottom: 0;
    text-style: bold;
    height: 1;
}

.edit-fields Input {
    width: 100%;
    margin-bottom: 0;
    height: 3;
}

.edit-fields Input:disabled {
    opacity: 0.6;
    background: $boost-darken-1;
}

/* --- Formatting Options --- */
.formatting-options {
    width: 100%;
    height: auto;
    padding: 0 1;
    margin-bottom: 1;
    layout: horizontal;
    align: center middle;
}

.format-reading-checkbox {
    width: auto;
    height: 3;
    padding: 0 1;
}

.format-reading-checkbox:hover {
    background: $boost;
}

.edit-actions {
    layout: horizontal;
    height: auto;
    align: left top;
    margin-top: 1;
}

.edit-actions Button {
    margin-right: 1;
    min-width: 10;
}

.media-content-display {
    height: 1fr;
    width: 100%;
    padding: 1;
}

/* Content search section */
.content-search-section {
    width: 100%;
    padding: 1;
    background: $boost;
    border-bottom: solid $primary-background;
}

.search-controls {
    layout: horizontal;
    align: center middle;
    height: 3;
}

.content-search-input {
    width: 1fr;
    margin-right: 1;
}

.content-search-button {
    width: 4;
    min-width: 4;
    margin-right: 1;
}

.content-search-nav {
    width: 3;
    min-width: 3;
    margin-right: 1;
}

.content-search-status {
    width: auto;
    color: $text-muted;
    text-style: italic;
}

/* --- Deleted Items Styling --- */
.deleted-media-item {
    opacity: 0.6;
}

.deleted-media-item:hover {
    opacity: 0.8;
}

.media-item-deleted {
    color: $text-disabled;
    text-style: strike;
}

.media-item-title.media-item-deleted {
    color: $error;
    text-style: strike;
}

/* Show deleted checkbox styling */
.show-deleted-checkbox {
    width: 100%;
    margin-bottom: 1;
    padding: 0 1;
    height: auto;
}

/* Metadata buttons container */
.metadata-buttons {
    layout: horizontal;
    height: 3;
    width: 100%;
    margin-top: 1;
    margin-bottom: 1;
}

.metadata-edit-button {
    width: auto;
    min-width: 10;
    dock: left;
}

.metadata-delete-button {
    width: auto;
    min-width: 10;
    dock: right;
}

/* Hidden state */
.hidden {
    display: none;
}

/* --- Collections/Tags Window --- */
.collections-main-container {
    layout: horizontal;
    width: 100%;
}

.collections-left-pane {
    width: 40%;
    min-width: 30;
    layout: vertical;
    padding: 1;
    border-right: thick $background-darken-1;
}

.collections-right-pane {
    width: 1fr;
    padding: 1;
    overflow-y: auto;
}

.keyword-list {
    height: 1fr;
    border: round $primary-lighten-2;
    background: $primary-background;
    overflow-y: auto;
}

.keyword-list .keyword-item {
    padding: 1;
    margin-bottom: 0;
}

.keyword-list .keyword-item.selected,
.keyword-list .keyword-item.selected:hover {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.keyword-list .keyword-item:hover {
    background: $surface-lighten-1;
    color: $text;
}

.keyword-action-buttons {
    layout: horizontal;
    height: 3;
    margin-bottom: 1;
}

.keyword-action-buttons Button {
    width: 1fr;
    margin-right: 1;
}

.action-buttons-container {
    layout: vertical;
    margin-bottom: 2;
}

.action-buttons-container Button {
    width: 100%;
    margin-bottom: 1;
}

.selection-info {
    padding: 1;
    background: $boost;
    margin-bottom: 1;
    text-align: center;
}

.keyword-details, .usage-stats {
    padding: 1;
    background: $boost;
    margin-top: 1;
    min-height: 10;
}

/* Rename/Merge Dialog Styles */
#rename-dialog-container, #merge-dialog-container {
    align: center middle;
    width: 50;
    min-height: 10;
    padding: 2;
    background: $surface;
    border: thick $primary;
}

#rename-title, #merge-title {
    text-align: center;
    text-style: bold;
    margin-bottom: 1;
}

#merge-instruction {
    text-align: center;
    margin-bottom: 1;
    color: $text-muted;
}

#new-keyword-input, #new-target-input {
    width: 100%;
    margin-bottom: 1;
}

#target-keyword-list {
    height: 15;
    margin-bottom: 1;
    border: round $primary-lighten-2;
    background: $primary-background;
}

#rename-buttons, #merge-buttons {
    layout: horizontal;
    height: 3;
    align: center middle;
}

#rename-buttons Button, #merge-buttons Button {
    margin: 0 1;
    min-width: 12;
}

/* --- Multi-Item Review Window --- */
.multi-review-container {
    width: 100%;
    padding: 1;
}

.selection-section, .items-section, .analysis-section {
    width: 100%;
    margin-bottom: 1;
    padding: 1;
    background: $boost;
}

.selection-section {
    height: auto;
    min-height: 15;
}

.items-section {
    height: auto;
    min-height: 20;
    max-height: 40;
}

.analysis-section {
    height: auto;
    min-height: 30;
}

.search-controls, .tag-filter-section, .selection-controls {
    layout: horizontal;
    height: 3;
    margin-bottom: 1;
}

.search-controls Input {
    width: 1fr;
    margin-right: 1;
}

.tag-filter-section Label {
    width: auto;
    margin-right: 1;
}

.tag-input {
    width: 1fr;
}

.selection-controls Button {
    margin-right: 1;
}

.selection-info {
    width: auto;
    padding: 0 1;
}

.review-items-list {
    height: 1fr;
    border: round $primary-lighten-2;
    background: $primary-background;
    overflow-y: auto;
}

.review-items-list .review-item {
    padding: 1;
    margin-bottom: 0;
}

.review-items-list .review-item.selected,
.review-items-list .review-item.selected:hover {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.review-items-list .review-item:hover {
    background: $surface-lighten-1;
    color: $text;
}

.item-title {
    text-style: bold;
    color: $text;
}

.item-meta {
    color: $text-muted;
    text-style: italic;
}

.analysis-prompt {
    width: 100%;
    height: 10;
    margin-bottom: 1;
}

.analysis-controls {
    layout: horizontal;
    height: 3;
    margin-bottom: 1;
}

.analysis-controls Checkbox {
    width: auto;
    margin-right: 2;
}

.analysis-controls Button {
    margin-right: 1;
    min-width: 15;
}

.analysis-progress {
    width: 100%;
    height: 1;
    margin-bottom: 1;
}

.progress-label {
    text-align: center;
    margin-bottom: 1;
    color: $text-muted;
}

.results-container {
    height: 1fr;
    background: $primary-background;
    padding: 1;
}

.analysis-results {
    layout: vertical;
    width: 100%;
}

.analysis-result-card {
    width: 100%;
    padding: 1;
    margin-bottom: 1;
    background: $boost;
    border: round $primary-lighten-2;
}

.result-header {
    layout: horizontal;
    height: auto;
    margin-bottom: 1;
}

.result-title {
    width: 1fr;
    text-style: bold;
}

.result-meta {
    color: $text-muted;
    margin-bottom: 1;
}

.result-content {
    padding: 1;
    max-height: 20;
    overflow-y: auto;
}

.result-separator {
    text-align: center;
    color: $text-disabled;
    margin-top: 1;
}

/* Delete confirmation dialog for keywords */
#delete-dialog {
    layout: vertical;
    padding: 2;
}

.dialog-title {
    text-align: center;
    text-style: bold;
    margin-bottom: 1;
}

.dialog-subtitle {
    text-align: center;
    color: $text-muted;
    margin-bottom: 1;
}

.dialog-message {
    text-align: center;
    margin-bottom: 2;
}

.dialog-buttons {
    layout: horizontal;
    height: 3;
    align: center middle;
}

.dialog-buttons Button {
    margin: 0 1;
    min-width: 12;
}

/* --- End of Media Tab --- */

/* ===== MODULE: features/_search-rag.tcss ===== */
/* ========================================
 * FEATURES: Search and RAG
 * ======================================== 
 * Search and RAG tab interface
 * ======================================== */

/* --- Search Tab (RAG/Embeddings) --- */
#search-window { /* Matches TAB_SEARCH, .window class provides layout: horizontal */
    /* No explicit layout needed here if .window handles it */
}

.search-nav-pane { /* Style for the left navigation pane in Search Tab */
    dock: left;
    width: auto;
    min-width: 25;
    max-width: 60;
    height: 100%;
    background: $boost;
    padding: 1;
    border-right: thick $background-darken-1;
    overflow-y: auto;
    overflow-x: hidden;
}

.search-nav-pane .search-nav-button { /* Style for navigation buttons in Search Tab */
    width: 100%;
    margin-bottom: 1;
    border: none;
    height: 3;
}
.search-nav-pane .search-nav-button:hover {
    background: $surface-lighten-1;
    color: $text;
}
.search-nav-pane .search-nav-button:disabled:hover {
    background: $surface-darken-1;
    color: $text-disabled;
    text-style: none;
}
/* Active state for selected search nav button */
.search-nav-pane .search-nav-button.-active-search-sub-view {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}
.search-content-pane { /* Style for the right content display area in Search Tab */
    width: 1fr;
    height: 100%;
    padding: 0;
    overflow-y: auto;
}

/* Generic style for all search view areas */
.search-view-area {
    height: 100%;
    width: 100%;
    display: block;
    overflow-y: auto;
}

/* Specific rule for the RAG Q&A view container */
#search-view-rag-qa {
    overflow-y: auto;
    height: 100%;
    width: 100%;
}

/* Ensure SearchRAGWindow fills its container properly */
#search-view-rag-qa SearchRAGWindow {
    display: block;
    height: 100%;
    width: 100%;
}

/* -------------------------------------------------------------------------------------- */

/* Web Search Specific Styles within Search Tab */
#search-view-web-search {
    /* Overriding the generic .search-view-area Static centering if needed */
    /* For direct children like Input, Button, VerticalScroll, default layout (vertical) should be fine. */
    padding: 1; /* Add some padding inside the web search view area */
}

#search-view-web-search > Input#web-search-input { /* Target Input directly inside */
    margin-bottom: 1; /* Space below the input field */
    width: 100%;
}

/* .search-action-button is used by #web-search-button */
.search-action-button {
    width: 100%;
    margin-bottom: 1; /* Space below the button */
    /* height: 3; /* Optional: Standard button height */
}

#search-view-web-search > VerticalScroll > Markdown#web-search-results { /* Target Markdown inside VS */
    width: 100%; /* Take full width */
    height: 1fr; /* Take remaining vertical space within its parent VerticalScroll */
    border: round $primary-background-lighten-2;
    padding: 1;
    background: $surface; /* A slightly different background for the results area */
}

/* Embeddings Creation View Styles */
#search-view-embeddings-creation {
    height: 100%;
    width: 100%;
    display: block;
    overflow: hidden;
}

.search-form-container {
    width: 100%;
    margin: 0 0;
}

.search-view-title {
    text-style: bold;
    text-align: center;
    background: blue 30%;
    color: $text;
    padding: 1;
    margin-bottom: 2;
    border: round $accent-darken-1;
}

.search-section-title {
    text-style: bold;
    margin-top: 2;
    margin-bottom: 1;
    background: $primary-background-lighten-1;
    padding: 0 1;
    border-left: thick $accent;
}

.search-form-row {
    margin-bottom: 1;
    height: 3;
    align: left middle;
}

.search-form-label {
    width: 30%;
    padding-right: 1;
    text-align: right;
}

/* Embeddings Management View Styles */
#search-view-embeddings-management {
    height: 100%;
    width: 100%;
    display: block;
    overflow: hidden;
}

.search-management-left-pane {
    width: 45%;
    padding-right: 1;
    border-right: solid $background-darken-1;
}

.search-management-right-pane {
    width: 55%;
    padding-left: 1;
}

.search-button-row {
    margin-top: 2;
    align-horizontal: center;
}

.search-button-row Button {
    margin: 0 1;
}

/* Status output styling */
#creation-status-output, #mgmt-status-output {
    margin-top: 2;
    border: round $primary-background-lighten-2;
    padding: 1;
    background: $surface;
}

/* --- End of Search Tab --- */
/* ----------------------------- ************************* ----------------------------- */

/* Enhanced SearchRAGWindow Styles */
.rag-search-main-wrapper {
    height: 100%;
    width: 100%;
    background: $background;
}

.rag-search-container {
    height: 100%;
    width: 100%;
    padding: 0;
    background: $background;
}

/* Header Section */
.search-header-section {
    background: $primary-darken-2;
    padding: 2 3 1 3;
    margin-bottom: 2;
    border-bottom: solid $primary-background;
}

.rag-title-enhanced {
    text-align: center;
    text-style: bold;
    color: $primary;
    /* font-size: 18; - not supported in TCSS */
    margin-bottom: 1;
}

.rag-subtitle {
    text-align: center;
    color: $text-muted;
    text-style: italic;
}

/* Search Section */
.search-section {
    background: $surface;
    padding: 2;
    margin: 0 2 2 2;
    border: round $primary-background;
}

.search-input-wrapper {
    /* position: relative; - not supported in TCSS */
}

.search-bar-enhanced {
    layout: horizontal;
    height: 4;
    background: $background;
    border: thick $primary;
    /* border-radius: 2; - not supported in TCSS */
    padding: 0 1;
    align: center middle;
}

.search-query-input-enhanced {
    width: 1fr;
    background: transparent;
    border: solid transparent;
    border-bottom: solid transparent;
    padding: 0 1;
    /* font-size: 14; - not supported in TCSS */
}

.search-query-input-enhanced:focus {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    outline: none;
}

.clear-button {
    width: 3;
    min-width: 3;
    height: 3;
    background: transparent;
    border: none;
    color: $text-muted;
    margin: 0;
}

.clear-button:hover {
    color: $error;
    background: $error 20%;
}

.search-button-enhanced {
    min-width: 10;
    height: 3;
    margin-left: 1;
    background: $primary;
    color: $text;
    border: none;
}

.search-button-enhanced:hover {
    background: $primary-lighten-1;
}

.search-loading-indicator {
    /* position: absolute; - not supported in TCSS */
    /* top: 1; - not supported in TCSS */
    /* right: 12; - not supported in TCSS */
    width: 2;
    height: 2;
}

/* Settings Section */
.settings-section {
    margin: 0 2;
}

.quick-settings-container {
    background: $surface;
    padding: 2;
    margin-bottom: 1;
    border: round $primary-background;
}

.settings-title {
    text-style: bold;
    color: $primary;
    margin-bottom: 2;
    text-align: center;
}

.settings-grid {
    layout: horizontal;
    /* gap: 3; - not supported in TCSS */
}

.setting-group {
    width: 1fr;
}

.setting-label {
    color: $text-muted;
    margin-bottom: 1;
    /* font-size: 12; - not supported in TCSS */
}

.mode-select {
    width: 100%;
    background: $background;
    border: solid $primary-background;
}

.source-checkboxes-enhanced {
    layout: horizontal;
    /* gap: 2; - not supported in TCSS */
    background: $background;
    padding: 1;
    border: round $primary-background;
}

.source-checkbox {
    margin: 0;
}

/* Saved Searches Panel */
.saved-searches-panel-enhanced {
    background: $boost;
    padding: 2;
    margin-bottom: 2;
    border: round $primary-background;
}

.saved-searches-wrapper {
    width: 100%;
}

.saved-searches-header {
    layout: horizontal;
    margin-bottom: 1;
    align: center middle;
}

.saved-searches-title {
    width: 1fr;
    text-style: bold;
    color: $secondary;
}

.new-search-button {
    width: 3;
    height: 3;
    min-width: 3;
    background: $primary;
    color: $text;
    border: round $primary;
}

.saved-searches-list-enhanced {
    height: 5;
    border: round $background;
    background: $background;
    margin-bottom: 1;
}

.empty-saved-searches {
    text-align: center;
    color: $text-muted;
    padding: 2;
    text-style: italic;
}

.saved-search-actions-enhanced {
    layout: horizontal;
    /* gap: 1; - not supported in TCSS */
}

.saved-action-button {
    width: 1fr;
    min-width: 8;
}

.saved-action-button.danger {
    background: $error-darken-1;
    color: $text;
}

.saved-action-button.danger:hover {
    background: $error;
}

/* Advanced Settings */
.advanced-collapsible {
    margin-bottom: 2;
}

.advanced-collapsible > .collapsible--header {
    background: $surface;
    padding: 1 2;
    border: round $primary-background;
}

.advanced-settings-wrapper {
    background: $surface;
    padding: 2;
    border: round $primary-background;
    border-top: none;
}

.advanced-section {
    margin-bottom: 2;
    padding-bottom: 2;
    border-bottom: dashed $primary-background;
}

.advanced-section:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
}

.advanced-section-title {
    text-style: bold;
    color: $secondary;
    margin-bottom: 1;
}

.parameter-grid-enhanced {
    layout: horizontal;
    /* gap: 2; - not supported in TCSS */
}

.param-group {
    width: 1fr;
}

.param-label {
    color: $text-muted;
    margin-bottom: 0;
    /* font-size: 12; - not supported in TCSS */
}

.param-input {
    width: 100%;
    margin-top: 0;
    background: $background;
    border: solid $primary-background;
}

.rerank-checkbox {
    margin: 1 0;
}

.chunking-section {
    margin-top: 1;
}

/* Status Container */
.status-container-enhanced {
    background: $boost;
    padding: 1 2;
    margin: 0 2 2 2;
    border: round $primary-background;
}

.status-bar {
    layout: horizontal;
    align: center middle;
}

.search-status-enhanced {
    width: 1fr;
    color: $text;
    text-style: bold;
}

.search-stats {
    color: $text-muted;
    /* font-size: 12; - not supported in TCSS */
}

.search-progress-bar {
    margin-top: 1;
    height: 1;
    background: $background;
    border: solid $primary-background;
}

/* Results Section */
.results-section {
    margin: 0 2 2 2;
    height: 1fr;
}

.results-title {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
    padding: 1;
    background: $surface;
    border: round $primary-background;
    text-align: center;
}

.results-tabs-enhanced {
    height: 100%;
    background: $surface;
    border: round $primary-background;
}

.results-tabs-enhanced TabPane {
    padding: 1;
}

.results-header {
    background: $boost;
    padding: 1;
    margin-bottom: 1;
    border: round $primary-background;
}

.results-header-bar {
    layout: horizontal;
    align: center middle;
}

.results-summary-enhanced {
    width: 1fr;
    color: $text;
}

.pagination-controls-enhanced {
    layout: horizontal;
    /* gap: 1; - not supported in TCSS */
    align: center middle;
}

.page-button {
    width: 3;
    min-width: 3;
    height: 3;
    background: $panel;
    border: solid $primary-background;
}

.page-button:hover {
    background: $primary;
    color: $text;
}

.page-button:disabled {
    opacity: 0.6;
    background: $panel-darken-2;
    color: $text-muted;
}

.page-info-enhanced {
    min-width: 10;
    text-align: center;
    color: $text-muted;
}

.results-container-enhanced {
    height: 1fr;
    background: $background;
    padding: 1;
}

/* Search Result Cards */
.search-result-card-enhanced {
    margin-bottom: 1;
    background: $panel;
    border: solid $primary-background;
    transition: all 0.2s;
}

.search-result-card-enhanced:hover {
    background: $panel-lighten-1;
    border: solid $primary;
    /* box-shadow: 0 2 4 $primary 30%; - not supported */
}

.search-result-card-enhanced.expanded {
    background: $boost;
    border: thick $primary;
}

.result-card-wrapper {
    layout: horizontal;
    padding: 1;
    /* gap: 1; - not supported in TCSS */
}

.result-source-column {
    width: 5;
    align: center middle;
    padding: 1;
    background: $background-darken-1;
    /* border-radius: 1; - not supported in TCSS */
}

.source-icon {
    /* font-size: 20; - not supported in TCSS */
    margin-bottom: 0;
}

.source-label {
    /* font-size: 10; - not supported in TCSS */
    text-style: bold;
    margin-top: 0;
}

.source-media { color: $primary; }
.source-conversation { color: $success; }
.source-note { color: $warning; }

.result-content-column {
    width: 1fr;
    padding: 0 1;
}

.result-header-enhanced {
    layout: horizontal;
    margin-bottom: 1;
    align: center middle;
}

.result-title-enhanced {
    width: 1fr;
    color: $text;
    /* font-size: 14; - not supported in TCSS */
}

.score-indicator {
    min-width: 5;
    height: 2;
    padding: 0 1;
    /* border-radius: 1; - not supported in TCSS */
    align: center middle;
}

.score-text {
    /* font-size: 11; - not supported in TCSS */
    text-align: center;
}

.score-high {
    background: $success;
    color: $text;
}

.score-medium {
    background: $warning;
    color: $text;
}

.score-low {
    background: $error-darken-1;
    color: $text;
}

.result-preview-enhanced {
    color: $text-muted;
    margin-bottom: 1;
    /* line-height: 1.4; - not supported in TCSS */
}

.metadata-pills {
    layout: horizontal;
    /* gap: 1; - not supported in TCSS */
    margin-bottom: 1;
    /* flex-wrap: wrap; - not supported in TCSS */
}

.metadata-pill {
    background: $background;
    padding: 0 1;
    border: solid $primary-background;
    /* border-radius: 1; - not supported in TCSS */
    /* font-size: 11; - not supported in TCSS */
    color: $text-muted;
}

.metadata-pill.more {
    background: $primary-darken-2;
    color: $primary;
}

.result-expanded-content {
    margin-top: 1;
    padding: 1;
    background: $background;
    border: round $primary-background;
}

.expanded-section-title {
    color: $secondary;
    margin: 1 0;
}

.citation-doc-title {
    color: $primary;
    margin: 1 0 0 1;
    text-style: bold;
}

.citation-item {
    color: $text-muted;
    margin: 0 0 0 2;
    padding: 0;
}

.citation-exact {
    color: $success;
}

.citation-semantic {
    color: $primary;
}

.citation-fuzzy {
    color: $warning;
}

.citation-keyword {
    color: $secondary;
}

.result-full-content {
    color: $text;
    margin-bottom: 1;
    max-height: 20;
    overflow-y: auto;
}

.metadata-full-item {
    color: $text-muted;
    margin-left: 1;
}

.result-actions-enhanced {
    layout: horizontal;
    /* gap: 1; - not supported in TCSS */
    margin-top: 1;
}

.result-button {
    min-width: 8;
    height: 3;
    background: $background;
    border: solid $primary-background;
    /* font-size: 12; - not supported in TCSS */
}

.result-button:hover {
    background: $primary;
    color: $text;
}

.view-button {
    background: $primary-darken-1;
    color: $text;
}

/* Context and Analytics */
.context-preview-enhanced {
    padding: 2;
    background: $background;
    border: round $primary-background;
    max-height: 30;
    overflow-y: auto;
}

.history-table-enhanced {
    width: 100%;
    height: 100%;
}

.analytics-content-enhanced {
    padding: 2;
}

/* Action Buttons */
.actions-section {
    margin: 0 2 2 2;
}

.action-buttons-bar-enhanced {
    layout: horizontal;
    background: $surface;
    padding: 2;
    border: round $primary-background;
    align: center middle;
}

.primary-actions {
    layout: horizontal;
    /* gap: 1; - not supported in TCSS */
}

.action-spacer {
    width: 1fr;
}

.maintenance-actions {
    /* position: relative; - not supported in TCSS */
}

.action-button {
    min-width: 12;
    height: 3;
    border: solid $primary-background;
}

.save-button {
    background: $success-darken-1;
    color: $text;
}

.save-button:hover {
    background: $success;
}

.export-button {
    background: $primary-darken-1;
    color: $text;
}

.export-button:hover {
    background: $primary;
}

.export-button:disabled {
    opacity: 0.6;
    background: $panel-darken-2;
}

.maintenance-button {
    background: $panel;
    color: $text-muted;
}

.maintenance-button:hover {
    background: $panel-lighten-1;
    color: $text;
}

.maintenance-menu {
    /* position: absolute; - not supported in TCSS */
    /* bottom: 4; - not supported in TCSS */
    /* right: 0; - not supported in TCSS */
    background: $surface;
    border: solid $primary;
    padding: 1;
    min-width: 15;
    /* z-index: 100; - not supported */
}

.menu-item {
    width: 100%;
    margin-bottom: 1;
    background: $panel;
    border: none;
    text-align: left;
}

.menu-item:hover {
    background: $primary;
    color: $text;
}

.menu-item:last-child {
    margin-bottom: 0;
}

/* Empty States */
.empty-results-message {
    text-align: center;
    color: $text-muted;
    padding: 4;
    text-style: italic;
    background: $surface;
    border: dashed $primary-background;
    margin: 2;
}

/* Ensure SearchRAGWindow fills its container */
#search-view-rag-qa {
    height: 100%;
    width: 100%;
    display: block;
    overflow-y: auto;
}

/* --- Enhanced RAG Search UI Styles --- */

/* Search History Dropdown */
.search-history-dropdown {
    /* position: absolute; - not supported in TCSS */
    width: 100%;
    max-height: 15;
    background: $surface;
    border: solid $primary;
    border-top: none;
    margin-top: -1;
    /* z-index: 100; - not supported in TCSS */
}

.search-history-dropdown.hidden {
    display: none;
}

.search-history-list {
    max-height: 15;
    overflow-y: auto;
    background: $background;
}

.history-item-text {
    padding: 1;
    border-bottom: dashed $primary-background;
}

.history-item-text:hover {
    background: $boost;
    color: $primary;
}

/* --- End Enhanced RAG Search UI Styles ---*/

/* ===== MODULE: features/_llm-management.tcss ===== */
/* ========================================
 * FEATURES: LLM Management
 * ======================================== 
 * LLM Management tab styles
 * ======================================== */

/* --- LLM Management Tab --- */
#llm_management-window { /* Matches TAB_LLM ("llm_management") */
    layout: horizontal;
}

.llm-nav-pane { /* Style for the left navigation pane */
    dock: left;
    width: auto;
    min-width: 25;
    max-width: 60;
    height: 100%;
    background: $boost; /* Or $surface-darken-1 or $surface-lighten-1 */
    padding: 1;
    border-right: thick $background-darken-1;
    overflow-y: auto;
    overflow-x: hidden;
}

.llm-nav-pane .llm-nav-button { /* Style for navigation buttons */
    width: 100%;
    margin-bottom: 1;
    border: none;
    height: 3;
    text-align: left;
    padding: 0 1;
}
.llm-nav-pane .llm-nav-button:hover {
    background: $surface-lighten-1;
    color: $text;
}
/* Active state for selected llm nav button */
.llm-nav-pane .llm-nav-button.-active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.llm-content-pane { /* Style for the right content display area */
    width: 1fr;
    height: 100%;
    padding: 1 2;
    overflow-y: auto;
}

.llm-view-area { /* Common class for individual content areas */
    width: 100%;
    height: 100%; /* Or auto */
    display: none; /* Initially hidden until activated */
}

/* Chat Sidebar Prompts Section Specific Styles */
#chat-sidebar-prompts-collapsible { /* The collapsible container itself */
    /* Add any specific styling for the collapsible if needed */
}

#chat-sidebar-prompt-search-input,
#chat-sidebar-prompt-keyword-filter-input {
    margin-bottom: 1; /* Add some space below these inputs */
}

#chat-sidebar-prompts-listview {
    min-height: 5;
    max-height: 15;
    height: auto;
    overflow-y: auto;
    border: round $surface;
    margin-bottom: 1;
}

#chat-sidebar-prompt-system-display,
#chat-sidebar-prompt-user-display {
    min-height: 5;
    max-height: 15;
    height: auto;
    width: 100%; /* Ensure they take full width */
    margin-bottom: 1;
    border: round $surface; /* Standard border like other textareas */
    /* read_only is set in Python, CSS cannot enforce it but can style */
}

#chat-sidebar-copy-system-prompt-button,
#chat-sidebar-copy-user-prompt-button {
    width: 100%; /* Make copy buttons full width */
    margin-top: 0; /* Remove top margin if directly after TextArea */
    margin-bottom: 1; /* Space after copy buttons */
}
/*

/* LLM Management Tab Specific Styles */
#llm_management-window .llm-view-area > VerticalScroll { /* Target the new VS inside each view */
    height: 100%; /* Ensure the VerticalScroll takes full height of its parent view area */
}

#llamacpp-args-help-collapsible,
#llamafile-args-help-collapsible,
#vllm-args-help-collapsible { /* Style for the collapsible itself */
    margin-top: 1;
    margin-bottom: 1;
    border: round $primary-lighten-1; /* Optional border for the collapsible */
}

#llamacpp-args-help-collapsible > .collapsible--header,
#llamafile-args-help-collapsible > .collapsible--header,
#vllm-args-help-collapsible > .collapsible--header { /* Style for the collapsible title */
    background: $surface-darken-1; /* Slightly different background for the header */
}

.help-text-display {
    height: 25; /* Or your desired fixed height for the scrollable help text */
    width: 100%;
    border: round $surface;
    padding: 1;
    margin-top: 1; /* Space between collapsible title and the content */
    background: $panel; /* Background for the help text area */
    overflow-y: scroll !important; /* Ensure vertical scrolling */
}

/* Ensure input fields for additional args are appropriately sized if they were TextAreas */
/* If you changed #llamacpp-additional-args to Input, this might not be needed for it */
#llamacpp-additional-args, /* This is now an Input, so this rule might be less relevant for it */
#llamafile-additional-args,
#vllm-additional-args {
    height: 3; /* For single-line Input or small TextArea */
    /* If it's a TextArea and you want more lines: */
    /* min-height: 3; */
    /* max-height: 7; */
    /* height: auto; */
}

/* Log output styles for Llama.cpp and Llamafile views */
#llm-view-llama-cpp .log_output,
#llm-view-llamafile .log_output {
    width: 100%;
    height: 15; /* Fixed height to ensure scrolling works */
    min-height: 10;
    max-height: 20;
    border: panel $primary-darken-2;
    background: $background-darken-1;
    margin-top: 1;
    overflow-y: auto;
}

/* Optional: Style for the input_container if needed */
.input_container {
    layout: horizontal;
    height: auto;
    margin-bottom: 1;
}
.input_container Input {
    width: 1fr; /* Input takes available space */
    margin-right: 1; /* Space before browse button */
}
.input_container .browse_button {
    width: auto; /* Let button size itself */
    height: 100%;
}

.button_container {
    layout: horizontal;
    height: auto;
    margin-top: 1;
}
.button_container Button {
    margin-left: 1; /* Space between buttons */
}
/* Ollama Specific Styles within #llm-view-ollama */
#llm-view-ollama {
    layout: vertical; /* Ensures children stack vertically by default */
    /* overflow-y: auto; /* Add if direct children of llm-view-ollama might overflow before VerticalScroll */
}
#llm-view-ollama VerticalScroll { /* Ensure the VerticalScroll takes up space */
    height: 100%;
}

#llm-view-ollama .label { /* General label styling if not already covered */
    margin-top: 1;
    margin-bottom: 0; /* Tighten space below label if input is right after */
    text-style: bold;
}
#llm-view-ollama .section_label { /* For labels that act as section headers */
    margin-top: 2; /* More space above section labels */
    padding: 1 0;
    border: ascii $primary-background-lighten-1; /* Optional: add a border or background */
    text-align: center;
    width: 100%;
}

#llm-view-ollama .input_field,
#llm-view-ollama .input_field_short,
#llm-view-ollama .input_field_long {
    margin-bottom: 1; /* Space after input fields */
}
#llm-view-ollama .input_field_long { /* For paths or longer inputs */
    width: 100%;
}

#llm-view-ollama .input_action_container { /* For Input + Button on same line */
    layout: horizontal;
    height: auto; /* Fit content */
    margin-bottom: 0; /* Status/Output will provide margin */
}
#llm-view-ollama .input_action_container .input_field_short {
    width: 1fr; /* Input takes most space */
    margin-right: 1;
    margin-bottom: 0; /* No bottom margin if button is next to it */
}
#llm-view-ollama .input_action_container .action_button_short {
    width: auto; /* Let button size itself */
    min-width: 10; /* Ensure it's not too small */
    height: 100%; /* Match input height */
}
#llm-view-ollama .input_action_container .browse_button_short {
    width: auto;
    min-width: 15;
    height: 100%;
}

#llm-view-ollama .action_container { /* For standalone buttons */
    width: 100%;
    height: auto;
    margin-bottom: 0;
}
#llm-view-ollama .action_button { /* For buttons that take full width or are main actions */
    width: 100%;
    margin-top: 1; /* If it's after a section label or input */
}
#llm-view-ollama .full_width_button {
    width: 100%;
    margin-top: 1;
}

#llm-view-ollama .delete_button Button { /* Specific styling for delete button if needed */
    background: $error-darken-1;
    color: $text;
}
#llm-view-ollama .delete_button Button:hover {
    background: $error;
}

/* New Status TextArea */
.ollama-status-textarea {
    width: 100%;
    height: 3; /* Small, 1-2 lines of text */
    border: round $primary-darken-1;
    background: $surface;
    margin-top: 1; /* Space above status */
    margin-bottom: 1; /* Space below status, before main output or next section */
    padding: 0 1;
    color: $text-muted; /* Subdued text color for status */
}

/* Output TextAreas */
#llm-view-ollama .output_textarea_medium { /* For JSON lists, model info */
    width: 100%;
    height: 25; /* Or adjust as needed */
    border: round $primary;
    background: $panel;
    margin-bottom: 1; /* Space before next element/spacer */
}
#llm-view-ollama .output_textarea_small { /* For embeddings */
    width: 100%;
    height: 6;
    border: round $primary;
    background: $panel;
    margin-bottom: 1;
}

/* Main RichLog for streaming */
#llm-view-ollama .log_output_large { /* Renamed from .log_output for specificity */
    width: 100%;
    height: 10; /* Make it taller */
    border: panel $primary-darken-2;
    background: $background-darken-1; /* Darker background for log */
}

/* Spacer element */
.ollama-spacer {
    height: 1; /* Creates 1 cell of vertical space */
    width: 100%;
}

/* OLLAMA compact layout grid */
.ollama-button-bar {
    layout: horizontal;
    height: auto;
    width: 100%;
    margin: 1 0;
    align-horizontal: center;
}
.ollama-button-bar Button {
    width: 1fr;
    margin: 0 1;
}

.ollama-actions-grid {
    layout: horizontal;
    height: auto;
    align-vertical: top; /* Align columns to the top */
    margin-bottom: 1;
}

.ollama-actions-column {
    layout: vertical;
    width: 1fr;
    height: 100%; /* Make columns fill parent height */
    padding: 1;
    border: round $panel-lighten-1;
    margin: 0 1;
}
.ollama-actions-column:first-of-type {
    margin-left: 0;
}
.ollama-actions-column:last-of-type {
    margin-right: 0;
}

.column-title {
    text-style: bold underline;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

/* Override input container margin inside a column */
.ollama-actions-column .input_action_container {
    margin-bottom: 1;
}
.ollama-actions-column .full_width_button {
    margin-top: 0; /* Tighten up space for buttons below inputs */
}

/* --- End of LLM Management Tab --- */

/* ===== MODULE: features/_tools-settings.tcss ===== */
/* ========================================
 * FEATURES: Tools and Settings
 * ======================================== 
 * Tools and Settings tab
 * ======================================== */

/* --- Tools & Settings Tab --- */
#tools_settings-window { /* Matches TAB_TOOLS_SETTINGS */
    layout: horizontal; /* Main layout for this tab */
}

.tools-nav-pane {
    dock: left;
    width: auto; /* Changed from 25% */
    min-width: 25; /* Example min-width */
    max-width: 60; /* Example max-width */
    height: 100%;
    background: $boost; /* Or $surface-lighten-1 */
    padding: 1;
    border-right: thick $background-darken-1;
    overflow-y: auto;
    overflow-x: hidden;
}

.tools-nav-pane .ts-nav-button { /* Style for navigation buttons */
    width: 100%;
    margin-bottom: 1;
    border: none; /* Cleaner look for nav buttons */
    height: 3;
}
.tools-nav-pane .ts-nav-button:hover {
    background: $surface-lighten-1;
    color: $text;
}

.tools-nav-pane .ts-nav-button.active-nav {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.tools-content-pane {
    width: 1fr; /* Takes remaining horizontal space */
    height: 100%;
    padding: 1 2; /* Padding for the content area */
    overflow-y: auto; /* If content within sub-views might scroll */
}

/* Ensure ContentSwitcher fills the pane */
.tools-content-pane ContentSwitcher {
    height: 100%;
    width: 100%;
}

.ts-view-area { /* Class for individual content areas */
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    /* Let ContentSwitcher handle visibility */
}

/* Container height fixes */
.general-settings-container {
    height: 100%;
    width: 100%;
    overflow-y: auto;
    overflow-x: hidden;
}

.config-file-settings-container {
    height: 100%;
    width: 100%;
    overflow-y: auto;
    overflow-x: hidden;
}

/* Ensure TabbedContent fills container */
.config-file-settings-container TabbedContent {
    height: 100%;
    width: 100%;
}

.config-file-settings-container TabPane {
    height: 100%;
    width: 100%;
}

/* Specific config tabs styling */
#config-tabs {
    height: 100%;
    width: 100%;
    min-height: 30;
}

/* Inner container for config file settings */
.config-file-settings-inner {
    height: 100%;
    width: 100%;
    layout: vertical;
}

/* Settings form styling */
.section-title {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
    text-align: center;
    height: auto;
}

.section-description {
    color: $text-muted;
    margin-bottom: 2;
    text-align: center;
    text-style: italic;
    height: auto;
}

.subsection-title {
    text-style: bold;
    color: $secondary;
    margin: 2 0 1 0;
}

.settings-group {
    margin-bottom: 2;
    padding: 1;
    background: $surface;
    border: round $primary-background;
    height: auto;
}

.settings-label {
    margin-bottom: 1;
    text-style: bold;
}

.settings-select, .settings-input {
    width: 100%;
    margin-bottom: 1;
    min-height: 3;
    height: auto;
}

.checkbox-group {
    margin-bottom: 1;
}

.warning-text {
    color: $warning;
    margin-bottom: 1;
    text-style: italic;
}

.settings-actions {
    margin-top: 2;
    layout: horizontal;
    height: auto;
    align: center middle;
}

.settings-actions Button {
    margin: 0 1 0 0;
}

/* Configuration file settings specific */
.config-file-settings-container {
    height: 100%;
    width: 100%;
}

.config-editor {
    height: 20;
    min-height: 20;
    border: round $primary;
    background: $panel;
    margin-bottom: 1;
}

.config-button-container {
    layout: horizontal;
    height: auto;
    margin-top: 1;
    align: center middle;
}

.config-button-container Button {
    margin: 0 1 0 0;
}

.tab-description {
    color: $text-muted;
    margin-bottom: 1;
    text-style: italic;
}

/* --- Core Settings Styles --- */
.core-settings-container {
    padding: 1 2;
    width: 100%;
    height: 100%;
}

.section-title {
    text-style: bold;
    text-align: center;
    margin-bottom: 2;
    color: $primary;
}

.subsection-title {
    text-style: bold;
    margin: 2 0 1 0;
    color: $secondary;
}

.settings-group {
    background: $surface;
    padding: 1;
    margin-bottom: 2;
    border: round $primary-background;
}

.settings-label {
    margin: 1 0 0 0;
    color: $text-muted;
}

.settings-input {
    width: 100%;
    margin: 0 0 1 0;
}

.settings-select {
    width: 100%;
    margin: 0 0 1 0;
}

.settings-subsection-title {
    color: $text;
    text-style: bold;
    margin-top: 1;
    margin-bottom: 1;
}

.settings-note {
    color: $text-muted;
    text-style: italic;
    margin-top: 1;
    margin-bottom: 1;
    padding: 0 1;
}

.checkbox-group {
    layout: horizontal;
    margin: 0 0 1 0;
}

.checkbox-group Checkbox {
    margin-right: 2;
}

.settings-actions {
    layout: horizontal;
    margin-top: 2;
    align: center middle;
}

.settings-actions Button {
    margin: 0 1;
    min-width: 15;
}

/* --- End Core Settings Styles ---*/

/* --- Config Form Styles --- */
.config-form {
    width: 100%;
    height: auto;
    padding: 1 2;
    overflow-y: auto;
}

.form-label {
    margin-top: 1;
    margin-bottom: 0;
    text-style: bold;
    color: $text-muted;
}

.form-description {
    color: $text-muted;
    margin-bottom: 2;
    text-style: italic;
}

.form-section-title {
    text-style: bold;
    color: $primary;
    margin: 2 0 1 0;
    border-bottom: solid $primary;
    padding-bottom: 0;
}

.form-subsection-title {
    text-style: bold;
    color: $secondary;
    margin: 1 0 1 0;
}

.form-actions {
    layout: horizontal;
    margin-top: 2;
    height: 3;
    width: 100%;
    align: center middle;
}

.form-actions Button {
    margin: 0 1 0 0;
    min-width: 15;
}

/* TextArea styling for config forms */
.config-form TextArea {
    width: 100%;
    height: 10;
    margin-bottom: 1;
    border: round $primary;
    background: $panel;
}

.system-prompt-textarea {
    height: 15;
}

.provider-models-textarea {
    height: 5;
}

/* Collapsible styling in config forms */
.config-form Collapsible {
    margin-bottom: 1;
    border: round $primary-background;
    background: $surface;
}

.config-form Collapsible > CollapsibleTitle {
    background: $boost;
    padding: 0 1;
}

/* Help text */
.help-text {
    color: $text-muted;
    margin-bottom: 1;
    text-style: italic;
}

/* Database status */
.db-status {
    color: $text-muted;
    margin-bottom: 1;
}

/* ===== MODULE: features/_ingest.tcss ===== */
/* ========================================
 * FEATURES: Ingest
 * ======================================== 
 * Media ingestion tab styles
 * ======================================== */

/* --- Ingest Content Tab --- */
#ingest-window { /* Matches TAB_INGEST */
    layout: vertical !important; /* Override .window class */
    height: 100%;
    width: 100%;
}

/* Override the horizontal layout from .window class */
#ingest-window.window {
    layout: vertical !important;
}
.tldw-api-media-specific-options { /* Common class for specific option blocks */
    padding: 1;
    border: round $surface;
    margin-top: 1;
    margin-bottom: 1;
}

/* Added to ensure initially hidden specific options are indeed hidden */
.tldw-api-media-specific-options.hidden {
     display: none;
}

.ingest-nav-pane { /* Style for the left navigation pane */
    dock: left;
    width: 25%;
    min-width: 20;
    max-width: 40;
    height: 100%;
    background: $boost; /* Or a slightly different shade */
    padding: 1;
    border-right: thick $background-darken-1;
    /* Removed overflow properties - let VerticalScroll handle scrolling */
}

.ingest-nav-pane .ingest-nav-button { /* Style for navigation buttons */
    width: 100%;
    margin-bottom: 1;
    border: none;
    height: 3;
}
.ingest-nav-pane .ingest-nav-button:hover {
    background: $surface-lighten-1;
    color: $text;
}
/* Active state for selected ingest nav button */
.ingest-nav-pane .ingest-nav-button.active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Collapsible sidebar styles */
.ingest-nav-pane.collapsed {
    width: 4;
    min-width: 4;
    padding: 1 0;
}

.nav-header {
    width: 100%;
    height: 3;
    margin-bottom: 1;
}

.nav-toggle-button {
    width: 3;
    height: 3;
    min-width: 3;
    padding: 0;
    text-align: center;
}

/* Hide text when collapsed */
.collapsed-hidden {
    display: none;
}

/* Adjust button appearance when collapsed */
.ingest-nav-pane.collapsed .ingest-nav-button {
    width: 3;
    padding: 0;
    /* Show only first letter or icon */
    overflow: hidden;
}

/* Style for sidebar section titles */
.ingest-nav-pane .sidebar-title {
    text-style: bold;
    color: $primary;
    margin-top: 2;
    margin-bottom: 1;
    padding-left: 1;
    border-left: thick $accent;
}
/* Active state for selected ingest nav button (optional) */
/* .ingest-nav-pane .ingest-nav-button.-active-view {
    background: $accent-darken-1;
    color: $text;
} */

.ingest-content-pane { /* Style for the right content display area */
    width: 1fr;
    height: 100%;
    padding: 1 2;
    /* Removed overflow - let child VerticalScroll widgets handle scrolling */
}

.ingest-view-area { /* Common class for individual content areas */
    width: 100%;
    height: 100%;
}
.ingest-label {
    margin-top: 1;
    margin-bottom: 0;
}
.ingest-selected-files-list {
    min-height: 5;
    max-height: 10;
    height: auto;
    border: round $ds-focus-accent;
    margin-bottom: 1;
    background: $surface;
}
.LocalIngestionPanel .file-selection-container {
    height: 1fr;
    min-height: 15;
    border: solid $primary;
    margin-bottom: 1;
    padding: 1;
}
.ingest-preview-area {
    height: 1fr;
    min-height: 10;
    border: round $primary-lighten-2;
    padding: 1;
    margin-bottom: 1;
    background: $surface;
}
.ingest-preview-area > Static#ingest-prompts-preview-placeholder {
    color: $text-muted;
    width: 100%;
    text-align: center;
    padding: 2 0;
}
.ingest-status-area {
    min-height: 5;
    max-height: 15;
    height: auto;
    margin-top: 1;
}

.prompt-preview-item {
    border: panel $background-lighten-2;
    padding: 1;
    margin-bottom: 1;
}
.prompt-preview-item .prompt-title {
    text-style: bold;
}
.prompt-preview-item .prompt-field-label {
    text-style: italic;
    color: $text-muted;
}
.prompt-preview-item Markdown {
    background: $surface-darken-1;
    padding: 0 1;
    margin-top: 1;
    margin-bottom: 1;
    border: solid $primary-darken-1; /* Use 'solid' instead of 'narrow' */
    max-height: 10;
    overflow-y: auto;
}
.prompt-preview-item .prompt-details-text {
    max-height: 5;
    overflow-y: auto;
    background: $surface;
    padding: 0 1;
    border: dashed $primary-darken-2; /* Use 'dashed' instead of 'dotted' */
    margin-bottom: 1;
}

/* Ensure VerticalScroll containers fill their parent */
.ingest-view-area VerticalScroll {
    height: 1fr;
    width: 100%;
}

/* Ensure VerticalScroll containers fill available space */
VerticalScroll.ingest-view-area {
    height: 1fr;
    width: 100%;
}

VerticalScroll.ingest-form-scrollable {
    height: 1fr;
    width: 100%;
}

/* Scrollable form container needs padding to prevent content cutoff */
.ingest-form-scrollable {
    height: 100%;
    overflow-y: auto;
    padding: 1;
}

/* Removed .ingest-media-tab-content - no longer needed since parent is VerticalScroll */

.ingest-file-section {
    margin-bottom: 2;
    padding: 1;
    border: round $primary;
    background: $surface;
}

.ingest-options-section {
    border: round $primary;
    padding: 1;
    margin-bottom: 2;
    background: $surface;
}

.ingest-metadata-section {
    margin-bottom: 2;
    padding: 1;
    border: round $primary;
    background: $surface;
}

.ingest-action-section {
    border-top: solid $primary;
    padding-top: 1;
    padding: 1;
}

.ingest-controls-row {
    margin-bottom: 1;
    height: 3;
}

.ingest-controls-row Button {
    height: 3;
    min-height: 3;
}

.ingest-url-button {
    width: auto;
    height: 3;
    margin-bottom: 1;
}

.ingest-form-row {
    margin-top: 1;
}

.ingest-form-col {
    width: 50%;
    padding-right: 1;
}

.title-author-row {
    margin-bottom: 1;
}

/* Ensure title/author input boxes are visible */
.title-author-row Input {
    height: 3;
    width: 100%;
    margin-bottom: 1;
}

.ingest-textarea-small {
    min-height: 3;
    max-height: 8;
    height: auto;
    margin-bottom: 1;
}

.ingest-textarea-medium {
    min-height: 10;
    max-height: 20;
    height: auto;
    margin-bottom: 1;
}

.ingest-textarea-large {
    min-height: 15;
    max-height: 30;
    height: auto;
    margin-bottom: 1;
}

/* Responsive textarea that grows with content */
.ingest-textarea-responsive {
    min-height: 5;
    height: auto;
    margin-bottom: 1;
}

/* All ingest views are controlled programmatically */
.ingest-view-area {
    /* display controlled by app.py watcher */
    height: 100%;
    width: 100%;
}

/* --- Visibility styles for ingest views --- */
/* Views are controlled programmatically via styles.display */

/* --- Tabbed Ingest Window Styles --- */
#ingest-media-tabs {
    height: 100%;
    width: 100%;
}

#ingest-media-tabs TabPane {
    padding: 0;
    height: 100%;
}

/* Ensure the IngestWindowTabbed container fills available space */
IngestWindowTabbed {
    height: 1fr;
    width: 100%;
    layout: vertical;
}

/* Ensure TabbedContent in ingest window displays properly */
#ingest-window TabbedContent {
    height: 1fr;  /* Use fr unit for flexible sizing */
    width: 100%;
}

.media-tab-container {
    height: 1fr;  /* Use fr unit instead of 100% */
    padding: 1;
}

.source-toggle-container {
    dock: top;
    height: auto;
    padding: 1;
    margin-bottom: 1;
    border-bottom: solid $primary;
}

.tab-title {
    text-style: bold;

    margin-bottom: 1;
}

.source-toggle {
    layout: horizontal;
    height: auto;
    margin-top: 1;
}

.source-toggle RadioButton {
    margin-right: 2;
}

.source-content {
    height: 1fr;
    width: 100%;
    overflow-y: auto;
}

/* Ensure content areas within tabs fill space */
.ingest-form-scrollable {
    height: 1fr;
    width: 100%;
}

/* Ensure TabbedContent and its children are visible and properly sized */
#ingest-media-tabs {
    height: 1fr !important;
    width: 100% !important;
}

#ingest-media-tabs TabPane {
    height: 100% !important;
    width: 100% !important;
    padding: 1;
}

/* Ensure all containers within TabPane are visible */
#ingest-media-tabs TabPane > * {
    display: block !important;
    visibility: visible !important;
}

/* Ensure tab panes have proper sizing */
#ingest-media-tabs TabPane Container {
    height: 100%;
    width: 100%;
}

#ingest-media-tabs TabPane Vertical {
    height: 100%;
    width: 100%;
}

#ingest-media-tabs TabPane VerticalScroll {
    height: 1fr;
    width: 100%;
    min-height: 10; /* Ensure minimum height */
}

.source-content.hidden {
    display: none;
}

/* Compact file lists for better space usage */
.ingest-selected-files-list {
    min-height: 3;
    max-height: 8;
    height: auto;
    border: round $ds-focus-accent;
    margin-bottom: 1;
    background: $surface;
}

/* Status section at top of forms */
.status-dashboard {
    width: 100%;
    height: auto;
    max-height: 8;      /* Prevent status from taking too much space */
    min-height: 3;
    background: $surface;
    border: round $primary;
    padding: 1;
    margin-bottom: 1;
}

/* Mode-specific visibility controls */
.simple-mode .advanced-only {
    display: none !important;
}

.advanced-mode .advanced-only {
    display: block !important;
}

/* URL input always visible */
.url-input-section {
    display: block;
    margin-top: 1;
    padding: 1;
    border: round $primary;
    background: $surface;
}

/* Simplified form sections */
.essential-fields {
    border: round $accent;
    padding: 1;
    margin-bottom: 2;
    background: $surface-lighten-1;
}

/* Placeholder text */
.placeholder-text {
    color: $text-muted;
    text-align: center;
    padding: 4;
}

/* Mode toggle styles */
.mode-toggle-container {
    dock: top;
    padding: 1;
    margin-bottom: 1;
}

.mode-toggle {
    layout: horizontal;
    height: auto;
}

.mode-toggle RadioButton {
    margin-right: 2;
}

/* File selection row */
.file-selection-row {
    height: 3;
    margin-bottom: 1;
}

.file-selection-row Button {
    margin-right: 1;
}

/* Enhanced file list with metadata */
.file-list-with-metadata {
    min-height: 5;
    max-height: 10;
    border: round $primary;
    background: $surface;
}

/* Metadata row */
.metadata-row {
    margin-top: 1;
    margin-bottom: 1;
}

.metadata-col {
    width: 50%;
    padding-right: 1;
}

/* Process button */
.process-button {
    width: 100%;
    height: 4;
    margin-top: 2;
    text-style: bold;
}

/* Basic options container */
.basic-options-container {
    border: round $surface;
    padding: 1;
    margin-top: 1;
    background: $surface-lighten-1;
}

/* Advanced options container */
.advanced-options-container {
    margin-top: 1;
}

.advanced-options-container.hidden {
    display: none;
}

/* Time range row */
.time-range-row {
    margin-top: 1;
}

.time-col {
    width: 50%;
    padding-right: 1;
}

/* Chunk settings row */
.chunk-settings-row {
    margin-top: 1;
}

.chunk-col {
    width: 50%;
    padding-right: 1;
}

/* Form labels */
.form-label-primary {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
}

/* Status Dashboard Styles */
.status-dashboard-container {
    border: round $primary;
    background: $surface;
    padding: 1;
    margin-bottom: 1;
}

.status-main-row {
    height: 3;
    align: left middle;
}

.status-message {
    width: 1fr;
    text-style: bold;
}

.file-counter {
    width: auto;
    margin-left: 2;
    color: $text-muted;
}

.time-display {
    width: auto;
    margin-left: 2;
    color: $text-muted;
}

.action-buttons {
    width: auto;
    dock: right;
    layout: horizontal;
}

.action-buttons.hidden {
    display: none;
}

.small-button {
    height: 3;
    min-width: 8;
    margin-left: 1;
}

.small-button.hidden {
    display: none;
}

/* Progress bar in dashboard */
.status-dashboard-container ProgressBar {
    margin-top: 1;
    height: 1;
}

.status-dashboard-container ProgressBar.hidden {
    display: none;
}

/* Alert container */
.alert-container {
    margin-top: 1;
    padding: 1;
    border: round $error;
    background: $error 10%;
}

.alert-container.hidden {
    display: none;
}

.alert-messages {
    color: $text;
    max-height: 6;
    overflow-y: auto;
}

/* Enhanced File List Styles */
.file-list-enhanced {
    border: round $primary;
    background: $surface;
    padding: 0;
}

.file-items-container {
    max-height: 10;
    overflow-y: auto;
    padding: 1;
}

.file-list-item-container {
    padding: 1;
    margin-bottom: 1;
    border: round $surface-lighten-2;
    background: $surface-lighten-1;
    height: auto;
}

.file-list-item-container:hover {
    background: $surface-lighten-2;
    border: round $primary;
}

.file-info-main {
    width: 1fr;
}

.file-name-row {
    height: auto;
    margin-bottom: 0;
}

.file-icon {
    width: 3;
    text-align: center;
}

.file-name {
    width: 1fr;
    text-style: bold;
    overflow: hidden;
    text-overflow: ellipsis;
}

.file-metadata {
    color: $text-muted;

    margin-left: 3;
}

.file-remove-button {
    width: 3;
    height: 3;
    min-width: 3;
    margin: 0;
    padding: 0;
    text-align: center;
}

.no-files-message {
    text-align: center;
    color: $text-muted;
    padding: 3;
}

.file-list-summary {
    dock: bottom;
    height: 3;
    padding: 1;
    border-top: solid $primary;
    background: $surface-darken-1;
    text-align: center;
    color: $text-muted;
}

/* --- END OF INTEGRATED NEW CSS --- */

/* ===== MODULE: features/_ingest_tldw_api_tabs.tcss ===== */
/* tldw_chatbook/css/features/_ingest_tldw_api_tabs.tcss */
/* Styles for the IngestTldwApiTabbedWindow */

#tldw-api-tabbed-window {
    height: 100%;
    width: 100%;
    display: block;
}

/* Ensure the parent container for tldw API view has proper dimensions */
#ingest-view-tldw-api {
    height: 100%;
    width: 100%;
    overflow: hidden;
}

#ingest-view-tldw-api > #tldw-api-tabbed-window {
    height: 100%;
    width: 100%;
}

.window-title {
    text-style: bold;
    text-align: center;
    padding: 1 0;
    background: $primary;
    color: $text;
}

.back-button {
    margin: 1 0;
    dock: top;
    width: auto;
    align: left middle;
}

#tldw-api-tabs {
    height: 100%;
    margin: 0;
}

#tldw-api-tabs TabPane {
    padding: 0;
    height: 100%;
}

/* Ensure the forms inside tabs are scrollable */
#tldw-api-tabs .ingest-form-scrollable {
    height: 100%;
    overflow-y: auto;
    padding: 1;
}

/* Ensure VerticalScroll containers fill their parent */
#tldw-api-tabs VerticalScroll {
    height: 100%;
    width: 100%;
}

/* Style for the tab content area */
.tldw-api-media-specific-options {
    margin-top: 2;
    padding: 1;
    border: round $primary-lighten-1;
    background: $surface;
}

/* Ensure submit buttons are visible */
#tldw-api-tabs .ingest-submit-button {
    margin-top: 2;
    width: 100%;
}

/* Style the loading indicator */
#tldw-api-tabs LoadingIndicator {
    align: center middle;
    margin: 1 0;
}

/* Style the status area */
#tldw-api-tabs .ingest-status-area {
    min-height: 10;
    max-height: 20;
    margin-top: 1;
}

/* Hidden class for dynamic elements */
#tldw-api-tabs .hidden {
    display: none;
}

/* ===== MODULE: features/_evaluation_v2.tcss (NOT FOUND) ===== */

/* ===== MODULE: features/_evaluation_unified.tcss ===== */
/* ========================================
 * FEATURES: Unified Evaluation Dashboard
 * ======================================== 
 * Single-page responsive design with collapsibles
 * Based on original UX design specifications
 * ======================================== */

/* --- Main Container --- */
.evals-main-container {
    layout: vertical;
    height: 100%;
}

/* --- Scrollable Dashboard --- */
.evals-unified-dashboard {
    background: $background;
    height: 1fr;
}

/* --- Quick Start Bar --- */
.quick-start-bar {
    height: auto;
    background: $surface;
    border-bottom: solid $primary;
    padding: 1;
    margin-bottom: 1;
}

.dashboard-title {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
}

.quick-actions {
    layout: horizontal;
    height: 3;
    margin-bottom: 1;
}

.quick-template-btn {
    margin-right: 1;
    min-width: 20;
}

/* Drop zone styling */
.drop-zone {
    layout: horizontal;
    height: 3;
    background: $panel;
    border: dashed $primary;
    padding: 0 2;
    align: center middle;
    margin: 1 0;
}

.drop-zone:hover {
    background: $boost;
    border: solid $primary;
}

.drop-text {
    margin-right: 1;
}

.inline-btn {
    height: 2;
    min-width: 10;
}

.suggestion-text {
    color: $text-muted;
    text-style: italic;
    margin-top: 1;
}

/* --- Main Content Area --- */
.main-content {
    padding: 1;
}

/* Ensure VerticalScroll works properly inside the evals dashboard.
   This selector MUST stay scoped: a bare `VerticalScroll` rule applies
   app-wide and (because stylesheet rules always outrank widget DEFAULT_CSS
   in Textual, regardless of specificity) silently overrides every widget's
   own `height: 1fr` sizing, pushing follow-on siblings off-screen. */
.evals-main-container VerticalScroll {
    height: 100%;
}

/* Make sure the entire window uses available height */
EvalsWindow {
    height: 100%;
}

/* --- Collapsible Sections --- */
Collapsible {
    margin-bottom: 1;
    border: tall $surface;
    background: $panel;
}

Collapsible > Container {
    padding: 1;
}

Collapsible.-collapsed {
    margin-bottom: 1;
}

/* Task Creation Form */
.task-creation-form {
    padding: 1;
}

.template-editor {
    height: 6;
    margin: 1 0;
}

.metrics-selection {
    layout: horizontal;
    height: 3;
    margin: 1 0;
}

.metrics-selection Checkbox {
    margin-right: 2;
}

.task-actions {
    layout: horizontal;
    margin-top: 2;
}

.task-actions Button {
    margin-right: 1;
}

/* Quick Setup Form */
.quick-setup-form {
    padding: 1;
}

.config-grid {
    layout: grid;
    grid-columns: 1fr 1fr;
    grid-gutter: 1;
    margin-bottom: 2;
}

/* Note: Textual doesn't support @media queries
   Use reactive attributes or resize events for responsive design */

.cost-estimation-box {
    background: $surface;
    padding: 1;
    margin: 1 0;
    border: tall $secondary;
}

.cost-display {
    text-style: bold;
    color: $success;
}

.cost-warning {
    color: $warning;
    margin-top: 1;
}

.cost-warning.hidden {
    display: none;
}

/* Template Grid */
.template-grid {
    layout: grid;
    grid-columns: 1fr 1fr;
    grid-gutter: 1;
    margin-top: 1;
}

.template-card {
    height: 5;
    padding: 1;
    background: $surface;
    border: tall $primary;
    text-align: center;
}

.template-card:hover {
    background: $boost;
    border: thick $primary;
}

/* Advanced Configuration */
.advanced-config-form {
    padding: 1;
}

.param-grid {
    layout: grid;
    grid-columns: auto 1fr;
    grid-gutter: 1;
    margin-bottom: 2;
}

.system-prompt-editor {
    height: 4;
    margin: 1 0;
}

.config-toggles {
    layout: horizontal;
    margin-top: 1;
}

.config-toggles Checkbox {
    margin-right: 2;
}

/* Active Evaluations */
.active-eval-empty {
    min-height: 10;
    align: center middle;
}

.empty-message {
    color: $text-muted;
    text-align: center;
}

/* Action Bar */
.action-bar {
    layout: horizontal;
    background: $surface;
    padding: 1;
    margin: 2 0;
    border: tall $primary;
    align: center middle;
}

.action-button {
    margin-right: 1;
    min-width: 12;
}

.action-button.primary {
    background: $primary;
    color: $text;
}

.action-button.primary.large {
    min-width: 20;
    height: 3;
    text-style: bold;
}

.keyboard-hint {
    color: $text-muted;
    margin-left: 2;
}

/* Results Dashboard */
.results-dashboard {
    background: $panel;
    padding: 2;
    margin-top: 2;
    border: tall $primary;
}

.section-title {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
}

.results-header {
    layout: horizontal;
    height: 3;
    margin-bottom: 1;
    align: left middle;
}

.results-header Static {
    width: 1fr;
}

.results-header Select {
    width: 20;
}

.results-list {
    height: 15;
    background: $surface;
    border: tall $secondary;
    margin-bottom: 2;
}

/* Quick Stats Grid */
.quick-stats-grid {
    layout: grid;
    grid-columns: 1fr 1fr 1fr;
    grid-gutter: 1;
}

.stat-card {
    background: $surface;
    padding: 1;
    border: tall $secondary;
    text-align: center;
}

.stat-title {
    color: $text-muted;
    margin-bottom: 1;
}

.stat-value {
    text-style: bold;
    color: $primary;
}

/* Model/Dataset Management Sections */
.model-management-form,
.dataset-management-form {
    padding: 1;
}

.button-row {
    layout: horizontal;
    margin-bottom: 1;
}

.button-row Button {
    margin-right: 1;
}

.models-container,
.datasets-container {
    min-height: 10;
    background: $surface;
    border: tall $secondary;
    padding: 1;
}

/* Status Bar */
.status-bar {
    height: 3;
    background: $surface;
    border-top: solid $primary;
    padding: 0 2;
    layout: horizontal;
    align: left middle;
}

.status-text {
    width: 1fr;
}

.connection-indicator {
    width: 20;
    text-align: right;
}

/* Responsive Adjustments - handled in Python code via resize events */
/* For narrow screens, switch grids to single column */

/* Utility Classes */
.hidden {
    display: none;
}

.subsection-title {
    text-style: bold;
    color: $secondary;
    margin: 1 0;
}

.help-text {
    color: $text-muted;
    text-style: italic;
}

/* Disabled States */
Button:disabled {
    opacity: 0.5;
}

/* Loading States */
.loading {
    opacity: 0.6;
}

/* Error States */
.error {
    border: tall $error;
    background: $error 10%;
}

/* ===== MODULE: features/_metrics.tcss ===== */
/* ========================================
 * FEATURES: Metrics
 * ======================================== 
 * Metrics display styles
 * ======================================== */

/* --- Metrics Screen Styling --- */
MetricsScreen {
    padding: 1 2; /* Add some padding around the screen content */
    /* layout: vertical; /* MetricsScreen is a Static, VerticalScroll handles layout */
    /* align: center top; /* If needed, but VerticalScroll might handle this */
}

#metrics-container {
    padding: 1;
    /* border: round $primary-lighten-2; /* Optional: a subtle border */
    /* background: $surface; /* Optional: a slightly different background */
}

/* Styling for individual metric labels within MetricsScreen */
MetricsScreen Label {
    width: 100%;
    margin-bottom: 1; /* Space between metric items */
    padding: 1;       /* Padding inside each label's box */
    background: $panel-lighten-1; /* A slightly lighter background for each item */
    border: round $primary-darken-1; /* Border for each item */
    /* Textual CSS doesn't allow direct styling of parts of a Label's text (like key vs value) */
    /* The Python code uses [b] for keys, which Rich Text handles. */
}

/* Style for the title label: "Application Metrics" */
/* This targets the first Label directly inside the VerticalScroll with ID metrics-container */
#metrics-container > Label:first-of-type {
    text-style: bold underline;
    align: center middle;
    padding: 1 0 2 0; /* More padding below the title */
    background: transparent; /* No specific background for the title itself */
    border: none; /* No border for the title itself */
    margin-bottom: 2; /* Extra space after the title */
}

/* Style for error messages within MetricsScreen */
/* These require the Python code to add the respective class to the Label widget */
MetricsScreen Label.-error-message {
    color: $error; /* Text color for errors */
    background: $error 20%; /* Background for error messages, e.g., light red. USES $error WITH 20% ALPHA */
    /* border: round $error; /* Optional: border for error messages */
    text-style: bold;
}

/* Style for info messages (e.g. "file empty") within MetricsScreen */
MetricsScreen Label.-info-message {
    color: $text-muted; /* Or another color that indicates information */
    background: $panel; /* A more subdued background, or $transparent */
    /* border: round $primary-lighten-1; /* Optional: border for info messages */
    text-style: italic;
}
/* --- End of Metrics Screen Styling --- */

/* ===== MODULE: features/_embeddings.tcss ===== */
/* ========================================
 * Embeddings Feature Styles
 * ======================================== */

/* ========================================
 * Main Embeddings Window Container
 * ======================================== */

/* Main window layout that contains navigation and content */
EmbeddingsWindow {
    layout: horizontal;
    height: 100%;
    width: 100%;
}

/* Navigation pane (left sidebar) */
#embeddings-nav-pane {
    dock: left;
    width: auto;
    min-width: 25;
    max-width: 50;
    background: $boost;
    padding: 1 2;
    border-right: thick $background-darken-1;
    height: 100%;
    overflow-y: auto;
}

/* Content pane (main area) */
#embeddings-content-pane {
    width: 1fr;
    height: 100%;
    overflow-y: auto;  /* Allow vertical scrolling on the content pane itself */
    overflow-x: hidden;
}

/* View area containers */
.embeddings-view-area {
    width: 100%;
    height: 100%;
    display: none;
}

/* Both views should be properly sized when shown by the watcher */
#embeddings-view-create {
    height: 100%;
}

#embeddings-view-manage {
    height: 100%;
}

/* Ensure VerticalScroll works properly as direct child */
.embeddings-view-area > VerticalScroll {
    height: 100%;
}

/* Navigation buttons */
.embeddings-nav-button {
    width: 100%;
    margin-bottom: 1;
    height: 3;
    border: none;
    background: $panel;
    color: $text-muted;
    text-align: left;
    padding: 0 1;
}

.embeddings-nav-button:hover {
    background: $surface-lighten-1;
    color: $text;
}

.embeddings-nav-button:focus,
.embeddings-nav-button.-active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* ========================================
 * Embeddings Creation Section
 * ======================================== */

.embeddings-creation-scroll {
    width: 100%;
    height: 100%;
    padding: 1 2 3 2;  /* Added extra bottom padding to ensure buttons are visible */
}

.embeddings-form-title {
    text-style: bold;
    text-align: center;
    background: $primary-darken-2;
    color: $text;
    padding: 0 1;
    margin-bottom: 1;
    border: round $primary-darken-1;
    width: 100%;
    height: 3;
}

.embeddings-section-title {
    text-style: bold;
    margin-top: 2;
    margin-bottom: 1;
    background: $primary-background-lighten-1;
    padding: 0 1;
    border-left: thick $accent;
    width: 100%;
}

.embeddings-form-row {
    layout: horizontal;
    margin-bottom: 1;
    height: 3;
    align: left middle;
    width: 100%;
}

.embeddings-form-label {
    width: 30%;
    min-width: 25;
    max-width: 40;
    padding-right: 1;
    text-align: right;
}

.embeddings-form-control {
    width: 1fr;
}

.embeddings-form-full-row {
    width: 100%;
    margin-bottom: 1;
}

/* Ensure inputs and selects use full available width */
.embeddings-form-control Input,
.embeddings-form-control Select,
.embeddings-form-control TextArea {
    width: 100%;
}

/* Ensure rules take full width */
.embeddings-form-container Rule {
    width: 100%;
    margin: 1 0;
}

.embeddings-input-source-container {
    width: 100%;
    padding: 1;
    border: round $surface;
    margin-bottom: 1;
}

.embeddings-file-list {
    height: 10;
    width: 100%;
    border: round $primary;
    background: $surface;
    padding: 1;
    margin-bottom: 1;
}

.embeddings-chunk-preview {
    min-height: 10;
    max-height: 20;
    border: round $primary-lighten-1;
    background: $surface-darken-1;
    padding: 1;
    margin-top: 1;
}

.embeddings-progress-container {
    margin-top: 2;
    padding: 1;
    border: round $primary;
    background: $surface;
}

.embeddings-progress-label {
    text-align: center;
    margin-bottom: 1;
}

/* Action buttons container */
.embeddings-action-container {
    width: 100%;
    padding: 1 2;
    margin-top: 2;
    margin-bottom: 2;
}

.embeddings-button-row {
    layout: horizontal;
    align: center middle;
    width: 100%;
    height: 3;
}

.embeddings-action-button {
    margin: 0 1;
    min-width: 20;
    height: 3;
}

.embeddings-status-output {
    margin-top: 2;
    margin-bottom: 2;  /* Added bottom margin for better visibility */
    min-height: 8;
    max-height: 15;
    border: round $primary-background-lighten-2;
    padding: 1;
    background: $surface;
}

/* ContentSwitcher handles visibility automatically */
#embeddings-source-switcher {
    width: 100%;
    height: auto;
}

#embeddings-progress-container {
    display: none;
}

.embeddings-progress-container {
    display: none;
    width: 100%;
    padding: 1;
    background: $surface;
    border: round $primary;
    margin-top: 2;
}

.embeddings-progress-label {
    text-align: center;
    margin-bottom: 1;
    text-style: bold;
}

/* Mode-specific containers */
.embeddings-mode-container {
    width: 100%;
    display: none;
}

#embeddings-search-container {
    display: block;  /* Default mode */
}

#embeddings-specific-container {
    display: none;
}

#embeddings-keywords-container {
    display: none;
}

/* RadioSet styling */
#embeddings-db-mode-set {
    layout: horizontal;
    margin: 1 0;
    width: 100%;
    padding: 1;
    background: $surface;
    border: round $primary;
}

#embeddings-db-mode-set RadioButton {
    margin-right: 2;
    padding: 0 1;
}

.embeddings-db-results-container {
    width: 100%;
    margin-top: 1;
    border: round $primary;
    background: $surface;
    padding: 1;
    /* Allow reasonable height for the table */
    min-height: 10;
    max-height: 40;
    overflow-y: auto;
}

#embeddings-db-results {
    /* Table fills container */
    width: 100%;
    height: auto;
}

.embeddings-db-selection-buttons {
    layout: horizontal;
    margin-bottom: 1;
    align-horizontal: left;
}

.embeddings-db-selection-button {
    margin-right: 1;
    min-width: 10;
}

/* Bottom spacer to ensure content is visible */
.embeddings-bottom-spacer {
    height: 5;
    width: 100%;
}

/* ========================================
 * Embeddings Management Window
 * ======================================== */

EmbeddingsManagementWindow {
    layout: horizontal;
    height: 100%;
    width: 100%;
}

.embeddings-left-pane {
    width: 40%;
    min-width: 30;
    max-width: 60;
    height: 100%;
    background: $boost;
    padding: 1;
    border-right: thick $background-darken-1;
    overflow-y: auto;
    overflow-x: hidden;
}

.embeddings-left-pane.collapsed {
    width: 0 !important;
    min-width: 0 !important;
    border-right: none !important;
    padding: 0 !important;
    overflow: hidden !important;
    display: none !important;
}

.embeddings-right-pane {
    width: 1fr;
    height: 100%;
    background: $surface;
    padding: 1 2;
    overflow-y: auto;
}

/* Loading overlay */
.embeddings-loading-overlay {
    /* Use dock to overlay on top of content */
    dock: top;
    width: 100%;
    height: 100%;
    background: $background 90%;
    align: center middle;
    layer: above;
}

.embeddings-loading-overlay.hidden {
    display: none;
}

.embeddings-loading-overlay LoadingIndicator {
    margin-bottom: 2;
}

.embeddings-loading-label {
    text-align: center;
    text-style: bold;
    color: $text;
}

.embeddings-section-title {
    text-style: bold underline;
    margin-bottom: 1;
    text-align: center;
    width: 100%;
}

.embeddings-list-item {
    width: 100%;
    padding: 1;
    margin-bottom: 1;
    border: round $surface;
    background: $panel;
}

.embeddings-list-item:hover {
    background: $panel-lighten-1;
    border: round $accent;
}

.embeddings-info-label {
    text-style: bold;
    margin-top: 1;
    margin-bottom: 0;
}

.embeddings-info-value {
    margin-bottom: 1;
    padding: 1;
    background: $surface-darken-1;
    border: round $primary-darken-1;
}

.embeddings-action-button {
    width: auto;
    min-width: 20;
    margin: 1;
}

/* Buttons in horizontal layout need specific spacing */
.embeddings-model-info-collapsible Horizontal .embeddings-action-button {
    width: auto;
    min-width: 15;
    margin: 0 1;
}

.embeddings-test-area {
    margin-top: 2;
    padding: 1;
    border: round $primary;
    background: $surface;
}

.embeddings-loading {
    align: center middle;
    height: 100%;
}

.embeddings-error {
    color: $error;
    text-style: bold;
    padding: 1;
    border: round $error;
    margin: 1;
}

.embeddings-toggle-button {
    width: 5;
    height: 100%;
    min-width: 0;
    border: none;
    background: $surface-darken-1;
    color: $text;
}

.embeddings-toggle-button:hover {
    background: $surface;
}

/* ========================================
 * New UI Elements for Enhanced Embeddings
 * ======================================== */

/* Help text styling */
.embeddings-help-text {
    color: $text-muted;
    text-style: italic;
    margin: 1 0;
    padding: 0 2;
}

/* Warning messages */
.embeddings-warning {
    background: $warning-lighten-3;
    color: $warning-darken-2;
    padding: 1;
    margin: 1;
    border: round $warning;
    text-align: center;
}

/* Info messages */
.embeddings-info {
    background: $primary-lighten-3;
    color: $primary-darken-2;
    padding: 1;
    margin: 1;
    border: round $primary;
    text-align: center;
}

/* Mode switcher content areas */
#embeddings-mode-switcher {
    width: 100%;
    min-height: 10;
}

/* Specific mode containers */
#mode-search, #mode-specific, #mode-all, #mode-keywords {
    width: 100%;
    padding: 1;
}

/* Results textarea for search mode */
.embeddings-db-results {
    min-height: 8;
    max-height: 15;
    width: 100%;
    border: round $primary;
    background: $surface;
    padding: 1;
    margin-top: 1;
}

/* RadioSet for keyword matching */
#embeddings-keyword-match {
    layout: vertical;
    padding: 0 1;
    width: 100%;
}

#embeddings-keyword-match RadioButton {
    margin: 1 0;
}

/* Collection description textarea height control */
#embeddings-collection-description {
    max-height: 5;
    min-height: 3;
}

/* Enhanced toggle button with better visibility */
.embeddings-toggle-button-enhanced {
    width: auto;
    min-width: 15;
    height: 100%;
    border: none;
    background: $surface-darken-1;
    color: $text;
    padding: 0 1;
    text-align: center;
}

.embeddings-toggle-button-enhanced:hover {
    background: $primary 30%;
    color: $text;
}

.embeddings-toggle-button-enhanced:focus {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Management specific styles */
.embeddings-management-container {
    width: 100%;
    height: 1fr;
    padding: 1 2;
}

.embeddings-management-title {
    text-style: bold;
    text-align: center;
    background: $accent-darken-1;
    color: $text;
    padding: 1;
    margin-bottom: 2;
    border: round $accent;
}

.embeddings-collections-table {
    height: 20;
    margin-bottom: 2;
    border: round $primary;
}

.embeddings-collection-details {
    height: 15;
    border: round $primary-lighten-1;
    background: $surface;
    padding: 1;
    margin-bottom: 2;
}

.embeddings-management-buttons {
    layout: horizontal;
    align-horizontal: center;
    margin-top: 1;
}

.embeddings-management-button {
    margin: 0 1;
    min-width: 15;
}

.embeddings-loading-label {
    text-align: center;
    margin-top: 1;
}

/* Tab content areas in management window */
.embeddings-management-content {
    width: 100%;
    height: 1fr;
}

/* Sidebar title styling */
.sidebar-title {
    text-style: bold;
    margin-bottom: 1;
    padding: 0 1;
    color: $text-muted;
}

/* ========================================
 * Confirmation Dialog Styles
 * ======================================== */

/* Dialog container for modal screens */
#dialog-container {
    align: center middle;
    background: $surface;
    border: thick $primary;
    padding: 2;
    width: 50;
    height: auto;
}

#dialog-title {
    text-style: bold;
    text-align: center;
    margin-bottom: 1;
    width: 100%;
}

#dialog-message {
    text-align: center;
    margin-bottom: 2;
    color: $text-muted;
    width: 100%;
}

#dialog-buttons {
    layout: horizontal;
    align: center middle;
    width: 100%;
    margin-top: 1;
}

#dialog-buttons Button {
    margin: 0 1;
    min-width: 10;
}

/* Modal screen background */
ModalScreen {
    align: center middle;
    background: $background 80%;
}

/* ========================================
 * Create Embeddings Enhanced Styles
 * ======================================== */

/* Main container for embeddings creation content */
EmbeddingsCreationContent {
    layout: vertical;
    height: 100%;
    width: 100%;
}

/* When used within search view */
#search-view-embeddings-create {
    display: none;  /* Hidden by default, shown by button handler */
    height: 100%;
    width: 100%;
}

#search-view-embeddings-create EmbeddingsCreationContent {
    display: block !important;
    height: 100%;
    width: 100%;
    background: $surface;  /* Add background to ensure visibility */
}

/* Tabbed content container */
#embeddings-tabs {
    height: 1fr;
    width: 100%;
}

/* Tab panes should allow scrolling */
#embeddings-tabs TabPane {
    height: 100%;
    overflow-y: auto;
}

/* Ensure VerticalScroll inside TabPane is visible */
#embeddings-tabs TabPane VerticalScroll {
    height: 100%;
    width: 100%;
}

/* Explicitly set tab scroll visibility */
.embeddings-tab-scroll {
    height: 100%;
    width: 100%;
    overflow-y: auto;
    padding: 1 2;
}

/* Progress section styling */
.embeddings-progress-section {
    width: 100%;
    padding: 1 2;
    background: $surface;
    border-top: thick $primary;
}

.embeddings-progress-section.hidden {
    display: none;
}

/* Sticky footer for action buttons */
.embeddings-sticky-footer {
    width: 100%;
    background: $panel;
    padding: 1 2;
    border-top: thick $primary;
    height: auto;
    margin-top: 1;
}

.embeddings-button-group {
    layout: horizontal;
    align: center middle;
    width: 100%;
}

.embeddings-button-group Button {
    margin: 0 1;
    min-width: 20;
}

/* ========================================
 * Form Validation Error Styles
 * ======================================== */

/* Error message displays */
.error-message {
    color: $error;

    margin-top: 0;
    margin-bottom: 1;
    padding: 0 1;
    text-style: italic;
}

.error-message.hidden {
    display: none;
}

/* General error at bottom */
.error-general {
    text-align: center;
    background: $error 20%;
    border: round $error;
    padding: 1;
    margin: 1 2;

    text-style: bold;
}

/* Input error state */
.embeddings-form-control.error {
    border: thick $error;
}

.embeddings-form-control Input.error,
.embeddings-form-control Select.error {
    border: thick $error;
}

/* ========================================
 * Enhanced List Item Styles
 * ======================================== */

/* Model List Item */
.model-list-item-container {
    layout: horizontal;
    align: left middle;
    padding: 1;
    width: 100%;
}

.model-select-checkbox {
    margin-right: 1;
}

.model-icon {

    margin-right: 1;
    min-width: 3;
    text-align: center;
}

.model-info-container {
    width: 1fr;
}

.model-header {
    layout: horizontal;
    margin-bottom: 0;
}

.model-name {
    text-style: bold;
    margin-right: 1;
}

/* Highlight favorite models */
.model-list-item-favorite {
    background: $accent 10%;
    border-left: thick $accent;
}

.model-provider {
    color: $text-muted;

}

.model-status-row {
    layout: horizontal;
    margin-top: 0;
}

.model-download-status,
.model-memory-status,
.model-size {

    margin-right: 2;
}

.model-download-status.downloaded {
    color: $success;
}

.model-download-status.not-downloaded {
    color: $warning;
}

.model-download-status.cloud {
    color: $primary;
}

.model-memory-status.loaded {
    color: $success;
}

.model-memory-status.not-loaded {
    color: $text-muted;
}

.model-size {
    color: $text-muted;
}

/* Collection List Item */
.collection-list-item-container {
    layout: horizontal;
    align: left middle;
    padding: 1;
    width: 100%;
}

.collection-select-checkbox {
    margin-right: 1;
}

.collection-icon {

    margin-right: 1;
    min-width: 3;
    text-align: center;
}

.collection-info-container {
    width: 1fr;
}

.collection-name {
    text-style: bold;
    margin-bottom: 0;
}

.collection-metadata-row {
    layout: horizontal;
    margin-top: 0;
}

.collection-doc-count,
.collection-modified,
.collection-size,
.collection-status {

    margin-right: 2;
}

.collection-doc-count {
    color: $primary;
}

.collection-modified {
    color: $text-muted;
}

.collection-size {
    color: $text-muted;
}

.collection-status.ready {
    color: $success;
}

.collection-status.indexing {
    color: $warning;
}

.collection-status.error {
    color: $error;
}

/* Enhanced list item hover states */
ModelListItem:hover,
CollectionListItem:hover {
    background: $panel-lighten-1;
}

#embeddings-model-list ModelListItem.-highlight,
#embeddings-collection-list CollectionListItem.-highlight {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* ========================================
 * Empty State Styles
 * ======================================== */

.empty-state-container {
    width: 100%;
    height: 100%;
    align: center middle;
    padding: 3;
}

.empty-state-content {
    align: center middle;
    width: auto;
}

.empty-state-icon {

    margin-bottom: 1;
    text-align: center;
}

.empty-state-title {
    text-style: bold;

    margin-bottom: 1;
    text-align: center;
}

.empty-state-description {
    color: $text-muted;
    margin-bottom: 2;
    text-align: center;
    max-width: 40;
}

.empty-state-action {
    margin-top: 1;
}

/* Debug styles */
.debug-message {
    background: $warning;
    color: $text;
    padding: 1;
    margin: 1;
    border: solid $warning-darken-1;
    text-align: center;
    text-style: bold;
}

/* ========================================
 * Enhanced Visual Design
 * ======================================== */

/* Section backgrounds */
.embeddings-form-section {
    background: $panel;
    border: round $primary-darken-2;
    padding: 1;
    margin-bottom: 1;
}

.embeddings-result-section {
    background: $surface;
    border: round $primary-darken-1;
    padding: 1;
}

/* Enhanced hover states */
/* Button:hover handled in components/_buttons.tcss to fix persistent hover issue */

Select:hover {
    border: solid $primary-lighten-1;
}

/* Consistent spacing system */
.spacing-small {
    margin: 1;
}

.spacing-medium {
    margin: 2;
}

.spacing-large {
    margin: 3;
}

/* Visual separators */
.section-separator {
    height: 1;
    background: $primary-darken-2;
    margin: 2 0;
}

/* ========================================
 * Tooltip and Help Icon Styles
 * ======================================== */

/* Tooltip container */
.tooltip {

    background: $panel;
    border: solid $primary;
    padding: 1;
    max-width: 40;

    display: none;
}

.tooltip-content {
    color: $text;

}

/* Help icon */
.help-icon {

    margin-left: 1;
    color: $primary;
}

.help-icon:hover {
    color: $primary-lighten-1;
}

.help-icon-inline {
    margin-left: 1;
    min-width: 3;
}

/* ========================================
 * Enhanced Form Sections
 * ======================================== */

/* Add visual grouping to form sections */
#tab-processing .embeddings-form-section,
#tab-output .embeddings-form-section {
    margin-bottom: 2;
}

/* Advanced options styling */
#embeddings-advanced-options {
    margin-top: 1;
    background: $surface;
    border: round $primary-darken-2;
}

/* ========================================
 * Chunk Preview Widget Styles
 * ======================================== */

.chunk-preview-widget {
    width: 100%;
    height: auto;
}

.chunk-preview-container {
    width: 100%;
    max-height: 30;
    background: $surface;
    border: round $primary-darken-1;
    padding: 1;
}

.chunk-preview-title {
    text-style: bold;
    margin-bottom: 1;
    color: $primary;
}

.chunk-preview-empty {
    color: $text-muted;
    text-align: center;
    padding: 2;
}

.chunk-item {
    margin-bottom: 2;
    padding: 1;
    background: $panel;
    border: round $primary-darken-2;
}

.chunk-header {
    layout: horizontal;
    margin-bottom: 1;
    padding-bottom: 1;
    border-bottom: dashed $primary-darken-2;
}

.chunk-number {
    text-style: bold;
    color: $accent;
    margin-right: 2;
}

.chunk-range {
    color: $text-muted;

    margin-right: 2;
}

.chunk-size {
    color: $text-muted;

}

.chunk-overlap {
    background: $warning 20%;
    padding: 0 1;
    margin-bottom: 1;
    border-left: thick $warning;
    text-style: italic;
    color: $text-muted;
}

.chunk-content {
    padding: 0 1;

}

.chunk-truncated {
    color: $text-muted;
    text-style: italic;
    text-align: right;
    margin-top: 0;
}

.chunk-more {
    text-align: center;
    color: $text-muted;
    text-style: italic;
    margin-top: 1;
}

.chunk-boundary {
    text-align: center;
    color: $primary-darken-1;
    margin: 1 0;
}

/* ========================================
 * Batch Selection Styles
 * ======================================== */

.batch-controls {
    layout: horizontal;
    margin: 1 0;
    padding: 1;
    background: $surface;
    border: round $primary;
}

.batch-controls.hidden {
    display: none;
}

.batch-button {
    margin: 0 1;
    min-width: 12;
    height: 3;
}

/* ========================================
 * Toast Notification Styles
 * ======================================== */

.toast-manager {
    dock: top;
    align: right top;
    width: auto;
    height: auto;
    margin: 2 2 0 0;
    layer: above;

}

.toast-stack {
    width: auto;
    height: auto;
}

.toast-notification {
    width: 35;
    margin-bottom: 1;
}

.toast-container {
    layout: horizontal;
    padding: 1;
    border: round;
    align: left middle;
}

.toast-icon {
    margin-right: 1;
    min-width: 3;
    text-align: center;
}

.toast-message {
    width: 1fr;
    text-wrap: wrap;
}

.toast-close {
    min-width: 3;
    height: 3;
    margin-left: 1;
    background: transparent;
    border: none;
}

.toast-close:hover {
    background: $background 50%;
}

/* Toast severity styles */
.toast-success {
    background: $success 90%;
    border: solid $success;
    color: $text;
}

.toast-info {
    background: $primary 90%;
    border: solid $primary;
    color: $text;
}

.toast-warning {
    background: $warning 90%;
    border: solid $warning;
    color: $text;
}

.toast-error {
    background: $error 90%;
    border: solid $error;
    color: $text;
}

/* Toast animations */
.toast-slide-in {
    /* Animation properties would go here if needed */
}

/* ========================================
 * Detailed Progress Bar Styles
 * ======================================== */

.detailed-progress-container {
    width: 100%;
    padding: 1;
    background: $panel;
    border: round $primary;
}

.progress-stage-row,
.progress-item-row,
.progress-metrics-row {
    layout: horizontal;
    margin-bottom: 1;
    align: left middle;
}

.progress-action-row {
    layout: horizontal;
    margin-bottom: 1;
    align: right middle;
}

.progress-label {
    width: 12;
    text-align: right;
    margin-right: 1;
    color: $text-muted;
}

.stage-indicator {
    width: 1fr;
    text-style: bold;
    color: $primary;
}

.current-item {
    width: 1fr;
    color: $text;
    text-style: italic;
}

.pause-button {
    min-width: 10;
}

#main-progress {
    margin-bottom: 1;
    height: 3;
}

.stage-progress {
    height: 2;
    background: $surface;
}

.progress-metrics-row {
    margin-top: 1;
    border-top: dashed $primary-darken-2;
    padding-top: 1;
}

.metric-group {
    margin-right: 3;
}

.metric-label {

    color: $text-muted;
    margin-bottom: 0;
}

.metric-value {

    text-style: bold;
    color: $primary;
}

/* ========================================
 * Embedding Template Selector Styles
 * ======================================== */

/* Template selector dialog */
#embedding-template-selector-container {
    width: 80;
    height: 50;
    background: $panel;
    border: thick $primary;
    padding: 2;
}

#embedding-template-selector-title {
    text-style: bold;
    text-align: center;
    margin-bottom: 2;
}

#embedding-template-selector-content {
    height: 1fr;
    margin-bottom: 2;
}

#embedding-template-category-pane {
    width: 25%;
    min-width: 20;
    background: $surface;
    padding: 1;
    border-right: solid $primary-darken-1;
}

#embedding-template-grid-container {
    width: 1fr;
    padding: 1;
    overflow-y: auto;
}

.embedding-template-grid {
    grid-columns: 2;
    grid-gutter: 1;
    padding: 1;
}

/* Template card styles */
.embedding-template-card-container {
    background: $surface;
    border: round $primary-darken-2;
    padding: 1;
    height: auto;
}

.embedding-template-card:hover .embedding-template-card-container {
    background: $surface-lighten-1;
    border: solid $accent;
}

.embedding-template-card-header {
    layout: horizontal;
    margin-bottom: 1;
    align: left middle;
}

.embedding-template-card-title {
    text-style: bold;
    color: $primary;
    width: 1fr;
}

.embedding-template-card-category {

    color: $text-muted;
    background: $primary 20%;
    padding: 0 1;
    border: round $primary;
}

.embedding-template-card-description {
    margin-bottom: 1;
    color: $text-muted;

}

.embedding-template-card-label {

    text-style: bold;
    margin-bottom: 0;
}

.embedding-template-card-list {
    margin-left: 1;
    margin-bottom: 1;
}

.embedding-template-card-item {

    color: $text-muted;
}

.embedding-template-card-button {
    width: 100%;
    margin-top: 1;
}

/* Quick select widget */
.embedding-template-quick-select-container {
    layout: horizontal;
    align: left middle;
    padding: 1;
    background: $surface;
    border: round $primary-darken-2;
    margin-bottom: 1;
}

.embedding-template-select-label {
    margin-right: 2;
    min-width: 10;
}

.embedding-template-quick-button {
    margin-right: 1;
    min-width: 15;
}

.embedding-template-browse-button {
    margin-left: 1;
}

.current-template-name {
    margin-left: 2;
    color: $success;
    text-style: italic;
}

/* ========================================
 * Activity Log Widget Styles
 * ======================================== */

.activity-log-widget {
    width: 100%;
    height: 100%;
}

.activity-log-container {
    width: 100%;
    height: 100%;
    background: $panel;
    border: round $primary-darken-2;
    padding: 1;
}

.activity-log-header {
    layout: horizontal;
    margin-bottom: 1;
    align: left middle;
}

.activity-log-title {
    text-style: bold;

    width: 1fr;
}

.activity-log-actions {
    layout: horizontal;
}

.activity-log-actions Button {
    margin-left: 1;
    min-width: 10;
    height: 3;
}

.activity-log-controls {
    layout: horizontal;
    margin-bottom: 1;
    align: left middle;
}

.level-filters {
    layout: horizontal;
    margin-right: 2;
}

.filter-button {
    margin-right: 1;
    min-width: 8;
    height: 3;
    background: $surface;
}

.filter-button:hover {
    background: $primary 30%;
}

.filter-button.active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.log-search-input {
    width: 20;
}

.activity-log-scroll {
    height: 1fr;
    background: $surface;
    border: round $primary-darken-3;
    padding: 1;
}

.log-entries-container {
    width: 100%;
}

/* Log entry styles */
.log-entry {
    layout: horizontal;
    margin-bottom: 1;
    padding: 0;
    align: left top;
}

.log-timestamp {
    min-width: 10;

    color: $text-muted;
    text-align: right;
    padding-right: 1;
}

.log-icon {
    min-width: 3;
    text-align: center;
}

.log-category {
    min-width: 12;
    color: $primary;

    padding: 0 1;
}

.log-message {
    width: 1fr;
    padding-left: 1;
}

/* Level-specific colors */
.log-info {
    color: $text;
}

.log-info .log-icon {
    color: $primary;
}

.log-success {
    color: $success;
}

.log-success .log-message {
    color: $success;
}

.log-warning {
    color: $warning;
}

.log-warning .log-message {
    color: $warning;
}

.log-error {
    color: $error;
}

.log-error .log-message {
    color: $error;
}

.log-debug {
    color: $text-muted;
    text-style: italic;
}

.log-debug .log-message {
    color: $text-muted;
}

/* Small button styles */
.small-button {
    height: 3;
    min-width: 8;

}

/* ========================================
 * Performance Metrics Widget Styles
 * ======================================== */

.performance-metrics-widget {
    width: 100%;
    height: auto;
}

.performance-metrics-container {
    width: 100%;
    padding: 1;
}

.metrics-title {
    text-style: bold;
    text-align: center;
    margin-bottom: 1;

}

.metrics-grid {
    grid-size: 2;
    grid-gutter: 1;
    width: 100%;
    margin-bottom: 1;
}

/* Metric box styling */
.metric-box {
    background: $surface;
    border: round $primary-darken-2;
    padding: 1;
    height: auto;
}

.metric-header {
    layout: horizontal;
    margin-bottom: 1;
    align: left middle;
}

.metric-icon {

    margin-right: 1;
}

.metric-label {

    color: $text-muted;
}

.metric-value {

    text-style: bold;
    color: $primary;
    text-align: center;
    margin-bottom: 0;
}

.metric-percent {
    text-align: center;
    color: $text-muted;

}

.metric-info {
    text-align: center;
    color: $text-muted;

    margin-top: 0;
}

/* I/O rates styling */
.metric-io-rates {
    layout: horizontal;
    align: center middle;
    margin-top: 1;
}

.io-rate {
    width: 50%;
    text-align: center;

}

.io-rate:first-child {
    color: $success;
}

.io-rate:last-child {
    color: $warning;
}

/* Sparkline chart styling */
.metric-chart {
    height: 5;
    margin-top: 1;
    color: $primary;
}

/* Alerts section */
.metrics-alerts {
    margin-top: 1;
    padding: 1;
    background: $error 10%;
    border: round $error;
}

.metrics-alerts.hidden {
    display: none;
}

.alerts-title {
    text-style: bold;
    color: $error;
    margin-bottom: 1;
}

.alerts-list {
    width: 100%;
}

.alert-item {
    color: $error;

    margin-bottom: 0;
    padding-left: 2;
}

/* Metric-specific colors */
.metric-cpu-usage .metric-value {
    color: $primary;
}

.metric-memory-usage .metric-value {
    color: $accent;
}

.metric-disk-io .io-rate {
    color: $text;
}

.metric-embeddings-rate .metric-value {
    color: $success;
}

/* High usage indicators */
.metric-box.high-usage {
    border: solid $warning;
    background: $warning 10%;
}

.metric-box.critical-usage {
    border: solid $error;
    background: $error 10%;
}

/* ===== MODULE: features/_splash.tcss ===== */
/* Splash Screen Styles */

/* Main splash screen container */
SplashScreen, .splash-screen {
    layer: overlay;
    background: $background;
    width: 100%;
    height: 100%;
    align: center middle;
    dock: top;
}

/* Center container for splash content */
#splash-center {
    width: 100%;
    height: 100%;
    align: center middle;
}

/* Content container */
#splash-content {
    width: 100%;
    height: 100%;
    align: center middle;
    padding: 0;
}

/* Main splash display area */
#splash-main, .splash-main {
    width: 100%;
    height: 100%;
    content-align: center middle;
    text-align: center;
    margin: 0;
}

/* Splash display widget - the actual content display area */
#splash-display, .splash-display {
    width: 100%;
    height: 100%;
    content-align: center middle;
    text-align: center;
    align: center middle;
    padding: 0;
    margin: 0;
}

/* Progress text */
#splash-progress-text, .splash-progress-text {
    width: 100%;
    text-align: center;
    color: $text-muted;
    margin-bottom: 1;
}

/* Progress bar styling */
#splash-progress-bar, .splash-progress-bar {
    width: 80%;
    max-width: 100;
    height: 1;
    margin: 0 0 0 0;
    align: center middle;
}

#splash-progress-bar Bar {
    color: $success;
}

#splash-progress-bar PercentageStatus {
    text-style: dim;
}

/* Animation-specific styles */

/* Matrix rain effect */
.matrix-rain {
    color: $success;
    text-style: bold;
}

/* Glitch effect */
.glitch-effect {
    color: $text;
    text-style: bold;
}

.glitch-effect-error {
    color: $error;
    text-style: bold;
}

.glitch-effect-primary {
    color: $primary;
    text-style: bold;
}

.glitch-effect-warning {
    color: $warning;
    text-style: bold;
}

.glitch-effect-success {
    color: $success;
    text-style: bold;
}

/* Retro terminal effect */
.retro-terminal {
    color: $success;
    background: rgba(0, 0, 0, 0.9);
    text-style: bold;
}

.retro-scanline {
    background: rgba(0, 255, 0, 0.1);
}

/* Fade effect styles */
.fade-in {
    opacity: 0.0;
}

.fade-out {
    opacity: 1.0;
}

/* Animated states */
.splash-visible {
    opacity: 1.0;
}

.splash-hidden {
    opacity: 0.0;
}

/* Loading placeholder for lazy-loaded content */
.loading-placeholder {
    color: $text-muted;
    text-align: center;
    padding: 4;
}

/* Hide splash screen when not active */
SplashScreen.hidden {
    display: none;
}

/* ===== MODULE: features/_wizards.tcss ===== */
/* ========================================
 * Wizard Framework Styles
 * ======================================== */

/* ========================================
 * Base Wizard Container
 * ======================================== */

.wizard-container {
    layout: vertical;
    height: 100%;
    width: 100%;
    background: $surface;
    padding: 0;
}

.wizard-title {
    text-style: bold;
    text-align: center;
    background: $primary-darken-2;
    color: $text;
    padding: 1 2;
    margin-bottom: 0;
    border-bottom: thick $primary-darken-1;
    width: 100%;
    height: 3;
}

/* ========================================
 * Progress Indicator
 * ======================================== */

.wizard-progress {
    layout: horizontal;
    align: center middle;
    padding: 2;
    background: $panel;
    border-bottom: solid $primary-darken-2;
    height: auto;
}

.step-indicator-container {
    layout: horizontal;
    align: center middle;
    width: 1fr;
}

.step-number {
    width: 3;
    height: 3;
    border: round $primary;
    background: $panel;
    align: center middle;
    margin-right: 1;
    text-align: center;
}

.step-number.active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    border: round $ds-focus-accent;
    text-style: bold underline;
}

.step-number.complete {
    background: $success;
    color: $text;
    border: solid $success;
}

.step-title {
    margin-right: 1;
    color: $text-muted;
}

.step-title.active {
    color: $ds-focus-fg;
    text-style: bold underline;
}

.step-title.complete {
    color: $success;
}

.step-connector {
    height: 1;
    width: 1fr;
    background: $primary-darken-2;
    margin: 0 1;
}

.step-connector.complete {
    background: $success;
}

/* ========================================
 * Step Container
 * ======================================== */

.wizard-steps-container {
    height: 1fr;
    width: 100%;
    overflow-y: auto;
    padding: 0;
    background: $surface;
}

.wizard-step {
    width: 100%;
    height: 100%;
    padding: 2;
    display: block;
    visibility: hidden;
}

.wizard-step.active {
    visibility: visible;
}

.wizard-step.hidden {
    display: none;
}

/* Step animations removed - not supported in Textual */

/* ========================================
 * Navigation Bar
 * ======================================== */

.wizard-navigation {
    layout: horizontal;
    align: center middle;
    padding: 1 2;
    background: $panel;
    border-top: thick $primary-darken-2;
    height: 5;
}

.wizard-progress-text {
    width: 1fr;
    text-align: center;
    color: $text-muted;
}

#wizard-back, #wizard-next {
    min-width: 15;
    height: 3;
}

#wizard-back:disabled {
    opacity: 0.5;
}

#wizard-next:disabled {
    opacity: 0.5;
}

/* ========================================
 * Content Type Selection
 * ======================================== */

.wizard-step-title {
    text-style: bold;
    text-align: center;
    margin-bottom: 1;
}

.wizard-step-subtitle {
    text-align: center;
    color: $text-muted;
    margin-bottom: 2;
}

.content-type-grid {
    layout: grid;
    grid-size: 3 2;
    grid-gutter: 2;
    padding: 2;
    margin-top: 2;
    width: 100%;
}

.content-type-card {
    background: $panel;
    border: round $primary-darken-2;
    padding: 2;
    align: center middle;
    height: 15;
}

.content-type-card:hover {
    background: $panel-lighten-1;
    border: solid $accent;
}

.content-type-card.selected {
    background: $ds-focus-bg;
    border: round $ds-focus-accent;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.content-type-icon {
    margin-bottom: 1;
    text-align: center;
}

.content-type-title {
    text-style: bold;
    margin-bottom: 0;
    text-align: center;
}

.content-type-description {
    color: $text-muted;
    text-align: center;
}

.content-type-card.selected .content-type-title,
.content-type-card.selected .content-type-description {
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* ========================================
 * Content Selection
 * ======================================== */

.smart-content-selector {
    width: 100%;
    height: 100%;
}

.selection-mode-set {
    layout: horizontal;
    margin-bottom: 2;
    padding: 1;
    background: $panel;
    border: round $primary-darken-2;
}

.selection-mode-set RadioButton {
    margin-right: 2;
}

.content-search-input {
    width: 100%;
    margin-bottom: 2;
}

.content-search-input.hidden {
    display: none;
}

.quick-selection-buttons {
    layout: horizontal;
    margin-bottom: 1;
}

.quick-selection-buttons Button {
    margin-right: 1;
    min-width: 12;
}

.preview-label {
    text-style: bold;
    margin-bottom: 1;
    color: $primary;
}

.content-list-container {
    height: 25;
    background: $surface;
    border: round $primary-darken-2;
    padding: 1;
    overflow-y: auto;
}

.content-list {
    width: 100%;
}

.content-item {
    width: 100%;
    padding: 1;
    margin-bottom: 0;
    border-bottom: dashed $primary-darken-3;
}

.content-item:hover {
    background: $panel 50%;
}

.content-item-row {
    layout: horizontal;
    align: left middle;
}

.content-item-checkbox {
    margin-right: 1;
}

.content-item-icon {
    margin-right: 1;
    min-width: 3;
    text-align: center;
}

.content-item-info {
    width: 1fr;
}

.content-item-title {
    text-style: bold;
    margin-bottom: 0;
}

.content-item-subtitle {
    color: $text-muted;
}

.placeholder-text {
    text-align: center;
    color: $text-muted;
    padding: 2;
}

/* ========================================
 * Quick Settings
 * ======================================== */

.settings-section {
    margin-bottom: 2;
    padding: 1;
    background: $panel;
    border: round $primary-darken-3;
}

.settings-label {
    text-style: bold;
    margin-bottom: 1;
    color: $primary;
}

.settings-input {
    width: 100%;
    margin-bottom: 0;
}

.settings-help {
    color: $text-muted;
    margin-top: 0;
}

.preset-cards-container {
    layout: horizontal;
    margin-bottom: 2;
    padding: 1;
}

.preset-card {
    background: $panel;
    border: round $primary-darken-2;
    padding: 2;
    margin-right: 1;
    width: 1fr;
    height: auto;
}

.preset-card:hover {
    background: $panel-lighten-1;
    border: solid $accent;
}

.preset-card.selected {
    background: $ds-focus-bg;
    border: round $ds-focus-accent;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.preset-icon {
    text-align: center;
    margin-bottom: 1;
}

.preset-name {
    text-style: bold;
    text-align: center;
    margin-bottom: 0;
}

.preset-description {
    color: $text-muted;
    text-align: center;
    margin-bottom: 1;
}

.preset-details {
    border-top: dashed $primary-darken-3;
    padding-top: 1;
}

.preset-detail {
    color: $text-muted;
    margin-bottom: 0;
}

.preset-card.selected .preset-name,
.preset-card.selected .preset-description,
.preset-card.selected .preset-detail {
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Advanced settings */
.advanced-settings-container {
    margin-top: 2;
}

.advanced-toggle {
    width: 100%;
    background: $surface;
    border: round $primary-darken-3;
    color: $text-muted;
    text-align: left;
}

.advanced-toggle:hover {
    background: $panel;
    color: $text;
}

.advanced-settings {
    margin-top: 1;
    padding: 2;
    background: $surface;
    border: round $primary-darken-3;
}

.advanced-settings.hidden {
    display: none;
}

.advanced-settings Label {
    margin-top: 1;
}

.advanced-settings Select,
.advanced-settings Input {
    width: 100%;
    margin-bottom: 1;
}

/* ========================================
 * Processing Step
 * ======================================== */

.processing-container {
    background: $panel;
    border: round $primary;
    padding: 2;
    margin-bottom: 2;
}

.main-progress-bar {
    height: 3;
    margin-bottom: 2;
}

.progress-text {
    text-align: center;
    text-style: bold;
    margin-bottom: 1;
    color: $primary;
}

.current-item {
    text-align: center;
    color: $text-muted;
    margin-bottom: 2;
    text-style: italic;
}

.progress-stats {
    layout: horizontal;
    align: center middle;
    padding-top: 1;
    border-top: dashed $primary-darken-2;
}

.progress-stats Label {
    width: 1fr;
    text-align: center;
    color: $text-muted;
}

.explanation-box {
    background: $primary 10%;
    border: round $primary;
    padding: 2;
}

.explanation-title {
    text-style: bold;
    margin-bottom: 1;
    color: $primary;
}

.explanation-text {
    color: $text;
}

/* ========================================
 * Validation and Errors
 * ======================================== */

.error-message {
    color: $error;
    background: $error 10%;
    border: round $error;
    padding: 1;
    margin: 1;
    text-align: center;
}

/* ========================================
 * Animations and Transitions
 * ======================================== */

/* Staggered entrance animations removed - not supported in Textual */

/* Progress bar animation removed - not supported in Textual */

/* Loading state */
.wizard-loading {
    align: center middle;
    height: 100%;
}

.wizard-loading LoadingIndicator {
    margin-bottom: 2;
}

/* ========================================
 * Responsive adjustments
 * ======================================== */

/* Media queries not supported in Textual - using fixed layouts */

/* ========================================
 * Chatbook Creation Wizard Specific Styles
 * ======================================== */

/* Basic Info Step */
BasicInfoStep {
    layout: vertical;
    padding: 2;
}

BasicInfoStep .form-group {
    margin-bottom: 2;
}

BasicInfoStep .form-label {
    color: $text-muted;
    margin-bottom: 0;
}

BasicInfoStep .form-input {
    width: 100%;
    margin-top: 0;
}

BasicInfoStep #chatbook-description {
    height: 6;
}

BasicInfoStep .info-box {
    padding: 1;
    background: $boost;
    border: round $primary;
    margin-top: 2;
}

/* Content Selection Step */
ContentSelectionStep {
    layout: vertical;
    height: 100%;
}

ContentSelectionStep .selection-header {
    height: 3;
    padding: 1;
    background: $boost;
    border: round $background-darken-1;
    margin-bottom: 1;
}

ContentSelectionStep .content-tree-container {
    height: 1fr;
}

/* Export Options Step */
ExportOptionsStep {
    layout: vertical;
    padding: 2;
}

ExportOptionsStep .option-group {
    margin-bottom: 2;
    padding: 1;
    background: $boost;
    border: round $background-darken-1;
}

ExportOptionsStep .option-title {
    text-style: bold;
    margin-bottom: 1;
}

ExportOptionsStep .radio-option {
    margin: 0 0 1 1;
}

ExportOptionsStep .checkbox-option {
    margin: 0 0 1 1;
}

ExportOptionsStep .compression-level {
    margin-left: 3;
    layout: horizontal;
    height: 3;
}

/* Preview Confirm Step */
PreviewConfirmStep {
    layout: vertical;
    padding: 2;
}

PreviewConfirmStep .preview-header {
    margin-bottom: 2;
}

PreviewConfirmStep .chatbook-title {
    text-style: bold;
    margin-bottom: 1;
}

PreviewConfirmStep .preview-section {
    margin-bottom: 2;
    padding: 1;
    background: $boost;
    border: round $background-darken-1;
}

PreviewConfirmStep .section-title {
    text-style: bold;
    margin-bottom: 1;
}

PreviewConfirmStep .content-list {
    margin-left: 2;
    color: $text-muted;
}

PreviewConfirmStep .file-tree {
    height: 12;
    border: round $background-darken-1;
    background: $background;
    padding: 1;
    margin: 1 0;
}

PreviewConfirmStep .location-section {
    margin-top: 2;
    padding: 1;
    background: $panel;
    border: round $primary;
}

PreviewConfirmStep .location-path {
    color: $primary;
    margin: 1 0;
}

/* Progress Step */
ProgressStep {
    layout: vertical;
    padding: 2;
    align: center middle;
}

ProgressStep .progress-container {
    width: 100%;
    max-width: 60;
    padding: 2;
    background: $boost;
    border: round $background-darken-1;
}

ProgressStep .progress-title {
    text-align: center;
    text-style: bold;
    margin-bottom: 2;
}

ProgressStep #export-progress, ProgressStep #import-progress {
    margin: 2 0;
}

ProgressStep .progress-status {
    margin: 2 0;
}

ProgressStep .status-item {
    margin: 0 0 1 2;
    color: $text-muted;
}

ProgressStep .status-item.completed {
    color: $success;
}

ProgressStep .status-item.active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

ProgressStep .status-item.error {
    color: $error;
}

ProgressStep .completion-message {
    text-align: center;
    padding: 2;
    margin-top: 2;
    background: $success 20%;
    border: round $success;
}

ProgressStep .completion-actions {
    layout: horizontal;
    height: auto;
    align: center middle;
    margin-top: 2;
}

ProgressStep .completion-actions Button {
    margin: 0 1;
}

ProgressStep .hidden {
    display: none;
}

/* ========================================
 * Chatbook Import Wizard Specific Styles
 * ======================================== */

/* File Selection Step */
FileSelectionStep {
    layout: vertical;
    padding: 2;
}

FileSelectionStep .file-selection-container {
    layout: vertical;
    height: 100%;
    align: center middle;
}

FileSelectionStep .drop-zone {
    width: 80%;
    height: 20;
    border: dashed $background-darken-2;
    background: $boost;
    align: center middle;
    margin: 2 0;
}

FileSelectionStep .drop-zone.hover {
    border: solid $primary;
    background: $primary 10%;
}

FileSelectionStep .drop-zone-content {
    text-align: center;
    padding: 2;
}

FileSelectionStep .drop-zone-icon {
    margin-bottom: 1;
    color: $text-muted;
}

FileSelectionStep .drop-zone-text {
    color: $text-muted;
    margin-bottom: 1;
}

FileSelectionStep .file-path-display {
    width: 80%;
    margin: 2 0;
    padding: 1;
    background: $boost;
    border: round $background-darken-1;
}

FileSelectionStep .path-label {
    color: $text-muted;
    margin-bottom: 0;
}

FileSelectionStep .path-value {
    color: $primary;
    margin-top: 0;
}

FileSelectionStep .browse-button {
    margin-top: 2;
}

/* Preview Validation Step */
PreviewValidationStep {
    layout: vertical;
    padding: 2;
}

PreviewValidationStep .preview-header {
    margin-bottom: 2;
}

PreviewValidationStep .chatbook-info {
    padding: 1 2;
    background: $boost;
    border: round $background-darken-1;
    margin-bottom: 2;
}

PreviewValidationStep .info-title {
    text-style: bold;
    margin-bottom: 1;
}

PreviewValidationStep .info-row {
    layout: horizontal;
    height: auto;
    margin: 0 0 1 1;
}

PreviewValidationStep .info-label {
    width: 15;
    color: $text-muted;
}

PreviewValidationStep .info-value {
    width: 1fr;
}

PreviewValidationStep .content-preview {
    padding: 1 2;
    background: $boost;
    border: round $background-darken-1;
    margin-bottom: 2;
}

PreviewValidationStep .preview-title {
    text-style: bold;
    margin-bottom: 1;
    color: $primary;
}

PreviewValidationStep .content-tree {
    height: 15;
    background: $background;
    border: round $background-darken-1;
    padding: 1;
}

PreviewValidationStep .validation-results {
    padding: 1 2;
    background: $boost;
    border: round $background-darken-1;
}

PreviewValidationStep .validation-title {
    text-style: bold;
    margin-bottom: 1;
}

PreviewValidationStep .validation-item {
    margin: 0 0 1 1;
}

PreviewValidationStep .validation-success {
    color: $success;
}

PreviewValidationStep .validation-warning {
    color: $warning;
}

PreviewValidationStep .validation-error {
    color: $error;
}

/* Conflict Resolution Step */
ConflictResolutionStep {
    layout: vertical;
    padding: 2;
}

ConflictResolutionStep .resolution-header {
    margin-bottom: 2;
    padding: 1;
    background: $boost;
    border: round $background-darken-1;
}

ConflictResolutionStep .strategy-section {
    margin-bottom: 2;
    padding: 1 2;
    background: $boost;
    border: round $background-darken-1;
}

ConflictResolutionStep .strategy-title {
    text-style: bold;
    margin-bottom: 1;
    color: $primary;
}

ConflictResolutionStep .radio-option {
    margin: 0 0 1 1;
}

ConflictResolutionStep .strategy-description {
    margin: 0 0 1 3;
    color: $text-muted;
}

ConflictResolutionStep .conflict-preview {
    padding: 1 2;
    background: $boost;
    border: round $warning;
}

ConflictResolutionStep .conflict-title {
    text-style: bold;
    color: $warning;
    margin-bottom: 1;
}

ConflictResolutionStep .conflict-list {
    margin-left: 2;
    color: $text-muted;
}

ConflictResolutionStep .no-conflicts {
    text-align: center;
    padding: 3;
    color: $success;
}

/* Import Options Step */
ImportOptionsStep {
    layout: vertical;
    padding: 2;
}

ImportOptionsStep .options-section {
    margin-bottom: 2;
    padding: 1 2;
    background: $boost;
    border: round $background-darken-1;
}

ImportOptionsStep .section-title {
    text-style: bold;
    margin-bottom: 1;
    color: $primary;
}

ImportOptionsStep .checkbox-option {
    margin: 0 0 1 1;
}

ImportOptionsStep .option-description {
    margin: 0 0 1 3;
    color: $text-muted;
}

/* Import Progress Step */
ImportProgressStep {
    layout: vertical;
    padding: 2;
    align: center middle;
}

ImportProgressStep .progress-container {
    width: 100%;
    max-width: 60;
    padding: 2;
    background: $boost;
    border: round $background-darken-1;
}

ImportProgressStep .progress-title {
    text-align: center;
    text-style: bold;
    margin-bottom: 2;
}

ImportProgressStep #import-progress {
    margin: 2 0;
}

ImportProgressStep .progress-status {
    margin: 2 0;
}

ImportProgressStep .status-item {
    margin: 0 0 1 2;
    color: $text-muted;
}

ImportProgressStep .status-item.completed {
    color: $success;
}

ImportProgressStep .status-item.active {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

ImportProgressStep .status-item.error {
    color: $error;
}

ImportProgressStep .completion-message {
    text-align: center;
    padding: 2;
    margin-top: 2;
    background: $success 20%;
    border: round $success;
}

ImportProgressStep .completion-stats {
    margin-top: 2;
    padding: 1 2;
    background: $boost;
    border: round $background-darken-1;
}

ImportProgressStep .stat-row {
    layout: horizontal;
    height: auto;
    margin: 0 0 1 0;
}

ImportProgressStep .stat-label {
    width: 20;
    color: $text-muted;
}

ImportProgressStep .stat-value {
    width: 1fr;
    text-align: right;
}

/* ========================================
 * SmartContentTree Styles (used by wizards)
 * ======================================== */

SmartContentTree {
    layout: vertical;
    height: 100%;
}

SmartContentTree .tree-controls {
    height: auto;
    padding: 1;
    background: $boost;
    border: round $background-darken-1;
    margin-bottom: 1;
}

SmartContentTree .search-row {
    layout: horizontal;
    height: 3;
    margin-bottom: 1;
}

SmartContentTree .search-input {
    width: 1fr;
    margin-right: 1;
}

SmartContentTree .filter-button {
    min-width: 12;
}

SmartContentTree .category-filters {
    layout: horizontal;
    height: auto;
    margin-bottom: 1;
}

SmartContentTree .category-checkbox {
    margin-right: 2;
}

SmartContentTree .selection-controls {
    layout: horizontal;
    height: auto;
}

SmartContentTree .selection-button {
    margin-right: 1;
    min-width: 10;
}

SmartContentTree .tree-container {
    height: 1fr;
    border: round $background-darken-1;
    background: $boost;
    padding: 1;
}

SmartContentTree .tree-stats {
    height: 2;
    padding: 0 1;
    text-align: right;
    color: $text-muted;
}

/* Tree node styling */
SmartContentTree Tree > .tree--cursor {
    background: $surface;
    color: $text;
    text-style: bold underline;
}

SmartContentTree Tree > .selected-node {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* ===== MODULE: features/_chatbooks.tcss ===== */
/* _chatbooks.tcss */
/* Styles for the Chatbooks window */

/* Main window */
ChatbooksWindow {
    background: $background;
}

/* Main horizontal layout */
#main-layout {
    layout: horizontal;
    height: 100%;
}

/* Left sidebar */
#chatbooks-sidebar {
    width: 30;
    background: $panel;
    border-right: solid $background-darken-1;
    padding: 1;
    layout: vertical;
}

.sidebar-title {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
    text-align: center;
}

#chatbooks-list {
    height: 1fr;
    background: $boost;
    border: round $background-darken-1;
}

#chatbooks-list ListItem {
    padding: 0 1;
    height: 3;
}

#chatbooks-list ListItem:hover {
    background: $surface-lighten-1;
    color: $text;
}

#chatbooks-list ListItem.-highlight {
    background: $surface;
    color: $text;
    text-style: bold underline;
}

/* Right content area */
#content-area {
    width: 1fr;
    layout: vertical;
    padding: 1;
}

/* Header section */
#chatbooks-header {
    background: $boost;
    border: round $background-darken-1;
    padding: 2;
    margin-bottom: 1;
}

.header-title {
    text-style: bold;
    text-align: center;
    color: $primary;
    margin-bottom: 1;
}

.header-subtitle {
    text-align: center;
    color: $text-muted;
    margin-bottom: 2;
}

#action-buttons {
    layout: horizontal;
    align: center middle;
    height: 3;
}

#action-buttons Button {
    margin: 0 1;
    min-width: 20;
}

/* Dynamic content area */
#dynamic-content {
    height: 1fr;
    background: $boost;
    border: round $background-darken-1;
    padding: 2;
    overflow-y: auto;
}

/* Welcome text */
.welcome-text {
    color: $text;
    padding: 2;
}

/* Status text */
.status-text {
    color: $text-muted;
    text-align: center;
    padding: 2;
}

/* Info text */
.info-text {
    color: $text-muted;
    text-align: center;
    padding: 2;
}

/* Templates text */
.templates-text {
    color: $text;
    padding: 2;
}

/* Chatbook details */
.chatbook-details {
    layout: vertical;
    padding: 1;
}

.chatbook-title {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
}

.chatbook-desc {
    color: $text;
    margin-bottom: 1;
}

.chatbook-size {
    color: $text-muted;
    margin-bottom: 1;
}

.chatbook-date {
    color: $text-muted;
    margin-bottom: 2;
}

/* Management buttons */
.management-buttons {
    layout: horizontal;
    height: 3;
    margin-top: 2;
}

.management-buttons Button {
    margin-right: 1;
    min-width: 12;
}

/* Error button variant */
Button.error {
    background: $error;
    color: $text;
}

Button.error:hover {
    background: $error-darken-1;
}

/* Template management styles */
.templates-list {
    layout: vertical;
    height: auto;
    max-height: 20;
    overflow-y: auto;
    margin: 1 0 2 0;
    background: $panel;
    border: round $background-darken-1;
    padding: 1;
}

.template-item {
    padding: 1;
    margin-bottom: 1;
    background: $boost;
    border: round $background-darken-1;
}

.template-item:hover {
    background: $primary 10%;
    border: round $primary;
}

.template-name {
    text-style: bold;
    color: $primary;
    margin-bottom: 0;
}

.template-description {
    color: $text-muted;
    text-style: italic;
}

/* ===== MODULE: features/_code_repo.tcss ===== */
/* ========================================
 * Code Repository Copy/Paste Feature Styles
 * ======================================== */

/* Repository browser container - now embedded in tab */
.repo-window-container {
    width: 100%;
    height: 100%;
    background: $surface;
    padding: 0;
}

/* ========================================
 * Header Section
 * ======================================== */

.repo-header {
    dock: top;
    height: 7;
    background: $boost;
    padding: 1;
    border-bottom: solid $primary;
}

.repo-header-content {
    layout: grid;
    grid-size: 4 2;
    grid-columns: 3fr 1fr 1fr 1fr;
    grid-rows: 3 2;
    grid-gutter: 1 1;
    width: 100%;
}

.repo-url-input {
    width: 100%;
}

#repo-url-input {
    width: 100%;
}

#load-repo-btn {
    min-width: 10;
}

#token-config-btn {
    min-width: 8;
}

#token-config-btn.token-configured {
    background: $success 20%;
    border: solid $success;
}

#branch-selector {
    min-width: 15;
}

#repo-settings-btn {
    width: 3;
    min-width: 3;
}

/* Selection summary */
.selection-summary {
    column-span: 4;
    layout: grid;
    grid-size: 3 1;
    grid-columns: 1fr 1fr 1fr;
    align: left middle;
    width: 100%;
}

.summary-stat {
    text-align: left;
    color: $text-muted;
}

/* ========================================
 * Filter Bar
 * ======================================== */

.filter-bar {
    dock: top;
    height: 3;
    background: $panel;
    layout: grid;
    grid-size: 6 1;
    grid-columns: 2fr 1fr 3 3 3 1fr;
    grid-gutter: 0 1;
    padding: 0 1;
    border-bottom: solid $primary-darken-1;
}

#file-search {
    width: 100%;
}

#file-type-filter {
    width: 100%;
}

.filter-quick-btn {
    width: 3;
    height: 3;
    min-width: 3;
    padding: 0;
    background: $surface;
    border: solid $primary-darken-2;
}

.filter-quick-btn:hover {
    background: $primary 30%;
    border: solid $primary;
}

/* ========================================
 * Main Content Area
 * ======================================== */

.main-content {
    layout: grid;
    grid-size: 2 1;
    grid-columns: 2fr 3fr;
    height: 1fr;
    background: $background;
}

/* Tree container */
.tree-container {
    border-right: solid $primary;
    overflow: hidden;
    padding: 1;
    background: $surface;
}

#repo-tree {
    height: 100%;
    width: 100%;
    border: none;
}

/* Preview container - now split into two sections */
.preview-panel {
    padding: 1;
    overflow: hidden;
    background: $surface;
    layout: vertical;
    height: 100%;
}

/* Aggregated text container (top half) */
.aggregated-text-container {
    height: 50%;
    margin-bottom: 1;
    layout: vertical;
}

/* File preview container (bottom half) */
.file-preview-container {
    height: 50%;
    layout: vertical;
}

.preview-header {
    height: 3;
    border-bottom: dashed $primary-darken-2;
    margin-bottom: 1;
    padding: 0 1;
    align: left middle;
}

#preview-title {
    text-style: bold;
    color: $primary;
}

#compilation-title {
    text-style: bold;
    color: $primary;
}

.preview-content {
    height: 1fr;
    border: round $primary-darken-2;
    padding: 1;
    background: $surface-darken-1;
    overflow-y: auto;
}

#file-preview {
    width: 100%;
    height: 100%;
    background: $surface-darken-1;
    padding: 1;
}

#aggregated-text {
    width: 100%;
    height: 100%;
    background: $surface-darken-1;
    padding: 1;
}

/* ========================================
 * Tree View Styles
 * ======================================== */

TreeView {
    height: 100%;
    width: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    border: solid $primary-darken-2;
    padding: 1;
    background: $surface;
}

.tree-container {
    width: 100%;
    height: auto;
}

.tree-loading {
    width: 100%;
    text-align: center;
    padding: 2;
    color: $text-muted;
}

.tree-empty {
    width: 100%;
    text-align: center;
    padding: 4;
    color: $text-muted;
}

/* Tree node styles */
TreeNode {
    height: 3;
    width: 100%;
}

.tree-node-row {
    layout: grid;
    grid-size: 4 1;
    grid-columns: auto 3 3 1fr;
    height: 3;
    align: left middle;
    width: 100%;
}

.tree-node-row:hover {
    background: $panel-lighten-1;
}

.tree-node-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

.tree-indent {
    width: auto;
    content-align: left middle;
}

.tree-expand-btn {
    width: 3;
    height: 3;
    min-width: 3;
    background: transparent;
    border: none;
    padding: 0;
}

.tree-expand-btn:hover {
    background: $surface-lighten-1;
    color: $text;
}

.tree-expand-spacer {
    width: 3;
    height: 3;
}

.tree-checkbox {
    width: 3;
    height: 3;
}

.tree-content {
    padding-left: 1;
    width: 100%;
    content-align: left middle;
}

/* ========================================
 * Action Bar
 * ======================================== */

.action-bar {
    dock: bottom;
    height: 3;
    background: $panel;
    layout: grid;
    grid-size: 6 1;
    grid-columns: 1fr auto auto auto auto 1fr;
    grid-gutter: 0 1;
    align: center middle;
    padding: 0 2;
    border-top: solid $primary;
}

.action-bar Button {
    min-width: 15;
}

#reset-btn {
    min-width: 10;
}

#generate-compilation-btn {
    min-width: 20;
}

/* ========================================
 * Loading Overlay
 * ======================================== */

.loading-overlay {
    dock: top;
    width: 100%;
    height: 100%;
    background: $background 90%;
    align: center middle;
    layer: above;
}

.loading-overlay.hidden {
    display: none;
}

.loading-overlay LoadingIndicator {
    margin-bottom: 2;
}

.loading-label {
    text-align: center;
    margin-top: 2;
    text-style: bold;
    color: $text;
}

/* ========================================
 * Error Messages
 * ======================================== */

.error-message {
    color: $error;
    text-align: center;
    padding: 2;
    text-style: bold;
}

/* ========================================
 * Responsive Adjustments
 * ======================================== */

/* Note: Textual doesn't support @media queries
   These styles would need to be applied dynamically
   based on terminal size detection in Python code */

/* For smaller terminals - apply these classes dynamically */
.repo-window-small .repo-window-container {
    width: 95%;
    height: 95%;
}

.repo-window-small .main-content {
    grid-columns: 1fr 1fr;
}

/* ========================================
 * Syntax Highlighting Support
 * ======================================== */

#file-preview {
    /* monospace font style */
}

/* Code highlighting classes would be added here */
.syntax-keyword {
    color: $primary;
    text-style: bold;
}

.syntax-string {
    color: $success;
}

.syntax-comment {
    color: $text-muted;
    text-style: italic;
}

.syntax-function {
    color: $accent;
}

.syntax-number {
    color: $warning;
}

/* ===== MODULE: features/_coding.tcss ===== */
/* ========================================
 * FEATURES: Coding Window
 * ======================================== 
 * Styles for the coding tab and its components
 * Includes sidebar navigation and content areas
 * ======================================== */

/* Main container */
CodingWindow {
    layout: horizontal;
    height: 100%;
    width: 100%;
}

/* Navigation pane (left sidebar) */
.coding-nav-pane {
    dock: left;
    width: 25%;
    min-width: 20;
    max-width: 40;
    background: $boost;
    padding: 1 2;
    border-right: thick $background-darken-1;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
}

.coding-nav-pane.collapsed {
    width: 0 !important;
    min-width: 0 !important;
    border-right: none !important;
    padding: 0 !important;
    overflow: hidden !important;
    display: none;
}

/* Navigation buttons */
.coding-nav-button {
    width: 100%;
    height: 3;
    margin: 1 0;
    padding: 0 2;
    text-align: left;
    background: $surface;
}

.coding-nav-button:hover {
    background: $surface-lighten-1;
    color: $text;
}

/* Content pane */
.coding-content-pane {
    height: 100%;
    width: 100%;
    padding: 2;
    background: $background;
}

/* Sidebar toggle button */
#coding-sidebar-toggle-button {
    dock: left;
    width: 3;
    height: 3;
    margin: 0 1 0 0;
    padding: 0;
    text-align: center;
    background: $surface;
}

#coding-sidebar-toggle-button.collapsed {
    dock: left;
    margin-left: 0;
}

/* View areas */
.coding-view-area {
    height: 100%;
    width: 100%;
    padding: 1;
}

/* Pane titles */
.coding-view-area .pane-title {
    text-style: bold underline;
    margin-bottom: 1;
    width: 100%;
    text-align: center;
}

/* Code repository specific */
#coding-view-repo-copy-paste Vertical {
    height: auto;
    align: center middle;
    padding: 2;
}

#coding-view-repo-copy-paste Label {
    margin-bottom: 2;
    text-align: center;
}

#open-repo-selector {
    width: auto;
    min-width: 30;
    height: 3;
    margin-top: 2;
}

/* ===== MODULE: features/_tab_dropdown.tcss ===== */
/* ========================================
 * FEATURES: Tab Dropdown Navigation
 * ======================================== 
 * Dropdown-based tab navigation system
 * Replaces horizontal tab bar with compact dropdown
 * ======================================== */

/* Container for the dropdown - positioned at top of window */
#tab-dropdown-container {
    dock: top;
    width: 100%;      /* Full width of window */
    height: 3;        /* Match the original tab bar height */
    padding: 0 1;
    background: $panel;
    border-bottom: solid $border;
    margin: 0;
    align: center middle;  /* Center the dropdown in the container */
}

/* The Select widget itself */
#tab-dropdown-select {
    width: 30;        /* Fixed width for the dropdown selector */
    height: 100%;
    background: $panel;
    color: $text;
    border: solid $border;
    border-bottom: solid $border;
    padding: 0 1;
    margin: 0;        /* No margin needed - centering handled by container */
}

/* Select widget hover state */
#tab-dropdown-select:hover {
    background: $panel-lighten-1;
    color: $text;
}

/* Select widget focus state */
#tab-dropdown-select:focus {
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
}

/* Dropdown overlay container */
#tab-dropdown-select SelectOverlay {
    background: $background;
    border: solid $border;
    max-height: 20;      /* Limit dropdown height to prevent full-screen coverage */
    margin-top: 0;       /* No gap - directly below the select */
    width: auto;         /* Auto width to fit content */
    min-width: 30;       /* Match the select widget width */
    /* layer: above; */  /* Ensure dropdown appears above other content if supported */
}

/* Individual options in the dropdown */
#tab-dropdown-select SelectOverlay Option {
    padding: 0 2;
    background: $panel;
    color: $text-muted;
    min-height: 3;       /* Comfortable click target */
}

/* Option hover state */
#tab-dropdown-select SelectOverlay Option:hover {
    background: $surface-lighten-1;
    color: $text;
}

/* Currently selected option (when dropdown is open) */
#tab-dropdown-select SelectOverlay Option.-selected {
    background: $ds-focus-bg;
    color: $ds-focus-fg;
    text-style: bold underline;
}

/* Disabled state (if needed in future) */
#tab-dropdown-select:disabled {
    opacity: 0.6;
    background: $panel-darken-1;
    color: $text-muted;  /* Using existing variable instead of $text-disabled */
}

/* Loading state (if needed for async operations) */
#tab-dropdown-select.-loading {
    color: $text-muted;
}

/* Textual CSS doesn't support transition animations */

/* Ensure dropdown doesn't interfere with main content */
#content {
    margin-top: 0;   /* No top margin needed - content flows after dropdown */
}

/* ===== MODULE: features/config_search.tcss ===== */
/* config_search.tcss */
/* Styling for configuration file search functionality */

/* Search container */
.config-search-container {
    width: 100%;
    margin-bottom: 1;
    padding: 1;
    background: $panel;
    border: solid $primary;
}

/* Search input */
.config-search-input {
    width: 100%;
    margin-bottom: 1;
}

/* Search results collapsible */
.config-search-results {
    width: 100%;
    margin-bottom: 1;
}

.config-search-results Collapsible > Contents {
    max-height: 20;
    overflow-y: auto;
}

/* Results list */
.config-results-list {
    width: 100%;
    height: auto;
    max-height: 20;
    background: $surface;
}

/* Individual search result item */
.config-search-result-item {
    width: 100%;
    padding: 1;
    margin-bottom: 0;
}

.config-search-result-item:hover {
    background: $boost;
}

/* Result info section */
.result-info {
    width: 1fr;
    padding-right: 1;
}

.result-path {
    text-style: bold;
    color: $primary;
}

.result-value {
    color: $text;
    margin-top: 0;
}

.result-context {
    color: $text-muted;
    text-style: italic;
    margin-top: 0;
}

/* Result action buttons */
.result-actions {
    dock: right;
    width: auto;
    height: 3;
    align: center middle;
}

.result-goto-btn {
    margin-right: 1;
    min-width: 8;
}

.result-edit-btn {
    min-width: 8;
}

/* Highlight matches in search results */
ConfigSearchResult.-highlight {
    background: $surface;
    color: $text;
    text-style: bold underline;
}

/* Ensure the config editor has proper spacing when search is shown */
#config-text-area {
    height: 1fr;
    min-height: 20;
}

/* Highlight effect for found UI elements */
.search-highlight {
    background: $warning 30%;
    border: solid $warning;
    border-bottom: solid $warning;
}

Input.search-highlight:focus,
TextArea.search-highlight:focus {
    background: $ds-input-focus-bg;
    color: $ds-text-primary;
    border: solid $ds-input-focus-border;
    border-bottom: solid $ds-input-focus-accent;
    outline: none;
}

Select.search-highlight {
    background: $warning 30%;
}

Checkbox.search-highlight {
    color: $warning;
}

TextArea.search-highlight {
    border: solid $warning;
    border-bottom: solid $warning;
}

/* ===== MODULE: features/feature_alerts.tcss ===== */
/* feature_alerts.tcss */
/* Styling for feature availability alerts */

FeatureNotAvailableDialog {
    width: 70;
    height: auto;
    background: $panel;
    border: thick $warning;
    align: center middle;
    layer: dialog;
    padding: 2 4;
    opacity: 0.98;
}

FeatureNotAvailableDialog > Vertical {
    width: 100%;
    height: auto;
}

FeatureNotAvailableDialog .dialog-title {
    text-align: center;
    color: $warning;
    text-style: bold;
    margin-bottom: 1;
    padding: 1 0;
}

FeatureNotAvailableDialog .dialog-message {
    margin-bottom: 1;
    text-align: center;
    color: $text;
}

FeatureNotAvailableDialog .install-command {
    background: $boost;
    padding: 1 2;
    margin: 1 0;
    border: solid $primary;
    text-align: center;
    color: $text-muted;
}

FeatureNotAvailableDialog .button-container {
    dock: bottom;
    align: center middle;
    height: 3;
    margin-top: 1;
}

FeatureNotAvailableDialog Button {
    margin: 0 1;
    min-width: 12;
}

/* Warning styles for disabled UI elements */
.feature-disabled-warning {
    color: $warning;
    text-style: italic;
    margin: 1;
    text-align: center;
}

/* Overlay for disabled features */
.feature-disabled-overlay {
    background: $background 50%;
    layer: overlay;
    align: center middle;
    padding: 2;
}

.feature-disabled-overlay Label {
    color: $warning;
    text-style: bold;
    text-align: center;
}

/* ===== MODULE: utilities/_helpers.tcss ===== */
/* ========================================
 * UTILITIES: Helpers
 * ======================================== 
 * Utility classes for common patterns
 * ======================================== */

/* Visibility utilities */
.hidden {
    display: none !important;
}

/* ===== MODULE: utilities/_states.tcss ===== */
/* ========================================
 * UTILITIES: States
 * ======================================== 
 * State modifiers: disabled, hidden, active, etc.
 * ======================================== */

/* --- Utility/Not-Tab Specific --- */

.disabled {
    /* Make the button semi-transparent. This is the most effective way
       to show it's inactive and works just like web CSS. */
    opacity: 0.6;

    /* To achieve a "grayscale" effect, we manually set the colors
       to be less vibrant, using Textual's design tokens for theming. */
    background: $panel-darken-2;
    color: $text-muted;

    /* You can also ensure the border is muted. */
    border: round $primary-darken-2;
}
/* --- End of Utility/Not-Tab Specific --- */

/* ===== MODULE: utilities/_overrides.tcss ===== */
/* ========================================
 * UTILITIES: Overrides
 * ======================================== 
 * Important overrides and edge case fixes
 * ======================================== */

/* No overrides currently needed */
